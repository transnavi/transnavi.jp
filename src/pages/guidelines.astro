---
import BaseLayout from '../layouts/BaseLayout.astro';
import guidelines from '../data/sogi-guidelines.json';

type Guideline = {
  title: string;
  institution: string;
  kind: 'national' | 'university' | 'local' | 'company' | 'academic';
  url: string;
  year?: string;
  note?: string;
};

const groupDefs: { key: Guideline['kind']; title: string; intro: string }[] = [
  { key: 'national', title: '国（省庁）の通知・手引き', intro: '学校や職場での対応のもとになる、国の方針です。' },
  { key: 'university', title: '大学のガイドライン', intro: '入学・在学中の名前や呼称、トイレ・更衣室、健康診断などの対応をまとめたものです。' },
  { key: 'local', title: '自治体のガイドライン・ハンドブック', intro: '都道府県・市区町村による、職員・学校・窓口向けの手引きです。' },
  { key: 'company', title: '職場・企業向け', intro: '働く場での取り組みや、就職活動に関する指針です。' },
  { key: 'academic', title: '学会・専門団体', intro: '医療・専門職の団体による指針です。' },
];

const all = guidelines as Guideline[];
const groups = groupDefs
  .map((g) => ({ ...g, items: all.filter((x) => x.kind === g.key).sort((a, b) => a.institution.localeCompare(b.institution, 'ja')) }))
  .filter((g) => g.items.length > 0);
const total = all.length;
---

<BaseLayout
  title="学校・職場・自治体のSOGIガイドライン - とらんすナビ"
  description="性的指向・性自認（SOGI）やトランスジェンダーへの対応について、国・大学・自治体・企業などが公表している公式ガイドラインへのリンク集。"
>
  <article class="article-shell">
    <div class="eyebrow">調べる</div>
    <h1>学校・職場・自治体のSOGIガイドライン</h1>
    <p class="lead">
      いま、多くの学校・大学・自治体・企業が、性的指向や性自認（<a href="/glossary/sogi/">SOGI</a>）やトランスジェンダーへの対応をまとめた公式のガイドラインを公表しています。「自分の通う学校や働く場にも、こういう方針がある（つくれる）」と知ることは、心強い手がかりになります。ここでは、発行した機関の公式ページへのリンクを集めています。
    </p>

    <div class="page-disclaimer">
      内容や名称、URLは更新されることがあります。最新版は、必ず各機関の公式サイトで確認してください。ここに載っていない学校・自治体・企業にも、独自の取り組みがあることがあります。足したいものがあれば<a href="/edit/">教えてください</a>。
    </div>

    {total === 0 ? (
      <p class="resource-section-intro">準備中です。</p>
    ) : (
      groups.map((group) => (
        <section class="link-section" aria-labelledby={`g-${group.key}`}>
          <h2 id={`g-${group.key}`}>{group.title}</h2>
          <p class="resource-section-intro">{group.intro}</p>
          <ul class="day-list">
            {group.items.map((item) => (
              <li class="day-item">
                <span class="day-date">{item.institution}</span>
                <div class="day-body">
                  <span class="day-name">
                    <a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
                    {item.year && <span class="works-col-year"> （{item.year}）</span>}
                  </span>
                  {item.note && <span class="day-note">{item.note}</span>}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))
    )}

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/allies/">周囲の人へ</a>
      <a class="word-chip" href="/legal-change/">戸籍と名前の変更</a>
      <a class="word-chip" href="/support/">相談先</a>
      <a class="word-chip" href="/resources/">関連サイト</a>
    </nav>
  </article>
</BaseLayout>
