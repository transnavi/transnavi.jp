---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('articles'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, 'ja'));

const pageLinks = [
  {
    href: '/library/',
    title: '資料集',
    description: '既存の資料や読みものを見やすく整理したページです。',
  },
  {
    href: '/about/',
    title: 'このサイトについて',
    description: 'サイトの目的と公開している内容をまとめています。',
  },
  {
    href: '/legal/',
    title: '掲載について',
    description: '掲載方針、修正依頼、免責の考え方を案内しています。',
  },
  {
    href: '/edit/',
    title: '情報を送る',
    description: '誤りの修正や地域情報の追加連絡はこちらから送れます。',
  },
];
---

<BaseLayout title="記事 - とらんすナビ" description="記事一覧。">
  <section class="article-shell">
    <div class="eyebrow">記事</div>
    <h1>記事</h1>
    <p class="lead">医療、制度、生活、安全に関する記事。</p>
    <div class="article-list">
      {articles.map((article) => (
        <a class="article-link" href={`/articles/${article.id}/`}>
          <strong>{article.data.title}</strong>
          <span>{article.data.description}</span>
        </a>
      ))}
    </div>

    <section class="article-section" aria-labelledby="article-pages">
      <h2 id="article-pages">そのほかのページ</h2>
      <div class="article-list">
        {pageLinks.map((pageLink) => (
          <a class="article-link" href={pageLink.href}>
            <strong>{pageLink.title}</strong>
            <span>{pageLink.description}</span>
          </a>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
