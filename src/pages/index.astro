---
import BaseLayout from '../layouts/BaseLayout.astro';
import Mascot from '../components/Mascot.astro';

// The homepage's main wayfinding (the header nav is hidden on the home page):
// every header-nav destination. Labels are short (compact on phones); the
// fuller description is kept as a hover tooltip.
const heroNav = [
  { href: '/start/', label: 'はじめての方へ', desc: 'まだよくわからない、というところから読めます。', primary: true },
  { href: '/basics/', label: '基本のことば', desc: 'トランス・シス・ノンバイナリーって？　やさしく整理。' },
  { href: '/learn/', label: '知る・学ぶ', desc: '性別違和、移行、暮らしのこと。テーマの一覧へ。' },
  { href: '/glossary/', label: '用語集', desc: '言葉の意味を、ひとつずつ調べる。' },
  { href: '/support/', label: '相談先', desc: '誰かに話したくなったら。身近で安全なところから。' },
  { href: '/clinics/', label: '医療機関', desc: 'ホルモンや診断の病院。地図でも探せます。' },
  { href: '/resources/', label: 'リンク', desc: '外部サイト、当事者団体、リンク集。' },
];

const routes = [
  { href: '/start/', when: '自分がトランスかも', to: 'はじめての方へ' },
  { href: '/basics/', when: 'トランス・シス・ノンバイナリーって？', to: '基本のことば' },
  { href: '/dysphoria/', when: '感じている違和感を知りたい', to: '性別違和を知る' },
  { href: '/transition/', when: 'これからできることを知りたい', to: '性別移行を知る' },
  { href: '/glossary/', when: '言葉がわからない', to: '用語集' },
  { href: '/support/', when: '相談したい', to: '相談先' },
  { href: '/clinics/', when: '病院を探したい', to: '医療機関一覧' },
  { href: '/map/', when: '近くの医療機関や団体を探したい', to: '地図で探す' },
  { href: '/allies/', when: '家族・学校・友人に説明したい', to: '周囲の人へ' },
];
---

<BaseLayout
  title="とらんすナビ - 日本のトランスジェンダー情報ウィキ"
  description="「自分はトランスかもしれない」と思ったとき、日本で情報を探すための出発点。まだ答えが出ていなくても大丈夫です。"
>
  <section class="intro hero" aria-labelledby="site-description">
    <div class="hero-people" aria-hidden="true">
      <Mascot name="person-2" variant="plain" />
      <Mascot name="person-3" variant="plain" />
      <Mascot name="person-1" variant="plain" />
      <Mascot name="person-4" variant="plain" />
      <Mascot name="person-5" variant="plain" />
    </div>
    <h1 id="site-description">「自分はトランスかもしれない」と思ったあなたへ</h1>
    <p class="lead">
      まだ答えが出ていなくても、大丈夫です。<br />
      ここは、トランスジェンダーのことを調べたいときの、最初の入り口を目指しています。
    </p>
    <nav class="hero-nav" aria-label="主要なページ">
      {heroNav.filter((item) => item.primary).map((item) => (
        <a class="hero-button hero-button-primary hero-button-lead" href={item.href} title={item.desc}>
          {item.label}
        </a>
      ))}
      <div class="hero-grid">
        {heroNav.filter((item) => !item.primary).map((item) => (
          <a class="hero-button hero-button-compact" href={item.href} title={item.desc}>
            {item.label}
          </a>
        ))}
      </div>
      <a class="hero-button hero-button-wide" href="/sitemap/" title="サイトのすべてのページを、テーマごとに一覧で見る">
        すべてのページを見る
      </a>
    </nav>
  </section>

  <section aria-labelledby="reassure">
    <h2 id="reassure">まず、安心してほしいこと</h2>
    <ul class="assure-list assure-list-pills">
      <li>すぐに決めなくていい</li>
      <li>ひとりで抱えなくていい</li>
      <li>誰かに話すかどうかは自分で選んでいい</li>
      <li>知ろうとすることは、悪いことじゃない</li>
    </ul>
  </section>

  <section aria-labelledby="routes">
    <h2 id="routes">こんなとき、どこを読めばいい？</h2>
    <div class="route-list">
      {routes.map((route) => (
        <a class="route-item" href={route.href}>
          <span class="route-when">{route.when}</span>
          <span class="route-dest"><span class="route-arrow" aria-hidden="true">→</span>{route.to}</span>
        </a>
      ))}
    </div>
  </section>

  <section aria-labelledby="community-heading">
    <h2 id="community-heading">なかまと、ゆるくつながる</h2>
    <p>同じように悩んだり、考えたりしている人たちが集まる、おしゃべりの場（Discord）があります。見るだけでも、書き込んでも大丈夫。あなたのペースでどうぞ。</p>
    <div class="hero-actions">
      <a class="hero-button hero-button-primary" href="https://discord.gg/S8NJGeS3Da" target="_blank" rel="noreferrer">Discord に参加する</a>
    </div>
  </section>

  <section class="notice" aria-labelledby="about-site">
    <h2 id="about-site">このサイトについて（やくそくごと）</h2>
    <p class="resource-section-intro">このサイトには、こんなことがまとめてあります。</p>
    <ul class="assure-list assure-list-plain">
      <li>ことばの意味、からだと医療のこと、暮らしや手続き、相談先、地域の医療機関、調べるための資料を、やさしくまとめています。</li>
      <li>ここは、知っておくための場所です。最後に決めるのは、お医者さんや専門の窓口、そしてあなた自身です。</li>
      <li>読む人の安全を、いちばんに大切にしています。急がせたり、どれかを選ばせたりはしません。</li>
      <li>新しいことに気づいたら、その都度なおしています。ただ、いつも最新とはかぎりません。</li>
    </ul>
    <p class="resource-section-intro">古いところやまちがいに気づいたとき、足したいことがあるときは、よかったら教えてください（<a href="/edit/">情報を送る</a>）。どこから読んでも、迷ったまま読んでも、大丈夫です。</p>
  </section>

  <aside class="home-flag" aria-label="このサイトの立場">
    <p class="home-flag-frame">このサイトを、そういう気持ちでつくっています。</p>
    <p class="home-flag-motto">私たちの存在そのものが、悪意への最大の抵抗だ。</p>
  </aside>
</BaseLayout>
