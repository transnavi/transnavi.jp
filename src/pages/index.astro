---
import BaseLayout from '../layouts/BaseLayout.astro';
import Mascot from '../components/Mascot.astro';

const actions = [
  { href: '/start/', label: 'はじめに', primary: true },
  { href: '/glossary/', label: '用語を知る' },
  { href: '/support/', label: '相談先を探す' },
  { href: '/clinics/', label: '医療機関を探す' },
];

const routes = [
  { href: '/start/', when: '自分がトランスかも', to: 'はじめての方へ' },
  { href: '/dysphoria/', when: '感じている違和感を知りたい', to: '性別違和を知る' },
  { href: '/transition/', when: 'これからできることを知りたい', to: '性別移行を知る' },
  { href: '/glossary/', when: '言葉がわからない', to: '用語集' },
  { href: '/support/', when: '相談したい', to: '相談先' },
  { href: '/clinics/', when: '病院を探したい', to: '医療機関一覧' },
  { href: '/allies/', when: '家族・学校・友人に説明したい', to: '周囲の人へ' },
];
---

<BaseLayout
  title="とらんすナビ - 日本のトランスジェンダー情報ウィキ"
  description="「自分はトランスかもしれない」と思ったとき、日本で情報を探すための出発点。まだ答えが出ていなくても大丈夫です。"
>
  <section class="intro hero" aria-labelledby="site-description">
    <Mascot name="home-welcome" variant="hero" />
    <h1 id="site-description">「自分はトランスかもしれない」と思ったあなたへ</h1>
    <p class="lead">
      まだ答えが出ていなくても、大丈夫。<br />
      このサイトは、日本でトランスジェンダーのことを調べたいときの、最初の入り口です。
    </p>
    <div class="hero-actions">
      {actions.map((action) => (
        <a class:list={['hero-button', { 'hero-button-primary': action.primary }]} href={action.href}>
          {action.label}
        </a>
      ))}
    </div>
  </section>

  <section aria-labelledby="reassure">
    <h2 id="reassure">まず、安心してほしいこと</h2>
    <ul class="assure-list">
      <li>すぐに決めなくていい</li>
      <li>ひとりで抱えなくていい</li>
      <li>誰かに話すかどうかは自分で選んでいい</li>
      <li>知ろうとすることは、悪いことじゃない</li>
    </ul>
  </section>

  <section aria-labelledby="routes">
    <h2 id="routes">こんなとき、どこを読めばいい？</h2>
    <div class="route-list">
      {routes.map((route) => (
        <a class="route-item" href={route.href}>
          <span class="route-when">{route.when}</span>
          <span class="route-arrow" aria-hidden="true">→</span>
          <span class="route-to">{route.to}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="notice" aria-labelledby="about-site">
    <h2 id="about-site">このサイトについて（やくそくごと）</h2>
    <p class="resource-section-intro">このサイトには、こんなことがまとめてあります。</p>
    <ul class="assure-list assure-list-plain">
      <li>ことばの意味、からだと医療のこと、暮らしや手続き、相談先、地域の医療機関、調べるための資料を、やさしくまとめています。</li>
      <li>ここは、知っておくための場所です。最後に決めるのは、お医者さんや専門の窓口、そしてあなた自身です。</li>
      <li>読む人の安全を、いちばんに大切にしています。急がせたり、どれかを選ばせたりはしません。</li>
      <li>新しいことに気づいたら、その都度なおしています。ただ、いつも最新とはかぎりません。</li>
    </ul>
    <p class="resource-section-intro">古いところやまちがいに気づいたとき、足したいことがあるときは、よかったら教えてください（<a href="/edit/">情報を送る</a>）。どこから読んでも、迷ったまま読んでも、大丈夫です。</p>
  </section>

  <aside class="home-flag" aria-label="このサイトの立場">
    <p class="home-flag-frame">このサイトを、そういう気持ちでつくっています。</p>
    <p class="home-flag-motto">私たちの存在そのものが、悪意への最大の抵抗だ。</p>
  </aside>
</BaseLayout>
