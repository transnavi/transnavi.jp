---
import BaseLayout from '../layouts/BaseLayout.astro';

type Flag = { name: string; colors?: string[]; gradient?: string; note: string };

const flags: Flag[] = [
  {
    name: 'レインボーフラッグ（プライドフラッグ）',
    colors: ['#e40303', '#ff8c00', '#ffed00', '#008026', '#004dff', '#750787'],
    note: 'LGBTQ+ 全体を象徴する旗。1978年にギルバート・ベイカーがデザインしました。各色に生命・癒し・自然・調和などの意味があります。',
  },
  {
    name: 'プログレス・プライド・フラッグ',
    colors: ['#e40303', '#ff8c00', '#ffed00', '#008026', '#004dff', '#750787'],
    note: '2018年にダニエル・クェーサーが考案。レインボーに加え、トランスの色（水色・桃色・白）と、黒・茶色（人種的マイノリティや、HIV/AIDSで亡くなった人々など）の山形（シェブロン）を重ね、「まだ続く前進」を表します。',
  },
  {
    name: 'トランスジェンダー・プライド・フラッグ',
    colors: ['#5BCEFA', '#F5A9B8', '#FFFFFF', '#F5A9B8', '#5BCEFA'],
    note: '1999年にモニカ・ヘルムズが考案。水色は男の子、桃色は女の子、白はノンバイナリーや移行中の人、性別を定めない人などを表します。',
  },
  {
    name: 'ノンバイナリー・フラッグ',
    colors: ['#FCF434', '#FFFFFF', '#9C59D1', '#2C2C2C'],
    note: '2014年にカイ・ローワンが考案。黄＝男女の枠の外、白＝多くの／すべての性、紫＝男女の中間、黒＝性別を持たない人を表します。',
  },
  {
    name: 'ジェンダークィア・フラッグ',
    colors: ['#B57EDC', '#FFFFFF', '#4A8123'],
    note: '紫＝両性的、白＝無性的、緑＝男女の枠の外であることを表します。',
  },
  {
    name: 'ジェンダーフルイド・フラッグ',
    colors: ['#FF75A2', '#FFFFFF', '#BE18D6', '#000000', '#333EBD'],
    note: '性のあり方が、時とともに流動的に変化する人を表します。',
  },
  {
    name: 'アジェンダー・フラッグ',
    colors: ['#000000', '#BCC4C7', '#FFFFFF', '#B7F684', '#FFFFFF', '#BCC4C7', '#000000'],
    note: '性別を持たない、または特定しない人を表します。',
  },
  {
    name: 'インターセックス・フラッグ',
    gradient: 'radial-gradient(circle at center, #FFD800 0 33%, #7902AA 33% 47%, #FFD800 47% 100%)',
    note: '2013年にモーガン・カーペンターが考案。黄色の地に紫の円で、「完全であること」と、自分のからだのままでいる権利を表します。',
  },
  {
    name: 'バイセクシュアル・フラッグ',
    gradient: 'linear-gradient(180deg, #D60270 0 40%, #9B4F96 40% 60%, #0038A8 60% 100%)',
    note: '1998年にマイケル・ペイジが考案。桃＝同性への惹かれ、青＝異性への惹かれ、紫＝その重なりを表します。',
  },
  {
    name: 'パンセクシュアル・フラッグ',
    colors: ['#FF218C', '#FFD800', '#21B1FF'],
    note: '相手の性別にとらわれずに惹かれることを表します。',
  },
  {
    name: 'アセクシュアル・フラッグ',
    colors: ['#000000', '#A3A3A3', '#FFFFFF', '#800080'],
    note: '他者に性的に惹かれにくい、または惹かれない人を表します。',
  },
  {
    name: 'アロマンティック・フラッグ',
    colors: ['#3DA542', '#A7D379', '#FFFFFF', '#A9A9A9', '#000000'],
    note: '他者に恋愛的に惹かれにくい、または惹かれない人を表します。',
  },
  {
    name: 'レズビアン・フラッグ',
    colors: ['#D52D00', '#FF9A56', '#FFFFFF', '#D362A4', '#A30262'],
    note: '女性を愛する女性を表す旗。2018年ごろに広まった5色版です。',
  },
];

function swatch(flag: Flag): string {
  if (flag.gradient) return flag.gradient;
  const colors = flag.colors ?? [];
  const n = colors.length;
  const stops = colors
    .map((c, i) => `${c} ${((i / n) * 100).toFixed(2)}% ${(((i + 1) / n) * 100).toFixed(2)}%`)
    .join(', ');
  return `linear-gradient(180deg, ${stops})`;
}

const days = [
  { date: '3月31日', name: '国際トランスジェンダー認知の日（TDOV）', note: 'トランスの人々の存在と歩みを可視化し、祝う日。' },
  { date: '4月26日', name: 'レズビアン・ビジビリティ・デー', note: 'レズビアンの可視化を目的とした日。' },
  { date: '5月17日', name: 'IDAHOBIT（ホモフォビア等に反対する国際デー）', note: '1990年にWHOが同性愛を国際疾病分類から除外した日にちなみます。' },
  { date: '5月22日', name: 'ハーヴェイ・ミルク・デー', note: '米国の活動家・政治家ハーヴェイ・ミルクを記念する日。' },
  { date: '5月24日', name: 'パンセクシュアル＆パンロマンティック認知の日', note: 'パンセクシュアルの人々の可視化の日。' },
  { date: '6月（1か月）', name: 'プライド月間（Pride Month）', note: '1969年のストーンウォールの蜂起にちなみ、世界各地でパレードやイベントが行われます。' },
  { date: '7月14日', name: 'ノンバイナリーの日', note: 'ノンバイナリーの人々の認知を広める日。' },
  { date: '9月23日', name: 'バイ・ビジビリティ・デー', note: 'バイセクシュアルの可視化を目的とした日。' },
  { date: '10月（1か月）', name: 'LGBTヒストリー月間', note: '主に米国で、歴史を振り返り学ぶ月間。' },
  { date: '10月11日', name: '国際カミングアウトデー', note: 'カミングアウトについて考える日。話すかどうかは、いつでも自分で選べます。' },
  { date: '10月下旬ごろ（1週間）', name: 'アセクシュアル認知週間（Ace Week）', note: 'アセクシュアル・スペクトラムの認知を広める週間。' },
  { date: '10月26日', name: 'インターセックス認知の日', note: 'インターセックスの人々の人権について考える日。' },
  { date: '11月13〜19日', name: 'トランスジェンダー認知週間', note: 'トランスの人々への理解を深める週間。' },
  { date: '11月20日', name: 'トランスジェンダー追悼の日（TDOR）', note: '嫌悪や暴力によって命を奪われたトランスの人々を追悼する日。' },
];

// 時期が決まっている近日のイベント（過ぎたら見直してください）。
const upcoming = [
  {
    date: '2026年6月4日（木）',
    name: 'プライドデモ（渋谷）',
    place: '東京・渋谷',
    note: '渋谷で行われるプライドのデモ行進。集合時間や経路などの最新情報は、主催者の案内をご確認ください。',
  },
  {
    date: '2026年6月6日（土）〜7日（日）',
    name: 'Tokyo Pride 2026',
    place: '東京・渋谷／代々木公園周辺',
    note: 'テーマは「多様性と平等がひらく未来」。パレード（デモ行進）は6月7日に行われます。',
    url: 'https://pride.tokyo/',
  },
];

const japanEvents = [
  { when: '例年 春〜初夏ごろ', name: '東京レインボープライド（Tokyo Pride）', note: '東京・渋谷／代々木などで開催される、国内最大級のプライドイベント。' },
  { when: '例年 5月ごろ', name: 'K.G. Rainbow Week（関西学院大学）', note: 'IDAHOBIT に合わせて関西学院大学で開かれる、性の多様性に関する年次イベント。' },
  { when: '例年 秋ごろ', name: '関西レインボーフェスタ', note: '大阪で開催されるプライドイベント。' },
];
---

<BaseLayout
  title="プライドフラッグと記念日 - とらんすナビ"
  description="プライドフラッグの意味と、LGBTQ+ に関する国際的な記念日・週間・月間のまとめ。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>プライドフラッグと記念日</h1>
    <p class="lead">
      旗や記念日には、ここまで歩いてきた人たちの思いと、「あなたは一人じゃない」という願いが込められています。ぜんぶ覚えなくて大丈夫。気になったものから、のぞいてみてください。
    </p>

    {upcoming.length > 0 && (
      <section aria-labelledby="upcoming-heading">
        <h2 id="upcoming-heading">近日のイベント</h2>
        <ul class="day-list">
          {upcoming.map((event) => (
            <li class="day-item day-item-upcoming">
              <span class="day-date">{event.date}</span>
              <div class="day-body">
                <span class="day-name">
                  {event.url ? <a href={event.url} target="_blank" rel="noreferrer">{event.name}</a> : event.name}
                </span>
                <span class="day-note">{event.place} ／ {event.note}</span>
              </div>
            </li>
          ))}
        </ul>
        <p class="resource-section-intro">日時や場所は変わることがあります。参加する前に主催者の最新情報を確認してください。</p>
      </section>
    )}

    <section aria-labelledby="flags-heading">
      <h2 id="flags-heading">プライドフラッグ</h2>
      <p class="resource-section-intro">色や数は時代や地域によって少しずつ違うことがあります。</p>
      <div class="flag-grid">
        {flags.map((flag) => (
          <div class="flag-card">
            <div class="flag-swatch" style={`background:${swatch(flag)}`} role="img" aria-label={`${flag.name}の配色`}></div>
            <div class="flag-text">
              <h3>{flag.name}</h3>
              <p>{flag.note}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="resource-section-intro">
        <strong>Xジェンダー</strong>は日本で使われる言葉で、決まった一つの旗はなく、ノンバイナリーやジェンダークィアの旗が用いられることがあります。性のあり方そのものについては<a href="/gender/">性別は、男女だけじゃない</a>もどうぞ。
      </p>
    </section>

    <section aria-labelledby="days-heading">
      <h2 id="days-heading">記念日・週間・月間</h2>
      <p class="resource-section-intro">主な国際的な記念日を、1年の流れにそって並べています。</p>
      <ul class="day-list">
        {days.map((day) => (
          <li class="day-item">
            <span class="day-date">{day.date}</span>
            <div class="day-body">
              <span class="day-name">{day.name}</span>
              <span class="day-note">{day.note}</span>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="japan-heading">
      <h2 id="japan-heading">日本の主なイベント</h2>
      <ul class="day-list">
        {japanEvents.map((event) => (
          <li class="day-item">
            <span class="day-date">{event.when}</span>
            <div class="day-body">
              <span class="day-name">{event.name}</span>
              <span class="day-note">{event.note}</span>
            </div>
          </li>
        ))}
      </ul>
      <p class="resource-section-intro">開催時期は年によって変わります。最新の情報は<a href="/resources/">各団体のサイト</a>で確認してください。</p>
    </section>
  </article>
</BaseLayout>
