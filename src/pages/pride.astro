---
import BaseLayout from '../layouts/BaseLayout.astro';

const days = [
  { date: '3月31日', name: '国際トランスジェンダー認知の日（TDOV）', note: 'トランスの人々の存在と歩みを可視化し、祝う日。' },
  { date: '4月26日', name: 'レズビアン・ビジビリティ・デー', note: 'レズビアンの可視化を目的とした日。' },
  { date: '5月17日', name: 'IDAHOBIT（ホモフォビア等に反対する国際デー）', note: '1990年にWHOが同性愛を国際疾病分類から除外した日にちなみます。' },
  { date: '5月22日', name: 'ハーヴェイ・ミルク・デー', note: '米国の活動家・政治家ハーヴェイ・ミルクを記念する日。' },
  { date: '5月24日', name: 'パンセクシュアル＆パンロマンティック認知の日', note: 'パンセクシュアルの人々の可視化の日。' },
  { date: '6月（1か月）', name: 'プライド月間（Pride Month）', note: '1969年のストーンウォールの蜂起にちなみ、世界各地でパレードやイベントが行われます。' },
  { date: '7月14日', name: 'ノンバイナリーの日', note: 'ノンバイナリーの人々の認知を広める日。' },
  { date: '9月23日', name: 'バイ・ビジビリティ・デー', note: 'バイセクシュアルの可視化を目的とした日。' },
  { date: '10月（1か月）', name: 'LGBTヒストリー月間', note: '主に米国で、歴史を振り返り学ぶ月間。' },
  { date: '10月11日', name: '国際カミングアウトデー', note: 'カミングアウトについて考える日。話すかどうかは、いつでも自分で選べます。' },
  { date: '10月下旬ごろ（1週間）', name: 'アセクシュアル認知週間（Ace Week）', note: 'アセクシュアル・スペクトラムの認知を広める週間。' },
  { date: '10月26日', name: 'インターセックス認知の日', note: 'インターセックスの人々の人権について考える日。' },
  { date: '11月13〜19日', name: 'トランスジェンダー認知週間', note: 'トランスの人々への理解を深める週間。' },
  { date: '11月20日', name: 'トランスジェンダー追悼の日（TDOR）', note: '嫌悪や暴力によって命を奪われたトランスの人々を追悼する日。' },
];

// 時期が決まっている近日のイベント（過ぎたら見直してください）。
const upcoming = [
  {
    date: '2026年6月4日（木）',
    name: 'プライドデモ（渋谷）',
    place: '東京・渋谷',
    note: '渋谷で行われるプライドのデモ行進。集合時間や経路などの最新情報は、主催者の案内をご確認ください。',
  },
];

const japanEvents = [
  { when: '例年 春〜初夏ごろ', name: '東京レインボープライド（Tokyo Pride）', note: '東京・渋谷／代々木などで開催される、国内最大級のプライドイベント。' },
  { when: '例年 5月ごろ', name: 'K.G. Rainbow Week（関西学院大学）', note: 'IDAHOBIT に合わせて関西学院大学で開かれる、性の多様性に関する年次イベント。' },
  { when: '例年 秋ごろ', name: '関西レインボーフェスタ', note: '大阪で開催されるプライドイベント。' },
];
---

<BaseLayout
  title="プライドの記念日・イベント - とらんすナビ"
  description="LGBTQ+ に関する国際的な記念日・週間・月間と、日本の主なプライドイベントのまとめ。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>プライドの記念日・イベント</h1>
    <p class="lead">
      記念日には、ここまで歩いてきた人たちの思いと、「あなたは一人じゃない」という願いが込められています。ぜんぶ覚えなくて大丈夫。気になったものから、のぞいてみてください。旗やシンボルについては<a href="/flags/">プライドフラッグ</a>をどうぞ。
    </p>

    {upcoming.length > 0 && (
      <section aria-labelledby="upcoming-heading">
        <h2 id="upcoming-heading">近日のイベント</h2>
        <ul class="day-list">
          {upcoming.map((event) => (
            <li class="day-item day-item-upcoming">
              <span class="day-date">{event.date}</span>
              <div class="day-body">
                <span class="day-name">
                  {event.url ? <a href={event.url} target="_blank" rel="noreferrer">{event.name}</a> : event.name}
                </span>
                <span class="day-note">{event.place} ／ {event.note}</span>
              </div>
            </li>
          ))}
        </ul>
        <p class="resource-section-intro">日時や場所は変わることがあります。参加する前に主催者の最新情報を確認してください。</p>
      </section>
    )}

    <section aria-labelledby="days-heading">
      <h2 id="days-heading">記念日・週間・月間</h2>
      <p class="resource-section-intro">主な国際的な記念日を、1年の流れにそって並べています。</p>
      <ul class="day-list">
        {days.map((day) => (
          <li class="day-item">
            <span class="day-date">{day.date}</span>
            <div class="day-body">
              <span class="day-name">{day.name}</span>
              <span class="day-note">{day.note}</span>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="japan-heading">
      <h2 id="japan-heading">日本の主なイベント</h2>
      <ul class="day-list">
        {japanEvents.map((event) => (
          <li class="day-item">
            <span class="day-date">{event.when}</span>
            <div class="day-body">
              <span class="day-name">{event.name}</span>
              <span class="day-note">{event.note}</span>
            </div>
          </li>
        ))}
      </ul>
      <p class="resource-section-intro">開催時期は年によって変わります。最新の情報は<a href="/resources/">各団体のサイト</a>で確認してください。</p>
    </section>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/flags/">プライドフラッグ</a>
      <a class="word-chip" href="/coming-out/">カミングアウト入門</a>
      <a class="word-chip" href="/resources/">関連サイト</a>
    </nav>
  </article>
</BaseLayout>
