      <a class="word-chip" href="/legal-change/">戸籍と名前の変更</a>
      <a class="word-chip" href="/safety/">安全とこころ</a>
      <a class="word-chip" href="/support/">相談先</a>
    </nav>
    <References route="/everyday/" />
  </article>
</BaseLayout>
