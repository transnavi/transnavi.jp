---
import BaseLayout from '../layouts/BaseLayout.astro';
import clinicsData from '../data/clinics.json';
import poisData from '../data/map-pois.json';
import type { Clinic } from '../types/clinic';
import { categoriesOf, primaryGenre, clinicMapTags } from '../utils/clinic-genre';

const clinics = (clinicsData as Clinic[])
  .filter((c) => typeof c.lat === 'number' && typeof c.lng === 'number')
  .map((c) => ({
    id: c.id,
    name: c.name,
    area: [c.prefecture, c.city].filter(Boolean).join(' '),
    approx: c.geoSource !== 'address',
    // Coloured by 診療区分 (ホルモン療法 / 精神科・診断 / 手術) — the same buckets as
    // the /clinics/ finder, so the two pages are consistent.
    genre: primaryGenre(categoriesOf(c)),
    tags: clinicMapTags(c),
    lat: c.lat,
    lng: c.lng,
  }));

const pois = poisData as { name: string; type: string; url: string; lat: number; lng: number }[];
const mapData = { clinics, pois };
---

<BaseLayout
  title="地図で探す（医療機関・団体・イベント） - とらんすナビ"
  description="医療機関を診療区分（ホルモン療法・精神科や診断・手術）の色で表示。性別適合手術（SRS）の病院（日本・タイ・韓国）や声の手術（VFS）、当事者団体・拠点、大学のLGBTQサークル、公的な相談窓口、プライドイベントも地図の上でまとめて探せます。"
>
  <article class="article-shell">
    <div class="eyebrow">地図で探す</div>
    <h1>地図で探す</h1>
    <p class="lead">
      医療機関を診療区分ごとの色（ホルモン療法・精神科や診断・手術）で表示し、あわせて当事者団体・拠点、大学のLGBTQサークル、公的な相談窓口、イベントも地図の上でまとめて見られます。「手術」には性別適合手術（SRS）や声の手術（VFS）などが含まれます。気になるピンをタップすると、掲載ページや公式サイトへ進めます。地図は最初は日本を表示しますが、引いて（ズームアウトして）いくと、タイや韓国などのSRS病院も表示されます。
    </p>

    <div class="map-legend" aria-label="地図の凡例（診療区分ほか）">
      <label><input type="checkbox" data-map-toggle="hrt" checked /><span class="map-dot map-dot-hrt" aria-hidden="true"></span>ホルモン療法</label>
      <label><input type="checkbox" data-map-toggle="mental" checked /><span class="map-dot map-dot-mental" aria-hidden="true"></span>精神科・診断</label>
      <label><input type="checkbox" data-map-toggle="surgery" checked /><span class="map-dot map-dot-surgery" aria-hidden="true"></span>手術（SRS・声など）</label>
      <label><input type="checkbox" data-map-toggle="org" checked /><span class="map-dot map-dot-org" aria-hidden="true"></span>団体・拠点</label>
      <label><input type="checkbox" data-map-toggle="circle" checked /><span class="map-dot map-dot-circle" aria-hidden="true"></span>学生サークル</label>
      <label><input type="checkbox" data-map-toggle="desk" checked /><span class="map-dot map-dot-desk" aria-hidden="true"></span>相談窓口</label>
      <label><input type="checkbox" data-map-toggle="event" checked /><span class="map-dot map-dot-event" aria-hidden="true"></span>イベント</label>
    </div>

    <div id="map" class="map-canvas" role="application" aria-label="医療機関・団体・イベントの地図">
      <p class="map-fallback">地図を表示するには JavaScript が必要です。<a href="/clinics/">医療機関の一覧</a>や<a href="/resources/">関連サイト</a>からも探せます。</p>
    </div>

    <p class="resource-section-intro">
      ピンの位置は、住所をもとにおおよそで表示しています（番地が不明なものは市区町村のおおよその位置です）。大学のサークルは活動キャンパスのおおよその場所、相談窓口は施設の場所を示しています。学生サークルの活動状況や開催日時は年度で変わることがあります。「手術」には、性別適合手術（SRS）や声の手術（VFS）などが含まれ、日本のGI学会認定施設などに加えて、海外（タイ・韓国）でよく知られたSRS病院も含みます。海外で受ける場合の費用・言葉・術後ケア・戸籍変更の書類などの注意は<a href="/surgery/">移行のための手術</a>を確認してください。正確な所在地・活動内容・診療内容は、必ず各施設・団体・窓口の公式情報で確認してください。当サイトは特定の施設をすすめたり順位づけしたりはしません。
    </p>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/clinics/">医療機関の一覧</a>
      <a class="word-chip" href="/resources/">団体・関連サイト</a>
      <a class="word-chip" href="/pride/">記念日・イベント</a>
    </nav>

    <p class="source-note">
      地図は <a href="https://maplibre.org/" target="_blank" rel="noreferrer">MapLibre GL</a> と
      {' '}<a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noreferrer">OpenStreetMap</a>
      のタイルを使っています。住所から座標への変換には
      {' '}<a href="https://www.gsi.go.jp/" target="_blank" rel="noreferrer">国土地理院</a>のジオコーディングを利用しました。
    </p>
  </article>

  <script type="application/json" id="map-data" set:html={JSON.stringify(mapData)} />
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />
  <script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <script is:inline src="/map.js" defer></script>
</BaseLayout>
