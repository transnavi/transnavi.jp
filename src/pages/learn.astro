---
import BaseLayout from '../layouts/BaseLayout.astro';

const groups = [
  {
    title: '自分と性のこと',
    items: [
      { href: '/basics/', title: 'トランス・シス・ノンバイナリーって？', desc: '基本のことばをやさしく。出生時の性別と性同一性、性的指向の違い。' },
      { href: '/gender/', title: '性別は、男女だけじゃない', desc: '性別はグラデーション。「身体的性別」も単純な二択ではありません。' },
      { href: '/orientation/', title: '性的指向と「好き」のいろいろ', desc: 'だれを好きになるか（性的指向）と性別は別。アロ・エースも。' },
      { href: '/intersex/', title: 'インターセックス（DSD）', desc: '生まれつきのからだの話。トランスとの違いと重なり。' },
      { href: '/dysphoria/', title: '性別違和を知る', desc: '性別違和とは何か、どんな形で現れるのか。性別高揚感についても。' },
    ],
  },
  {
    title: 'はじまりとこれから',
    items: [
      { href: '/start/', title: 'はじめての方へ', desc: 'まだよくわからない、というところから読めます。' },
      { href: '/transition/', title: '性別移行を知る', desc: '社会的・医療的・法的な側面と、「急がなくていい」という考え方。' },
      { href: '/detransition/', title: '気持ちが揺れたとき・脱移行のこと', desc: '迷いや揺れ、脱移行について。揺れていい、やめてもいい。' },
      { href: '/legal-change/', title: '戸籍と名前の変更', desc: '改名（家庭裁判所）と戸籍の性別変更の手続きの全体像。' },
      { href: '/support/', title: '相談先', desc: '誰に相談できる？　身近で安全なところから。' },
    ],
  },
  {
    title: 'からだと医療',
    items: [
      { href: '/puberty-blockers/', title: '思春期ブロッカーとは', desc: '二次性徴を一時的に止める薬。時間に敏感な選択です。' },
      { href: '/hrt-effects/', title: 'ホルモン療法で起きること', desc: '第二の思春期。からだはどう変わるのか、戻る変化・戻らない変化。' },
      { href: '/hrt-medications/', title: 'ホルモン療法の薬とフラホル', desc: '具体的な薬の種類と、個人輸入・DIYの注意。安全第一で。' },
      { href: '/fertility/', title: '妊孕性と「始める前」の選択', desc: '精子・卵子の凍結保存など、時間に敏感な選択について。' },
      { href: '/voice/', title: '声を変える練習', desc: '声の女性化・男性化の基本。自宅で今日から。' },
      { href: '/presentation/', title: '見た目と、毎日のこと', desc: '服・メイク・体の見せ方（バインディング/タッキング）。安全第一で。' },
      { href: '/hair-removal/', title: '脱毛の入門', desc: 'レーザーと電気脱毛のちがい、費用や回数の目安。' },
      { href: '/surgery/', title: '移行のための手術', desc: '手術の種類のオリエンテーション。どれも必須ではありません。' },
      { href: '/cost/', title: 'お金のこと・費用の全体像', desc: '自費が基本のこと、費用の目安、負担を軽くする仕組み。' },
      { href: '/clinics/', title: '医療機関', desc: '地域ごとの医療機関一覧。' },
      { href: '/map/', title: '地図で探す', desc: '医療機関や当事者の集まる場所・相談窓口を、地図の上でまとめて。' },
    ],
  },
  {
    title: '暮らしとつながり',
    items: [
      { href: '/coming-out/', title: 'カミングアウト入門', desc: '誰に・いつ・どう伝える？　義務ではありません。' },
      { href: '/relationships/', title: '恋愛と性の健康のこと', desc: '「好き」と性別は別。同意・安全と、ホルモンは避妊にならない話。' },
      { href: '/everyday/', title: 'トイレ・更衣室・身分証など', desc: '性別で分かれた場所や、名前が表に出る場面での、具体的なヒント。' },
      { href: '/pronouns/', title: '一人称と呼ばれ方', desc: '僕・私・うち…の一人称、さん付けや呼称、通称名のこと。試していい。' },
      { href: '/school/', title: '学校でのこと', desc: '制服・名簿・トイレ・体育・修学旅行・いじめのこと。' },
      { href: '/work/', title: '働くこと・職場でのこと', desc: '就職・転職や、働きながらの移行。配慮の頼み方、保険証、SOGIハラのこと。' },
      { href: '/allies/', title: '周囲の人へ', desc: '伝えるとき、そして打ち明けられたとき。' },
      { href: '/parents/', title: '保護者の方へ', desc: 'お子さんから打ち明けられたとき。受けとめ方と、親自身の相談先。' },
      { href: '/guidelines/', title: '学校・職場・自治体のSOGIガイドライン', desc: '配慮のよりどころになる、公式ガイドラインのリンク集。' },
      { href: '/mental-health/', title: 'こころのケアと、つきあっていくこと', desc: '危機のときとふだんのケアのちがい。味方になってくれるカウンセラー・精神科の探し方。' },
      { href: '/safety/', title: '安全とこころ', desc: 'つらいときの相談先、身を守るための基本。' },
    ],
  },
  {
    title: '文化と歴史',
    items: [
      { href: '/flags/', title: 'プライドフラッグ', desc: '旗やシンボルの色に込められた意味。' },
      { href: '/pride/', title: 'プライドの記念日・イベント', desc: 'LGBTQ+ に関する記念日・週間・月間と、日本のイベント。' },
      { href: '/history/', title: 'トランスジェンダーの歴史', desc: '世界と日本の歩みを年表で。各地の多様な性の文化も。' },
      { href: '/works/', title: '文芸作品', desc: '映画・ドラマ・漫画・ゲームなどの作品データベース。' },
    ],
  },
  {
    title: '調べる・参考資料',
    items: [
      { href: '/glossary/', title: '用語集', desc: 'トランスジェンダーに関する基本的な言葉の一覧。' },
      { href: '/faq/', title: 'よくある質問（FAQ）', desc: 'はじめに気になりやすい疑問への、みじかい答え。' },
      { href: '/myths/', title: 'よくある誤解', desc: 'よく見聞きする誤解と、その隣にある事実。出典つきで。' },
      { href: '/bibliography/', title: '文献（書籍・論文）', desc: '学術的な書籍・論文・ガイドラインの一覧。深く知りたい人へ。' },
      { href: '/resources/', title: '関連サイト・団体', desc: '当事者団体・コミュニティ・相談窓口など、外部サイトのリンク集。' },
      { href: '/library/', title: '資料集', desc: '既存の資料を、確認しやすい形で整理したアーカイブ。' },
      { href: '/reference/', title: '資料・リンク（まとめ）', desc: 'さらに調べたいときの入り口をまとめたページ。' },
    ],
  },
];
---

<BaseLayout
  title="知る・学ぶ - とらんすナビ"
  description="性別や性別違和、移行、医療、暮らし、文化や歴史について知るためのページの一覧。テーマごとに整理しています。気になったところから読めます。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>知る・学ぶ</h1>
    <p class="lead">
      性別や<a href="/glossary/gender-dysphoria/">性別違和</a>、これからのこと、からだや暮らし、文化や歴史について、知るためのページをテーマごとにまとめました。順番はありません。気になったところから、どうぞ。各ページのタグから、同じ話題のページや用語をたどることもできます。はじめに気になりやすいことは、<a href="/faq/">よくある質問（FAQ）</a>にも短くまとめています。
    </p>

    {groups.map((group) => (
      <section class="article-section" aria-label={group.title}>
        <h2>{group.title}</h2>
        <div class="topic-list">
          {group.items.map((item) => (
            <a class="topic-item article-link" href={item.href}>
              <strong>{item.title}</strong>
              <span>{item.desc}</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </article>
</BaseLayout>
