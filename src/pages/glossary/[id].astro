---
import BaseLayout from '../../layouts/BaseLayout.astro';
import glossaryData from '../../data/glossary.json';
import type { GlossaryEntry } from '../../types/glossary';

export function getStaticPaths() {
  const entries = glossaryData as GlossaryEntry[];
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: GlossaryEntry };

// Further reading: link each term to the page(s) that explain it in depth, so a
// glossary entry is a doorway into the gentle 知る layer, not a dead end. We use
// a per-term map first, then category fallbacks, deduped by href.
type Link = { href: string; label: string };
const P: Record<string, Link> = {
  basics: { href: '/basics/', label: 'トランス・シス・ノンバイナリーって？' },
  gender: { href: '/gender/', label: '性別は、男女だけじゃない' },
  dysphoria: { href: '/dysphoria/', label: '性別違和を知る' },
  transition: { href: '/transition/', label: '性別移行を知る' },
  hrt: { href: '/hrt-effects/', label: 'ホルモン療法で起きること' },
  meds: { href: '/hrt-medications/', label: '薬と自己投薬（フラホル）' },
  blockers: { href: '/puberty-blockers/', label: '思春期ブロッカーとは' },
  surgery: { href: '/surgery/', label: '移行のための手術' },
  voice: { href: '/voice/', label: '声を変える練習' },
  hair: { href: '/hair-removal/', label: '脱毛の入門' },
  presentation: { href: '/presentation/', label: '見た目と、毎日のこと' },
  comingout: { href: '/coming-out/', label: 'カミングアウト入門' },
  safety: { href: '/safety/', label: '安全とこころ' },
  legal: { href: '/legal-change/', label: '戸籍と名前の変更' },
  clinics: { href: '/clinics/', label: '医療機関を探す' },
  start: { href: '/start/', label: 'はじめての方へ' },
  intersex: { href: '/intersex/', label: 'インターセックス・性分化疾患（DSD）のこと' },
  orientation: { href: '/orientation/', label: '性的指向と「好き」のいろいろ' },
};
const termPages: Record<string, Link[]> = {
  'transgender': [P.basics], 'cisgender': [P.basics],
  'cisgender-woman': [P.basics], 'cisgender-man': [P.basics],
  'transgender-woman': [P.basics], 'transgender-man': [P.basics],
  'non-binary': [P.basics, P.gender], 'questioning': [P.start, P.basics],
  'gender-identity': [P.basics, P.gender], 'gender-expression': [P.presentation],
  'gender-dysphoria': [P.dysphoria], 'gender-incongruence': [P.dysphoria],
  'gender-transition': [P.transition], 'detransition': [P.transition],
  'gaht': [P.hrt, P.meds], 'diy-hrt': [P.meds], 'puberty-blocker': [P.blockers],
  'coming-out': [P.comingout], 'force-outing': [P.comingout, P.safety],
  'passing': [P.presentation], 'rle': [P.presentation],
  'intersex': [P.intersex, P.gender],
};
const knowledgePages: Record<string, Link> = {
  'ホルモン療法': P.hrt, '検査': P.hrt, '医療': P.transition,
  '手術': P.surgery, '声': P.voice, '脱毛': P.hair,
};

const related: Link[] = [];
const seen = new Set<string>();
const add = (item?: Link) => { if (item && !seen.has(item.href)) { seen.add(item.href); related.push(item); } };

(termPages[entry.id] ?? []).forEach(add);
if (entry.category === '性同一性・属性') { add(P.basics); add(P.gender); }
if (entry.category === '性的指向') { add(P.orientation); add(P.basics); }
const knowledgePage = knowledgePages[entry.category];
if (knowledgePage) { add(knowledgePage); add(P.clinics); }
if (entry.category === '法律・制度') add(P.legal);

const translations = [
  ['英語', entry.translations.en],
  ['韓国語', entry.translations.ko],
  ['簡体字中国語', entry.translations.zhHans],
  ['繁体字中国語', entry.translations.zhHant],
  ['タイ語', entry.translations.th],
  ['スペイン語', entry.translations.es],
].filter(([, value]) => value);

// Wikipedia articles for this term, in the languages the site supports. Labelled
// with each language's own name so readers can pick the edition they read.
const wikipedia = [
  ['日本語', entry.wikipedia?.ja],
  ['English', entry.wikipedia?.en],
  ['한국어', entry.wikipedia?.ko],
  ['简体中文', entry.wikipedia?.zhHans],
  ['繁體中文', entry.wikipedia?.zhHant],
  ['ไทย', entry.wikipedia?.th],
  ['Español', entry.wikipedia?.es],
].filter(([, href]) => href) as [string, string][];

// Real per-page meta description from the definition (not a generic template),
// trimmed to ~150 chars at a clause boundary so search snippets read cleanly.
const metaDescription = entry.notes
  ? entry.notes.length <= 150
    ? entry.notes
    : entry.notes.slice(0, 150).replace(/[、。][^、。]*$/, '') + '…'
  : `${entry.term}（${entry.translations.en ?? ''}）の意味を、やさしく説明します。`;

const canonical = new URL(`/glossary/${entry.id}/`, Astro.site).toString();
const alt = [entry.abbr, ...(entry.aliases ?? [])].filter(Boolean);
const termLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  '@id': `${canonical}#term`,
  name: entry.term,
  url: canonical,
  inLanguage: 'ja',
  ...(alt.length ? { alternateName: alt } : {}),
  ...(entry.notes ? { description: entry.notes } : {}),
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    '@id': new URL('/glossary/', Astro.site).toString(),
    name: 'とらんすナビ 用語集',
  },
  ...(entry.wikidata ? { sameAs: `https://www.wikidata.org/wiki/${entry.wikidata}` } : {}),
};
---

<BaseLayout title={`${entry.term} - とらんすナビ`} description={metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(termLd)} />
  <article class="article-shell">
    <a href="/glossary/" class="glossary-back" data-glossary-back>← 用語集にもどる</a>
    <div class="eyebrow">用語集 ・ {entry.category}</div>
    <h1>{entry.term}{entry.abbr ? `（${entry.abbr}）` : ''}</h1>

    {entry.notes && <p class="glossary-def">{entry.notes}</p>}

    <dl class="clinic-detail glossary-detail">
      {entry.aliases.length > 0 && (
        <div>
          <dt>別名・関連表現</dt>
          <dd>{entry.aliases.join('、')}</dd>
        </div>
      )}
      {translations.length > 0 && (
        <div>
          <dt>ほかの言語では</dt>
          <dd>
            <ul>
              {translations.map(([label, value]) => <li>{label}: {value}</li>)}
            </ul>
          </dd>
        </div>
      )}
      {entry.avoid.length > 0 && (
        <div>
          <dt>避けたい言い方</dt>
          <dd>{entry.avoid.join('、')}</dd>
        </div>
      )}
      {entry.disputed.length > 0 && (
        <div>
          <dt>議論がある言い方</dt>
          <dd>{entry.disputed.join('、')}</dd>
        </div>
      )}
      {wikipedia.length > 0 && (
        <div>
          <dt>Wikipedia で読む</dt>
          <dd>
            <ul class="wiki-langs">
              {wikipedia.map(([label, href]) => (
                <li><a href={href} target="_blank" rel="noreferrer" lang={label === 'English' ? 'en' : undefined}>{label}</a></li>
              ))}
            </ul>
          </dd>
        </div>
      )}
      {entry.wikidata && (
        <div>
          <dt>Wikidata</dt>
          <dd><a href={`https://www.wikidata.org/wiki/${entry.wikidata}`} target="_blank" rel="noreferrer">{entry.wikidata}</a></dd>
        </div>
      )}
    </dl>

    {entry.message && (
      <aside class="entry-message" role="note" aria-label="読んでいるあなたへ">
        <p>{entry.message}</p>
      </aside>
    )}

    <nav class="word-chips entry-related" aria-label="関連ページ">
      {related.map((item) => (
        <a class="word-chip" href={item.href}>{item.label}</a>
      ))}
      <a class="word-chip" href="/glossary/">用語集の一覧</a>
    </nav>
  </article>
  <script is:inline>
    // If the reader came from the 用語集 list, "もどる" goes back in history so the
    // list reopens at the same scroll position (and filter), instead of jumping to
    // the top. Otherwise it stays a normal link to /glossary/.
    (function () {
      var a = document.querySelector('[data-glossary-back]');
      if (!a) return;
      try {
        var ref = document.referrer ? new URL(document.referrer) : null;
        if (ref && ref.origin === location.origin && ref.pathname === '/glossary/') {
          a.addEventListener('click', function (e) { e.preventDefault(); history.back(); });
        }
      } catch (e) {}
    })();
  </script>
</BaseLayout>
