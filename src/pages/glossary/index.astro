---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Mascot from '../../components/Mascot.astro';
import glossaryData from '../../data/glossary.json';
import glossaryReadings from '../../data/glossary-readings.json';
import type { GlossaryEntry } from '../../types/glossary';

const entries = glossaryData as GlossaryEntry[];
// Hiragana readings of kanji terms/aliases (built in prebuild) so the filter can
// match an entry typed by its reading. See scripts/gen-glossary-readings.mjs.
const readings = glossaryReadings as Record<string, string>;

// Friendly, beginner-first category order with plain-language labels.
const categoryMeta = [
  { key: '性同一性・属性', label: '性のあり方', desc: 'トランスジェンダー、性同一性、ノンバイナリーなど、自分の性のあり方に関する言葉。' },
  { key: '性的指向', label: '性的指向（好きになる相手）', desc: '同性愛、異性愛、無性愛など、「だれに惹かれるか」に関する言葉。自分の性別（性同一性）とは別のものさしです。' },
  { key: '生活・社会', label: '暮らし・社会', desc: 'カミングアウト、パッシングなど、日常や人との関わりに関する言葉。' },
  { key: '法律・制度', label: '法律・制度', desc: '戸籍や診断書など、手続き・制度に関する言葉。' },
  { key: 'ホルモン療法', label: 'ホルモン療法', desc: 'ホルモンや薬に関する言葉。' },
  { key: '手術', label: '手術', desc: '手術や、からだの部位に関する言葉。' },
  { key: '医療', label: '医療・からだ', desc: '医療やからだの健康に関する言葉。' },
  { key: '検査', label: '検査', desc: '血液検査などで確認する項目。' },
  { key: '声', label: '声', desc: '声やボイストレーニングに関する言葉。' },
  { key: '脱毛', label: '脱毛', desc: '脱毛に関する言葉。' },
  { key: 'その他', label: 'その他', desc: 'そのほかの言葉。' },
];

// "First words to know" — surfaced at the top for newcomers.
const keyTermIds = [
  'transgender', 'gender-dysphoria', 'gender-identity', 'non-binary',
  'questioning', 'coming-out', 'gender-transition', 'gaht',
];
const byId = new Map(entries.map((e) => [e.id, e]));
const keyTerms = keyTermIds.map((id) => byId.get(id)).filter(Boolean) as GlossaryEntry[];

const sections = categoryMeta
  .map((meta) => ({ ...meta, items: entries.filter((e) => e.category === meta.key) }))
  .filter((s) => s.items.length > 0);

// Short Japanese meaning (the English name is shown separately on every card).
const meaningOf = (entry: GlossaryEntry) =>
  entry.notes ? (entry.notes.length > 46 ? entry.notes.slice(0, 46) + '…' : entry.notes) : '';

// Show a couple of aliases inline so people who know a term by another name can
// spot it; keep it short so cards stay scannable.
const aliasPreview = (entry: GlossaryEntry) => {
  if (entry.aliases.length === 0) return '';
  const shown = entry.aliases.slice(0, 3);
  const more = entry.aliases.length - shown.length;
  return shown.join('、') + (more > 0 ? ` ほか${more}件` : '');
};
---

<BaseLayout title="用語集 - とらんすナビ" description="トランスジェンダー、医療、制度、生活に関する、やさしい用語集。">
  <article class="article-shell">
    <div class="eyebrow">用語集</div>
    <Mascot name="reading" />
    <h1>用語集</h1>
    <p class="lead">
      トランスジェンダーや医療・制度・暮らしに関する言葉を、やさしくまとめました。気になった言葉から、どうぞ。
    </p>

    <section aria-labelledby="key-terms">
      <h2 id="key-terms">はじめに知りたい言葉</h2>
      <div class="word-chips">
        {keyTerms.map((entry) => (
          <a class="word-chip" href={`/glossary/${entry.id}/`}>{entry.term}</a>
        ))}
      </div>
    </section>

    <div class="clinic-summary" aria-label="掲載件数">
      <span><span data-filter-count>{entries.length}</span>語</span>
      <span>{sections.length}分野</span>
    </div>

    <section class="filter-tabs" aria-label="分野" data-filter-tabs>
      <button type="button" class="filter-tab" data-filter-tab data-filter-value="" aria-pressed="true">すべて</button>
      {sections.map((s) => (
        <button type="button" class="filter-tab" data-filter-tab data-filter-value={s.key} aria-pressed="false">{s.label}</button>
      ))}
    </section>

    <form class="index-search" role="search" data-filter-form data-filter-fuzzy data-filter-highlight>
      <label for="glossary-search">用語を検索</label>
      <input id="glossary-search" name="q" type="search" autocomplete="off" placeholder="例: HRT、診断書、カミングアウト" data-filter-input />
      <p id="glossary-search-help">用語、略語、別名、英語名で絞り込めます。</p>
    </form>

    {sections.map((section) => (
      <details class="glossary-section" data-filter-group data-filter-default-open open aria-labelledby={`glossary-${section.key}`}>
        <summary class="glossary-section-summary">
          <h2 id={`glossary-${section.key}`}>{section.label}</h2>
          <span class="glossary-section-count"><span data-filter-group-count>{section.items.length}</span> 語</span>
        </summary>
        <p class="resource-section-intro">{section.desc}</p>
        <div class="glossary-list">
          {section.items.map((entry) => (
            <a
              class="glossary-card"
              href={`/glossary/${entry.id}/`}
              data-filter-item
              data-categories={entry.category}
              data-search={[entry.term, entry.abbr, entry.category, ...(entry.tags ?? []), entry.translations.en, ...entry.aliases, readings[entry.id]].filter(Boolean).join(' ')}
            >
              <span class="glossary-card-head">
                <span class="clinic-name">{entry.term}{entry.abbr ? `（${entry.abbr}）` : ''}</span>
                {entry.translations.en && <span class="glossary-en" lang="en">{entry.translations.en}</span>}
              </span>
              {entry.notes && <span class="glossary-meaning">{meaningOf(entry)}</span>}
              {entry.aliases.length > 0 && (
                <span class="glossary-aliases"><span class="glossary-aliases-label">別名</span><span class="glossary-aliases-text">{aliasPreview(entry)}</span></span>
              )}
              <span class="glossary-match-hint" data-filter-hint hidden></span>
            </a>
          ))}
        </div>
      </details>
    ))}
    <p class="empty-state" data-filter-empty hidden>条件に合う用語は見つかりませんでした。</p>
  </article>
  <script is:inline src="/filter-index.js" defer></script>
</BaseLayout>
