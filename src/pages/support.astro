---
import BaseLayout from '../layouts/BaseLayout.astro';

// Ordered from the most accessible / lowest-stakes toward the more formal.
const steps = [
  {
    title: '信頼できる友人',
    body: '安心して話せる相手がいれば、気持ちを言葉にするだけでも楽になることがあります。話す内容や範囲は自分で選べます。',
  },
  {
    title: '学校の先生・スクールカウンセラー',
    body: 'スクールカウンセラーは守秘義務があり、比較的話しやすい相手です。信頼できそうな先生でも大丈夫です。',
  },
  {
    title: '地域の相談窓口',
    body: '自治体やよりそいホットラインなど、匿名で相談できる窓口があります。名前を名乗らずに話せるところもあります。',
  },
  {
    title: 'LGBTQ+支援団体',
    body: '当事者団体やコミュニティセンターでは、同じような経験をした人につながれます。',
    link: { href: '/resources/', label: '団体・相談先を見る' },
  },
  {
    title: '医療機関',
    body: '医療を受けるかどうかは、急いで決めなくて大丈夫です。知りたくなったときに、選択肢のひとつとして。',
    link: { href: '/clinics/', label: '医療機関一覧を見る' },
  },
  {
    title: '家族に話す前に考えること',
    body: '家族はいちばん身近な一方で、反応が読みにくい相手でもあります。安全や反応を想像してから、タイミングを選んで大丈夫です。',
    link: { href: '/allies/', label: '周囲の人へ' },
  },
];
---

<BaseLayout
  title="誰に相談できる？ - とらんすナビ"
  description="相談先にはいくつかの段階があります。身近で安全なところから考えられます。カミングアウトは義務ではありません。"
>
  <article class="article-shell">
    <div class="eyebrow">相談先</div>
    <h1>誰に相談できる？</h1>
    <p class="lead">
      相談先には、いくつかの段階があります。いちばん身近で、安全だと感じられるところから考えてみてください。
    </p>

    <ol class="step-list">
      {steps.map((step, index) => (
        <li class="step-item">
          <span class="step-num" aria-hidden="true">{index + 1}</span>
          <div class="step-body">
            <h2>{step.title}</h2>
            <p>{step.body}</p>
            {step.link && <a class="step-link" href={step.link.href}>{step.link.label} →</a>}
          </div>
        </li>
      ))}
    </ol>

    <section class="notice" aria-labelledby="safety">
      <h2 id="safety">無理をしないで</h2>
      <p>
        安全でない相手に、無理に話す必要はありません。<strong>カミングアウトは義務ではありません。</strong>
        話すかどうか、誰に・いつ話すかは、すべてあなたが選んでいいことです。
      </p>
    </section>
  </article>
</BaseLayout>
