---
import BaseLayout from '../layouts/BaseLayout.astro';
import Mascot from '../components/Mascot.astro';

// Verified national hotlines (free, anonymous). Numbers/hours confirmed 2026-06.
const hotlines = [
  {
    name: 'よりそいホットライン',
    detail: 'どんな悩みでも。セクシュアル・マイノリティ専門の回線もあります（音声ガイダンスで選べます）。無料・匿名。',
    tel: '0120-279-338',
    hours: '24時間',
    url: 'https://www.since2011.net/yorisoi/',
  },
  {
    name: '#いのちSOS（ライフリンク）',
    detail: '「死にたい」「消えたい」「生きるのに疲れた」と感じるとき。無料・秘密厳守。',
    tel: '0120-061-338',
    hours: '24時間・365日',
    url: 'https://www.lifelink.or.jp/inochisos/',
  },
  {
    name: 'チャイルドライン',
    detail: '18歳まで。名前は言わなくて大丈夫。話すのがつらくなったら、途中で切っても大丈夫。',
    tel: '0120-99-7777',
    hours: '毎日 16:00〜21:00',
    url: 'https://childline.or.jp/tel',
  },
];

// Ordered from the most accessible / lowest-stakes toward the more formal.
const steps = [
  {
    title: '信頼できる友人',
    body: '安心して話せる相手なら、口に出してみるだけでも気持ちが軽くなることがあります。どこまで話すかは、自分で決めて大丈夫です。',
  },
  {
    title: '学校の先生・スクールカウンセラー',
    body: 'スクールカウンセラーは守秘義務があり、比較的話しやすい相手です。信頼できそうな先生でも大丈夫です。',
  },
  {
    title: '地域の相談窓口',
    body: '自治体やよりそいホットラインなど、匿名で相談できる窓口があります。名前を名乗らずに話せるところもあります。',
  },
  {
    title: 'LGBTQ+支援団体',
    body: '当事者団体やコミュニティセンターでは、同じような経験をした人につながれます。',
    link: { href: '/resources/', label: '団体・相談先を見る' },
  },
  {
    title: '医療機関',
    body: '医療を受けるかどうかは、急いで決めなくて大丈夫です。知りたくなったときに、選択肢のひとつとして。',
    link: { href: '/clinics/', label: '医療機関一覧を見る' },
  },
  {
    title: '家族に話す前に考えること',
    body: '家族はいちばん近い存在ですが、だからこそ、どう受け止めるか読めないこともあります。相手の反応を想像してみて、無理のないタイミングを選んで大丈夫です。',
    link: { href: '/allies/', label: '周囲の人へ' },
  },
];
---

<BaseLayout
  title="誰に相談できる？ - とらんすナビ"
  description="相談先にはいくつかの段階があります。身近で安全なところから考えられます。カミングアウトは義務ではありません。"
>
  <article class="article-shell">
    <div class="eyebrow">相談先</div>
    <Mascot name="support-heart" />
    <h1>誰に相談できる？</h1>
    <p class="lead">
      相談できる相手は、身近な人から専門の窓口まで、いろいろあります。まずは、いちばん話しやすそうなところから考えてみてください。
    </p>
    <p>まだ気持ちがはっきりしないときは、<a href="/start/">はじめての方へ</a>から読んでみても大丈夫です。</p>

    <section class="notice hotlines" aria-labelledby="now-heading">
      <h2 id="now-heading">つらくて、今すぐ話したいとき</h2>
      <p class="resource-section-intro">電話は匿名で大丈夫です。番号をタップするとかけられます。つながらないときは、少し時間をおいてかけ直してみてください。</p>
      <ul class="hotline-list">
        {hotlines.map((h) => (
          <li class="hotline-item">
            <div class="hotline-head">
              <span class="hotline-name">{h.name}</span>
              <span class="hotline-hours">{h.hours}</span>
            </div>
            <p class="hotline-detail">{h.detail}</p>
            <div class="hotline-actions">
              <a class="hotline-tel" href={`tel:${h.tel.replace(/-/g, '')}`} aria-label={`${h.name}に電話する ${h.tel}`}>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="16" height="16"><path d="M6.6 10.8a15.3 15.3 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1Z"/></svg>
                {h.tel}
              </a>
              <a class="hotline-site" href={h.url} target="_blank" rel="noreferrer">公式サイト</a>
            </div>
          </li>
        ))}
      </ul>
      <p class="resource-section-intro">
        電話より文字がよいときは、LINE などの<a href="https://www.mhlw.go.jp/mamorouyokokoro/" target="_blank" rel="noreferrer">SNS相談（厚労省「まもろうよ こころ」）</a>もあります。<strong>いますぐ命が危ないと感じたら、110（警察）・119（救急）に電話してください。</strong>
      </p>
    </section>

    <ol class="step-list">
      {steps.map((step, index) => (
        <li class="step-item">
          <span class="step-num" aria-hidden="true">{index + 1}</span>
          <div class="step-body">
            <h2>{step.title}</h2>
            <p>{step.body}</p>
            {step.link && <a class="step-link" href={step.link.href}>{step.link.label} →</a>}
          </div>
        </li>
      ))}
    </ol>

    <p>
      オンラインで、同じような人とゆるくつながれる場所もあります。とらんすナビの<a href="https://discord.gg/S8NJGeS3Da" target="_blank" rel="noreferrer">Discord（おしゃべりの場）</a>は、見るだけでも、書き込んでも大丈夫です。あなたのペースでどうぞ。
    </p>

    <section class="notice" aria-labelledby="safety">
      <h2 id="safety">無理をしないで</h2>
      <p>
        安全でない相手に、無理に話す必要はありません。<strong><a href="/glossary/coming-out/">カミングアウト</a>は義務ではありません。</strong>
        話すかどうか、誰に・いつ話すかは、すべてあなたが選んでいいことです。
      </p>
    </section>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/start/">はじめての方へ</a>
      <a class="word-chip" href="/coming-out/">カミングアウト入門</a>
      <a class="word-chip" href="/allies/">周囲の人へ</a>
      <a class="word-chip" href="/safety/">安全とこころ</a>
      <a class="word-chip" href="/resources/">関連サイト</a>
    </nav>
  </article>
</BaseLayout>
