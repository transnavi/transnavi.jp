---
import BaseLayout from '../../layouts/BaseLayout.astro';
import clinicsData from '../../data/clinics.json';
import type { Clinic } from '../../types/clinic';
import { categoriesOf, capabilitiesOf, CAPABILITY_LABELS } from '../../utils/clinic-genre';

// 47-prefecture order so the regional list reads top-to-bottom like an atlas.
const prefectureOrder = [
  '北海道', '青森県', '岩手県', '宮城県', '秋田県', '山形県', '福島県', '茨城県', '栃木県', '群馬県',
  '埼玉県', '千葉県', '東京都', '神奈川県', '新潟県', '富山県', '石川県', '福井県', '山梨県', '長野県',
  '岐阜県', '静岡県', '愛知県', '三重県', '滋賀県', '京都府', '大阪府', '兵庫県', '奈良県', '和歌山県',
  '鳥取県', '島根県', '岡山県', '広島県', '山口県', '徳島県', '香川県', '愛媛県', '高知県', '福岡県',
  '佐賀県', '長崎県', '熊本県', '大分県', '宮崎県', '鹿児島県', '沖縄県',
];

const all = clinicsData as Clinic[];
const hrt = all
  .filter((clinic) => categoriesOf(clinic).includes('hrt'))
  .map((clinic) => ({ ...clinic, caps: capabilitiesOf(clinic) }));

const byPrefecture = prefectureOrder
  .map((prefecture) => ({ prefecture, items: hrt.filter((clinic) => clinic.prefecture === prefecture) }))
  .filter((group) => group.items.length > 0);

const mtfCount = hrt.filter((clinic) => clinic.caps.includes('gaht-feminizing')).length;
const ftmCount = hrt.filter((clinic) => clinic.caps.includes('gaht-masculinizing')).length;

const faqs = [
  {
    q: 'ホルモン注射はどこで打てますか？',
    a: 'ジェンダークリニックや、トランスジェンダーの医療に対応している一部の内科・婦人科・美容外科などで受けられます。このページの地域別一覧や、地図から探せます。受診の条件（診断書の要否など）は施設によって違うので、予約の前に確認すると確実です。',
  },
  {
    q: 'MtF（女性化）とFtM（男性化）で、対応する病院は違いますか？',
    a: '両方に対応している施設も、どちらか一方の施設もあります。各施設のカードには、公開情報で確認できた対応を「女性化ホルモン（MtF）」「男性化ホルモン（FtM）」のタグで表示しています。ただしタグがないことは「対応していない」という意味ではなく、もとの情報に記載がないだけのこともあります。必ず医療機関にご確認ください。',
  },
  {
    q: 'ホルモン療法に健康保険はききますか？',
    a: '日本では、性別違和に対するホルモン療法は原則として自費（自由診療）になることが多いです。費用の目安や、医療費控除などの仕組みは「お金のこと・費用の全体像」にまとめています。',
  },
  {
    q: '未成年でもホルモン療法を受けられますか？',
    a: '年齢や保護者の同意など、条件は施設によって異なります。思春期の選択肢としては、クロスホルモンとは別に思春期ブロッカーもあります。あせらず、まずは相談できる窓口や医療機関に問い合わせてみてください。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  title="ホルモン療法ができる病院・クリニック一覧【MtF・FtM】 - とらんすナビ"
  description="日本でホルモン療法（HRT・ホルモン注射）を受けられる病院・クリニックを地域別にまとめた一覧。女性化（MtF）・男性化（FtM）の対応や、費用・受診の流れ、予約前に確認したいことも。"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  <article class="article-shell">
    <div class="eyebrow">医療機関</div>
    <h1>ホルモン療法ができる病院・クリニック</h1>
    <p class="lead">
      日本でホルモン療法（HRT・ホルモン注射）を受けられる医療機関を、地域別にまとめました。女性化（MtF）・男性化（FtM）どちらの対応かも、公開情報でわかる範囲でタグ表示しています。下の地域別一覧から、お住まいの近くの医療機関を探せます。
    </p>

    <div class="page-disclaimer">
      このページは、特定のクリニックをすすめたり、比べたりするものではありません。受診条件・費用・対応は変わることがあります。実際に受けられるかどうかは、必ず各医療機関にご確認ください。
    </div>

    <div class="clinic-summary" aria-label="掲載件数">
      <span>ホルモン療法 <strong>{hrt.length}</strong> 件</span>
      <span>女性化（MtF）記載 {mtfCount} 件</span>
      <span>男性化（FtM）記載 {ftmCount} 件</span>
    </div>

    <section aria-labelledby="how">
      <h2 id="how">ホルモン療法ができる病院の探し方</h2>
      <ul class="assure-list">
        <li>予約のときに「<strong>ホルモン療法に対応していますか</strong>」「初診で診断書は必要ですか」「MtF（FtM）のホルモンに対応していますか」と確認すると確実です。</li>
        <li>ホルモンでからだがどう変わるかは<a href="/hrt-effects/">ホルモン療法で起きること</a>、使う薬は<a href="/hrt-medications/">ホルモン療法の薬と、自己投薬（フラホル）</a>へ。</li>
        <li>費用の目安や、医療費控除などの仕組みは<a href="/cost/">お金のこと・費用の全体像</a>にまとめています。</li>
        <li>地図から探したいときは<a href="/map/">地図で探す</a>、絞り込み・検索したいときは<a href="/clinics/">医療機関の一覧（検索・絞り込み）</a>が便利です。</li>
      </ul>
    </section>

    <section aria-labelledby="list">
      <h2 id="list">ホルモン療法ができる医療機関（地域別）</h2>
      <p>
        各施設のタグは、公開情報で確認できた対応です。<strong>タグがないことは、対応していないという意味ではありません。</strong>
      </p>
      {byPrefecture.map((group) => (
        <div class="finder-region">
          <h3 class="finder-region-name">{group.prefecture}</h3>
          <ul class="finder-clinic-list">
            {group.items.map((clinic) => (
              <li class="finder-clinic">
                <a href={`/clinics/${clinic.id}/`}>{clinic.name}</a>
                <span class="finder-clinic-city">{clinic.city}</span>
                {clinic.caps.length > 0 && (
                  <span class="finder-clinic-tags">
                    {clinic.caps.map((cap) => (
                      <span class:list={['clinic-tag', cap.startsWith('gaht') ? 'clinic-tag-gaht' : 'clinic-tag-surgery']}>
                        {CAPABILITY_LABELS[cap]}
                      </span>
                    ))}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
      <p>
        絞り込みや検索（地域・診療区分・対応）をしたいときは、<a href="/clinics/">医療機関の一覧ページ</a>からどうぞ。
      </p>
    </section>

    <section aria-labelledby="faq">
      <h2 id="faq">よくある質問</h2>
      <dl class="finder-faq">
        {faqs.map((item) => (
          <div>
            <dt>{item.q}</dt>
            <dd>{item.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/clinics/">医療機関をさがす</a>
      <a class="word-chip" href="/hrt-effects/">ホルモン療法で起きること</a>
      <a class="word-chip" href="/hrt-medications/">薬と自己投薬（フラホル）</a>
      <a class="word-chip" href="/cost/">お金のこと・費用</a>
      <a class="word-chip" href="/transition/">性別移行を知る</a>
    </nav>
  </article>
</BaseLayout>
