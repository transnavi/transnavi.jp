---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Mascot from '../../components/Mascot.astro';
import clinicsData from '../../data/clinics.json';
import poisData from '../../data/map-pois.json';
import type { Clinic } from '../../types/clinic';
import { splitClinicUrls } from '../../utils/clinic-links';
import { categoriesOf, primaryGenre, surgeryTypesOf, capabilitiesOf, CAPABILITY_LABELS, isGiCertified, clinicMapTags } from '../../utils/clinic-genre';

const clinics = clinicsData as Clinic[];
const prefectureOrder = [
  '北海道',
  '青森県',
  '岩手県',
  '宮城県',
  '秋田県',
  '山形県',
  '福島県',
  '茨城県',
  '栃木県',
  '群馬県',
  '埼玉県',
  '千葉県',
  '東京都',
  '神奈川県',
  '新潟県',
  '富山県',
  '石川県',
  '福井県',
  '山梨県',
  '長野県',
  '岐阜県',
  '静岡県',
  '愛知県',
  '三重県',
  '滋賀県',
  '京都府',
  '大阪府',
  '兵庫県',
  '奈良県',
  '和歌山県',
  '鳥取県',
  '島根県',
  '岡山県',
  '広島県',
  '山口県',
  '徳島県',
  '香川県',
  '愛媛県',
  '高知県',
  '福岡県',
  '佐賀県',
  '長崎県',
  '熊本県',
  '大分県',
  '宮崎県',
  '鹿児島県',
  '沖縄県',
];

const categoryDefinitions = [
  { id: '', label: 'すべて' },
  { id: 'hrt', label: 'ホルモン療法（HRT）' },
  { id: 'surgery', label: '手術' },
  { id: 'mental', label: '精神科（メンタルクリニック）' },
] as const;

// Facility scale, by the 医療法 (Medical Care Act) definition: a 病院 is an
// inpatient facility with 20+ beds, and everything smaller is a 診療所 (≤19
// beds) — クリニック・医院・専門診療所などはすべて診療所にあたります。Only a
// facility with 20+ beds may legally be named "病院", so the name is a reliable
// proxy for the legal category (no per-clinic bed-count data needed).
const typeOf = (name: string): string => (name.includes('病院') ? '病院' : '診療所');
const typeDefinitions = [
  { id: '', label: 'すべて' },
  { id: '病院', label: '病院（20床以上）' },
  { id: '診療所', label: '診療所（クリニック・医院など）' },
] as const;

// 地方（region）grouping of the 47 prefectures, for a region-level filter.
const regionByPrefecture: Record<string, string> = {
  '北海道': '北海道',
  '青森県': '東北', '岩手県': '東北', '宮城県': '東北', '秋田県': '東北', '山形県': '東北', '福島県': '東北',
  '茨城県': '関東', '栃木県': '関東', '群馬県': '関東', '埼玉県': '関東', '千葉県': '関東', '東京都': '関東', '神奈川県': '関東',
  '新潟県': '中部', '富山県': '中部', '石川県': '中部', '福井県': '中部', '山梨県': '中部', '長野県': '中部', '岐阜県': '中部', '静岡県': '中部', '愛知県': '中部',
  '三重県': '近畿', '滋賀県': '近畿', '京都府': '近畿', '大阪府': '近畿', '兵庫県': '近畿', '奈良県': '近畿', '和歌山県': '近畿',
  '鳥取県': '中国', '島根県': '中国', '岡山県': '中国', '広島県': '中国', '山口県': '中国',
  '徳島県': '四国', '香川県': '四国', '愛媛県': '四国', '高知県': '四国',
  '福岡県': '九州・沖縄', '佐賀県': '九州・沖縄', '長崎県': '九州・沖縄', '熊本県': '九州・沖縄', '大分県': '九州・沖縄', '宮崎県': '九州・沖縄', '鹿児島県': '九州・沖縄', '沖縄県': '九州・沖縄',
};
const regionOf = (prefecture: string): string => regionByPrefecture[prefecture] ?? 'その他';
const regionDefinitions = [
  { id: '', label: 'すべて' },
  { id: '北海道', label: '北海道' },
  { id: '東北', label: '東北' },
  { id: '関東', label: '関東' },
  { id: '中部', label: '中部' },
  { id: '近畿', label: '近畿' },
  { id: '中国', label: '中国' },
  { id: '四国', label: '四国' },
  { id: '九州・沖縄', label: '九州・沖縄' },
] as const;

// Categorisation (hrt / mental / surgery, with surgery sub-types) lives in a
// shared util so the embedded map here and the global /map/ use the same rules.
const clinicsWithCategories = clinics.map((clinic) => ({
  ...clinic,
  categories: categoriesOf(clinic),
  surgeryTypes: surgeryTypesOf(clinic),
  capabilities: capabilitiesOf(clinic),
  giCertified: isGiCertified(clinic),
  type: typeOf(clinic.name),
  region: regionOf(clinic.prefecture),
  links: splitClinicUrls(clinic.urls),
}));

const prefectures = [...new Set(clinics.map((clinic) => clinic.prefecture))].sort((a, b) => {
  const indexA = prefectureOrder.indexOf(a);
  const indexB = prefectureOrder.indexOf(b);

  if (indexA === -1 || indexB === -1) {
    return a.localeCompare(b, 'ja');
  }

  return indexA - indexB;
});
const groupedClinics = prefectures.map((prefecture) => ({
  prefecture,
  clinics: clinicsWithCategories.filter((clinic) => clinic.prefecture === prefecture),
}));

// Data for an embedded clinics-only map (reuses /map.js). Only clinics with
// coordinates; no orgs/events here. Each pin is coloured by its 診療区分:
// surgery-capable first, then HRT, then mental.
const mapClinics = clinicsWithCategories
  .filter((clinic) => typeof clinic.lat === 'number' && typeof clinic.lng === 'number')
  .map((clinic) => ({
    id: clinic.id,
    name: clinic.name,
    area: [clinic.prefecture, clinic.city].filter(Boolean).join(' '),
    approx: clinic.geoSource !== 'address',
    genre: primaryGenre(clinic.categories),
    tags: clinicMapTags(clinic),
    lat: clinic.lat,
    lng: clinic.lng,
  }));
// Overseas SRS hospitals (タイ・韓国) live in map-pois.json as type 'surgery'.
// Show them on this embedded map too, so it matches the global /map/ (which was
// showing 9 surgery pins the clinic map omitted). The list below stays domestic.
const overseasSurgery = (poisData as { name: string; type: string; url: string; lat: number; lng: number }[])
  .filter((p) => p.type === 'surgery');
const clinicMapData = { clinics: mapClinics, pois: overseasSurgery };
const genreCounts = mapClinics.reduce(
  (acc, clinic) => ((acc[clinic.genre] = (acc[clinic.genre] ?? 0) + 1), acc),
  {} as Record<string, number>,
);
// The 手術 legend counts map pins, so include the overseas SRS surgery pins.
genreCounts.surgery = (genreCounts.surgery ?? 0) + overseasSurgery.length;
---

<BaseLayout title="医療機関一覧（ホルモン療法・性別適合手術ができる病院・クリニック） - とらんすナビ" description="トランスジェンダーのホルモン療法（MtF・FtM）や性別適合手術、診断に対応する全国の病院・クリニックを、地域別・診療区分別に探せます。地図・検索つき。受診前に必ず各医療機関へご確認ください。">
  <article class="article-shell">
    <div class="eyebrow">医療機関</div>
    <Mascot name="doctor" />
    <h1>医療機関</h1>
    <p class="lead">
      ホルモン療法や診断に関する医療機関。受診条件、診断書の要否、費用、診療内容は変わることがあります。
    </p>
    <p>予約前に必ず医療機関へ確認してください。口コミ、ランキング、推奨表現は掲載しません。詳しくは<a href="/legal/">掲載について</a>を確認してください。</p>
    <p>ホルモン療法そのものについて先に知りたいときは、<a href="/hrt-effects/">ホルモン療法で起きること</a>もどうぞ。診療内容の用語は<a href="/glossary/">用語集</a>で調べられます。<a href="/clinics/hormone-therapy/">ホルモン療法ができる病院・クリニック一覧</a>や<a href="/clinics/surgery/">性別適合手術（SRS）ができる病院・クリニック一覧</a>に、地域別でまとめたページもあります。</p>

    <div class="map-legend" aria-label="地図の凡例（診療区分）">
      <label><input type="checkbox" data-map-toggle="hrt" checked /><span class="map-dot map-dot-hrt" aria-hidden="true"></span>ホルモン療法<span class="map-legend-count">{genreCounts.hrt ?? 0}</span></label>
      <label><input type="checkbox" data-map-toggle="mental" checked /><span class="map-dot map-dot-mental" aria-hidden="true"></span>精神科・診断<span class="map-legend-count">{genreCounts.mental ?? 0}</span></label>
      <label><input type="checkbox" data-map-toggle="surgery" checked /><span class="map-dot map-dot-surgery" aria-hidden="true"></span>手術<span class="map-legend-count">{genreCounts.surgery ?? 0}</span></label>
    </div>
    <div id="map" class="map-canvas clinic-map" role="application" aria-label="医療機関の地図">
      <p class="map-fallback">地図を表示するには JavaScript が必要です。下の一覧からも探せます。</p>
    </div>
    <p class="clinic-map-note">
      ピンの色は診療区分、位置は住所からのおおよそです（番地が不明なものは市区町村のあたり）。ピンをタップすると掲載ページへ進めます。海外（タイ・韓国）でよく知られたSRS病院も「手術」として地図に表示しています（下の一覧は国内の医療機関です）。
      <a class="map-everything-link" href="/map/">当事者団体・イベントもふくむ地図を見る →</a>
    </p>
    <p class="source-note">
      地図は <a href="https://maplibre.org/" target="_blank" rel="noreferrer">MapLibre GL</a> と
      {' '}<a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noreferrer">OpenStreetMap</a> を利用しています。
    </p>
    <p>病院では、特定の医師や診療科だけがトランス関連の診療に対応していることがあります。予約のときに「ホルモン療法に対応していますか」「担当はどの先生ですか」と確認すると確実です。専門の医師を探す手がかりとして、<a href="http://www.gi-soc.jp/" target="_blank" rel="noreferrer">日本GI（性別不合）学会</a>の<a href="http://www.gi-soc.jp/ninteiiichiran.html" target="_blank" rel="noreferrer">認定医一覧</a>も役立ちます（当サイトは特定の医師をすすめたり順位づけしたりはしません）。</p>

    <p class="clinic-tags-note">
      各施設のカードには、公開情報で確認できた対応を<strong>タグ</strong>で表示しています（<a href="/glossary/gaht/">女性化／男性化ホルモン</a>、<a href="/glossary/gas/">SRS</a>・<a href="/glossary/voice-feminization-surgery/">VFS</a>・<a href="/glossary/ffs/">FFS</a>・豊胸など）。<strong>タグがないことは、対応していないという意味ではありません。</strong>もとの情報に書かれていないだけのこともあります。実際に受けられるかどうかは、かならず各医療機関にご確認ください。
    </p>

    <div class="clinic-summary" aria-label="掲載件数">
      <span><span data-filter-count>{clinics.length}</span>件</span>
      <span>{prefectures.length}地域</span>
    </div>

    <div class="filter-group-row">
      <span class="filter-tabs-label">診療区分</span>
      <section class="filter-tabs" aria-label="診療区分" data-filter-tabs data-filter-key="categories">
        {categoryDefinitions.map((category) => (
          <button
            type="button"
            class="filter-tab"
            data-filter-tab
            data-filter-value={category.id}
            aria-pressed={category.id === '' ? 'true' : 'false'}
          >
            {category.label}
          </button>
        ))}
      </section>
    </div>

    <div class="filter-group-row">
      <span class="filter-tabs-label">地方</span>
      <section class="filter-tabs" aria-label="地方" data-filter-tabs data-filter-key="regions">
        {regionDefinitions.map((region) => (
          <button
            type="button"
            class="filter-tab"
            data-filter-tab
            data-filter-value={region.id}
            aria-pressed={region.id === '' ? 'true' : 'false'}
          >
            {region.label}
          </button>
        ))}
      </section>
    </div>

    <div class="filter-group-row">
      <span class="filter-tabs-label" title="医療法による区分。病院は20床以上の入院設備をもつ施設、診療所は19床以下（クリニック・医院もここに含まれます）。">施設の規模</span>
      <section class="filter-tabs" aria-label="施設の規模（医療法による区分）" data-filter-tabs data-filter-key="types">
        {typeDefinitions.map((type) => (
          <button
            type="button"
            class="filter-tab"
            data-filter-tab
            data-filter-value={type.id}
            aria-pressed={type.id === '' ? 'true' : 'false'}
          >
            {type.label}
          </button>
        ))}
      </section>
    </div>

    <form class="index-search" role="search" data-filter-form>
      <label for="clinic-search">医療機関を検索</label>
      <input id="clinic-search" name="q" type="search" autocomplete="off" placeholder="例: 東京都、渋谷区、ホルモン療法" data-filter-input />
      <p id="clinic-search-help">医療機関名、地域、住所、診療内容で絞り込めます。</p>
    </form>

    {groupedClinics.map((group) => (
      <details class="clinic-region" data-filter-group>
        <summary aria-labelledby={`prefecture-${group.prefecture}`}>
          <span id={`prefecture-${group.prefecture}`}>{group.prefecture}</span>
          <span class="clinic-region-count"><span data-filter-group-count>{group.clinics.length}</span>件</span>
        </summary>
        <div class="clinic-list">
          {group.clinics.map((clinic) => (
            <article
              class="clinic-card"
              data-filter-item
              data-categories={clinic.categories.join(',')}
              data-surgery-types={clinic.surgeryTypes.join(',')}
              data-types={clinic.type}
              data-regions={clinic.region}
              data-search={[clinic.name, clinic.displayName, clinic.region, clinic.prefecture, clinic.city, clinic.address, clinic.phone, clinic.type, ...clinic.services, ...clinic.surgeryTypes, ...clinic.capabilities.map((cap) => CAPABILITY_LABELS[cap]), clinic.giCertified ? 'GI学会認定施設 保険適用' : ''].filter(Boolean).join(' ')}
            >
              <div class="clinic-card-header">
                <div>
                  <div class="clinic-name-row">
                    <a class="clinic-name-link" href={`/clinics/${clinic.id}/`}>
                      <span class="clinic-name">{clinic.name}</span>
                    </a>
                    <span class="clinic-type">{clinic.type}</span>
                  </div>
                  <span>{[clinic.city, clinic.address].filter(Boolean).join(' / ')}</span>
                </div>
                <button type="button" class="clinic-expand-button" data-expand-button aria-expanded="false">
                  詳細を開く
                </button>
              </div>
              <div class="clinic-meta">
                {clinic.phone && <span>電話: {clinic.phone}</span>}
                <span>{clinic.services.join('、')} / {clinic.verificationStatus}</span>
              </div>
              {(clinic.capabilities.length > 0 || clinic.giCertified) && (
                <ul class="clinic-tags" aria-label="公開情報で確認できた対応">
                  {clinic.giCertified && (
                    <li class="clinic-tag clinic-tag-certified">GI学会認定施設</li>
                  )}
                  {clinic.capabilities.map((cap) => (
                    <li class:list={['clinic-tag', cap.startsWith('gaht') ? 'clinic-tag-gaht' : 'clinic-tag-surgery']}>
                      {CAPABILITY_LABELS[cap]}
                    </li>
                  ))}
                </ul>
              )}
              <div class="clinic-links">
                {clinic.links.officialUrls.length > 0 ? (
                  clinic.links.officialUrls.map((url) => (
                    <a href={url} target="_blank" rel="noreferrer">
                      <span class="clinic-link-label">公式サイト</span>
                      <span class="clinic-link-url">{url}</span>
                    </a>
                  ))
                ) : (
                  <span>公式サイト未確認</span>
                )}
                {clinic.links.relatedUrls.length > 0 && (
                  <span>
                    関連ページ:
                    {' '}
                    {clinic.links.relatedUrls.map((url, index) => (
                      <>
                        {index > 0 && ' / '}
                        <a href={url} target="_blank" rel="noreferrer">{index + 1}</a>
                      </>
                    ))}
                  </span>
                )}
              </div>
              <div class="clinic-expand-panel" data-expand-panel hidden>
                <dl class="clinic-card-detail-list">
                  <div>
                    <dt>地域</dt>
                    <dd>{[clinic.prefecture, clinic.city].filter(Boolean).join(' / ')}</dd>
                  </div>
                  <div>
                    <dt>施設の規模</dt>
                    <dd>{clinic.type === '病院' ? '病院（20床以上）' : '診療所（19床以下）'}</dd>
                  </div>
                  {clinic.address && (
                    <div>
                      <dt>住所</dt>
                      <dd>{clinic.address}</dd>
                    </div>
                  )}
                  {clinic.phone && (
                    <div>
                      <dt>電話</dt>
                      <dd>{clinic.phone}</dd>
                    </div>
                  )}
                  <div>
                    <dt>掲載項目</dt>
                    <dd>{clinic.services.join('、')}</dd>
                  </div>
                  <div>
                    <dt>カテゴリ</dt>
                    <dd>{clinic.categories.map((category) => categoryDefinitions.find((item) => item.id === category)?.label ?? category).join(' / ')}</dd>
                  </div>
                  <div>
                    <dt>確認状況</dt>
                    <dd>{clinic.verificationStatus}</dd>
                  </div>
                </dl>
                <p><a href={`/clinics/${clinic.id}/`}>掲載ページを見る</a></p>
              </div>
            </article>
          ))}
        </div>
      </details>
    ))}
    <p class="empty-state" data-filter-empty hidden>条件に合う医療機関は見つかりませんでした。</p>
  </article>
  <script is:inline src="/filter-index.js" defer></script>
  <script type="application/json" id="map-data" set:html={JSON.stringify(clinicMapData)} />
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />
  <script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <script is:inline src="/map.js" defer></script>
</BaseLayout>
