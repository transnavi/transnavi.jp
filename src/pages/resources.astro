---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import organizations from '../data/organizations.json';
import poisData from '../data/map-pois.json';

const resources = await getCollection('resources');

// Embedded map of the place-based community resources (orgs, student circles,
// support desks, events) — the non-clinic POIs, reusing /map.js.
const resourceMapPois = (poisData as { name: string; type: string; url: string; lat: number; lng: number }[]).filter(
  (p) => p.type !== 'surgery',
);
const resourceMapData = { clinics: [], pois: resourceMapPois };
const poiTypeCounts = resourceMapPois.reduce(
  (acc, p) => ((acc[p.type] = (acc[p.type] ?? 0) + 1), acc),
  {} as Record<string, number>,
);

// Predefined search chips — common tags/regions, so people can filter by tapping
// instead of typing (clicking sets the search box; see public/filter-index.js).
const searchTags = ['相談', 'MtF', 'FtM', 'ノンバイナリー', '医療', 'ホルモン療法', 'SRS', '当事者会', '居場所', 'ブログ', '体験談', '法制度', '若者支援', '英語', '東京', '関西'];

const sectionDefinitions = [
  { key: 'guide', title: '入門・読みもの', tab: '入門', description: 'はじめて調べるときの解説や、個人・団体による情報発信。' },
  { key: 'media', title: '発信・メディア', tab: 'メディア', description: '当事者による YouTube・SNS・ポッドキャスト・ブログなどの発信。' },
  { key: 'directory', title: '医療機関・リンク集', tab: 'リンク集', description: '医療機関の一覧や、関連情報を探すための外部リンク集。' },
  { key: 'community', title: '団体・相談先', tab: '団体・相談先', description: '当事者団体、コミュニティ拠点、相談や学習につながる外部サイト。' },
  { key: 'research', title: '調査・データ', tab: '調査・データ', description: '調査研究、統計、制度データや社会課題の整理。' },
  { key: 'legal', title: '法制度・権利', tab: '法制度', description: '法制度や権利に関する情報、提言、キャンペーン。' },
  { key: 'medical', title: '医療情報', tab: '医療情報', description: '医療に関する外部情報。' },
] as const;

const sections = sectionDefinitions
  .map((section) => ({
    ...section,
    items: resources
      .filter((resource) => resource.data.category === section.key)
      .sort((a, b) => a.data.title.localeCompare(b.data.title, 'ja')),
  }))
  .filter((section) => section.items.length > 0);

const orgSections = organizations.sections;
const orgTabLabels: Record<string, string> = {
  'community-centers': '地域団体',
  'university-circles': '大学サークル',
};

const tabs = [
  ...sections.map((s) => ({ value: s.key, label: s.tab })),
  ...orgSections.map((s) => ({ value: s.key, label: orgTabLabels[s.key] ?? s.title })),
];

const orgItemCount = orgSections.reduce(
  (sum, s) => sum + s.groups.reduce((g, group) => g + group.items.length, 0),
  0,
);
const totalCount = resources.length + orgItemCount;

const langLabels: Record<string, string> = {
  en: '英語',
  'zh-Hans': '中国語',
  'zh-Hant': '中国語',
  ko: '韓国語',
  other: '多言語',
};
---

<BaseLayout title="関連サイト - とらんすナビ" description="外部サイト、団体、リンク集。">
  <article class="article-shell">
    <div class="eyebrow">関連サイト</div>
    <h1>関連サイト</h1>
    <p class="lead">外部サイト、団体、リンク集を分野ごとにまとめています。分類で絞り込んだり、名前やタグで検索できます。場所から探したいときは<a href="/map/">地図で探す</a>もどうぞ。海外の英語・中国語の資料には有用な情報が多くありますが、制度や医療事情は国によって違います。日本との違いを確認しながら読んでください（<a href="/about/">編集方針</a>）。MtF.wiki のリンク集を抄訳した<a href="/library/mtf-wiki-ja/docs/links/">リンク集（資料集）</a>もあります。</p>

    <div class="clinic-summary" aria-label="掲載件数">
      <span><span data-filter-count>{totalCount}</span>件</span>
      <span>{tabs.length}分類</span>
    </div>

    <section class="resource-map" aria-label="団体・拠点の地図">
      <div class="map-legend" aria-label="地図の凡例">
        <label><input type="checkbox" data-map-toggle="org" checked /><span class="map-dot map-dot-org" aria-hidden="true"></span>団体・拠点<span class="map-legend-count">{poiTypeCounts.org ?? 0}</span></label>
        <label><input type="checkbox" data-map-toggle="circle" checked /><span class="map-dot map-dot-circle" aria-hidden="true"></span>学生サークル<span class="map-legend-count">{poiTypeCounts.circle ?? 0}</span></label>
        <label><input type="checkbox" data-map-toggle="desk" checked /><span class="map-dot map-dot-desk" aria-hidden="true"></span>相談窓口<span class="map-legend-count">{poiTypeCounts.desk ?? 0}</span></label>
        <label><input type="checkbox" data-map-toggle="event" checked /><span class="map-dot map-dot-event" aria-hidden="true"></span>イベント<span class="map-legend-count">{poiTypeCounts.event ?? 0}</span></label>
      </div>
      <div id="map" class="map-canvas" role="application" aria-label="団体・拠点・相談窓口・イベントの地図">
        <p class="map-fallback">地図を表示するには JavaScript が必要です。下の一覧からも探せます。</p>
      </div>
      <p class="clinic-map-note">
        場所のわかる団体・拠点・相談窓口・イベントを地図にしています。
        <a class="map-everything-link" href="/map/">医療機関もふくむ地図を見る →</a>
      </p>
    </section>

    <section class="filter-tabs" aria-label="分類" data-filter-tabs>
      <button type="button" class="filter-tab" data-filter-tab data-filter-value="" aria-pressed="true">すべて</button>
      {tabs.map((tab) => (
        <button type="button" class="filter-tab" data-filter-tab data-filter-value={tab.value} aria-pressed="false">
          {tab.label}
        </button>
      ))}
    </section>

    <form class="index-search" role="search" data-filter-form>
      <label for="resource-search">サイトを検索</label>
      <input id="resource-search" name="q" type="search" autocomplete="off" placeholder="例: 相談、MtF、大阪、大学" data-filter-input />
      <p id="resource-search-help">名前、タグ、地域で絞り込めます。下のタグから選ぶこともできます。</p>
      <div class="filter-tag-chips" aria-label="よく使うタグ">
        {searchTags.map((tag) => (
          <button type="button" class="filter-tag-chip" data-filter-set={tag} aria-pressed="false">{tag}</button>
        ))}
      </div>
    </form>

    {sections.map((section) => (
      <section class="link-section" data-filter-group aria-labelledby={`resource-section-${section.key}`}>
        <h2 id={`resource-section-${section.key}`}>{section.title}</h2>
        <p class="resource-section-intro">{section.description}</p>
        <div class="link-chips">
          {section.items.map((resource) => (
            <a
              class="link-chip"
              href={resource.data.url}
              target="_blank"
              rel="noreferrer"
              title={resource.data.description}
              data-filter-item
              data-categories={section.key}
              data-search={[resource.data.title, resource.data.description, ...resource.data.tags, ...resource.data.topicTags].join(' ')}
            >
              <span class="link-chip-title">{resource.data.title}</span>
              {resource.data.language !== 'ja' && langLabels[resource.data.language] && (
                <span class="link-chip-lang">{langLabels[resource.data.language]}</span>
              )}
              {(resource.data.topicTags.length > 0 ? resource.data.topicTags : resource.data.tags).length > 0 && (
                <span class="link-chip-tags">
                  {(resource.data.topicTags.length > 0 ? resource.data.topicTags : resource.data.tags).slice(0, 4).map((tag) => (
                    <span class="link-chip-tag">{tag}</span>
                  ))}
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    ))}

    {orgSections.map((section) => (
      <section class="link-section" data-filter-group aria-labelledby={`org-section-${section.key}`}>
        <h2 id={`org-section-${section.key}`}>{section.title}</h2>
        <p class="resource-section-intro">{section.description}</p>
        {section.groups.map((group) => (
          <div class="link-group" data-filter-group>
            <h3 class="link-group-region">{group.region}</h3>
            <div class="link-chips">
              {group.items.map((item) => (
                <a
                  class="link-chip link-chip-compact"
                  href={item.url}
                  target="_blank"
                  rel="noreferrer"
                  data-filter-item
                  data-categories={section.key}
                  data-search={[item.name, group.region].join(' ')}
                >
                  <span class="link-chip-title">{item.name}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
        {section.reference && (
          <p class="resource-section-intro link-section-reference">
            参考: <a href={section.reference.url} target="_blank" rel="noreferrer">{section.reference.name}</a>
          </p>
        )}
      </section>
    ))}

    <p class="empty-state" data-filter-empty hidden>条件に合うサイトは見つかりませんでした。</p>

    <p class="source-note">
      一部のリンクは
      {' '}<a href="https://github.com/project-trans/2345.LGBT/" target="_blank" rel="noreferrer">project-trans/2345.LGBT</a>
      （CC0）をもとに、当サイトで追加・更新しています。リンク先の内容は各運営者に帰属します。
    </p>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/support/">相談先</a>
      <a class="word-chip" href="/clinics/">医療機関</a>
      <a class="word-chip" href="/bibliography/">文献（書籍・論文）</a>
      <a class="word-chip" href="/library/">資料集</a>
      <a class="word-chip" href="/works/">文芸作品</a>
    </nav>
  </article>
  <script type="application/json" id="map-data" set:html={JSON.stringify(resourceMapData)} />
  <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />
  <script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <script is:inline src="/map.js" defer></script>
  <script is:inline src="/filter-index.js" defer></script>
</BaseLayout>
