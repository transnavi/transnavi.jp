---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cite from '../components/Cite.astro';
import References from '../components/References.astro';
import Mascot from '../components/Mascot.astro';

const doList = [
  '「話してくれてありがとう」と、まず受けとめてください。打ち明けるには、たくさんの勇気が要ります。',
  'お子さんが望む名前や呼び方（「彼／彼女／その子」など）を確認し、家のなかで少しずつ使ってみてください。',
  '「すぐに全部を理解できなくて大丈夫」。わからないことは正直に伝えつつ、あなたが味方であることは何度でも伝えてください。',
  '今この場で医療や手続きを決める必要はありません。今日いちばん大切なのは、お子さんが安心できることです。',
  '「あなたはあなたのままで大切」と、性別に関係なく愛していることを、言葉と態度でくり返し示してください。',
  '本人の許可なく、親戚や学校に話さないでください。誰にいつ伝えるかは、本人と相談して決めましょう。',
  'お子さんが安心して眠れて、食べられて、つながれているか。日々の小さな安全と居場所を、そっと見守ってください。',
  '焦らず、お子さんのペースで。',
];

const avoidList = [
  {
    text: '「ただの一時期」「気のせい」と片づけたくなるかもしれませんが、まずはそのまま受けとめてみませんか。',
    why: '否定されると本人は「わかってもらえない」と感じ、相談をやめて孤立しやすくなります。',
  },
  {
    text: '「もとに戻そう」「治そう」とする働きかけは、よかれと思っても、お子さんを追いつめてしまいます。',
    why: 'いわゆる「転向（コンバージョン）療法」は効果がなく、抑うつや自傷のリスクを高めると国際的に否定されています。',
  },
  {
    text: '「らしくしなさい」「人前では隠して」と、変わることや隠すことを強く求めるのは、少し立ち止まって考えたいところです。',
    why: 'ありのままを否定されると自己肯定感が下がり、不安や抑うつ、自殺念慮のリスクが高まることがわかっています。',
  },
  {
    text: '本人の同意なく、親戚や学校・周囲に話してしまう前に、一度ご本人に確認してみてください。',
    why: '本人の意思に反したアウティングは信頼関係を壊し、思わぬ差別やいじめにさらす危険があります。',
  },
  {
    text: 'ホルモンや手術などの医療を焦って急がせるのも、逆に頭ごなしに禁じるのも、どちらも避けたいことです。',
    why: '医療は本人の年齢・希望・専門家との相談で進めるもので、一方的な強制や禁止は、かえって本人を傷つけます。',
  },
  {
    text: '「育て方が悪かった」と自分を責めたり、「あなたのせいで」とお子さんを責めたりしないでください。',
    why: '性自認は育て方や本人の落ち度で決まるものではなく、誰のせいでもないと理解されています。',
  },
];
---

<BaseLayout
  title="保護者の方へ（お子さんから打ち明けられたとき） - とらんすナビ"
  description="お子さんから性別のことを打ち明けられた、あるいは気づいたとき。戸惑うのは自然なことです。あなたの受けとめがお子さんを守ること、してあげられること、気をつけたいこと、そして親であるあなた自身の相談先を、やさしくまとめました。"
>
  <article class="article-shell prose">
    <div class="eyebrow">周囲の人へ</div>
    <Mascot name="support-heart" />
    <h1>保護者の方へ</h1>
    <p class="lead">
      お子さんから性別のことを打ち明けられた。あるいは、もしかして、と感じている。そんなとき、戸惑うのは自然なことです。すぐに全部を理解できなくて大丈夫。このページは、最初の一歩をいっしょに考えるためのものです。いちばん大切なのは、あなたがお子さんの味方でいること。それだけで、お子さんの毎日は、ずっと安心できるものになります。
    </p>

    <div class="page-disclaimer">
      正解が一つに決まっているわけではありません。ここに書いたのは「こう関わると、お子さんの安心につながりやすい」という手がかりです。あなた自身も戸惑って当然なので、どうか一人で抱え込まないでください。
    </div>

    <section aria-labelledby="thanks">
      <h2 id="thanks">まず、ひと言だけ</h2>
      <p>
        お子さんがあなたに打ち明けたのは、あなたを信じているからです。返すことばは、立派でなくて大丈夫。「話してくれてありがとう」「あなたのことが大切だよ」。それだけで、十分に伝わります。
      </p>
      <p>
        うまく言えなくても、戸惑っても、それは愛情がないということではありません。これから少しずつ知っていけば大丈夫です。
      </p>
    </section>

    <section aria-labelledby="evidence">
      <h2 id="evidence">あなたの受けとめが、お子さんを守る</h2>
      <p>
        親や家族の関わり方は、お子さんのこころの健康に、とても大きく影響します。これは気持ちの問題だけでなく、研究でもくり返し示されてきたことです。
      </p>
      <ul>
        <li>
          <Cite src="familyproject-family-rejection">家族から強く拒絶された性的マイノリティの若者は、そうでない若者に比べて、自殺を試みる割合が約8.4倍、深刻なうつ状態になる割合が約5.9倍高かった</Cite>という報告があります。
        </li>
        <li>
          逆に、<Cite src="familyproject-family-acceptance-of">家族から受け入れられた若者は、自殺念慮や自殺未遂、うつや薬物乱用から守られていた</Cite>と報告されています。
        </li>
        <li>
          <Cite src={['thetrevorproject-accepting-adults-reduce', 'thetrevorproject-protectiveness-of-famil']}>「受け入れてくれる大人が、少なくとも一人いる」ことは、若者の自殺リスクをはっきり下げます</Cite>。その一人に、あなたがなれます。
        </li>
        <li>
          <Cite src="rebit-2022-youth">日本の調査では、10代のLGBTQの過去1年で53.9%が自殺を考え、19.6%が自殺未遂を経験し、40.8%が「安心して話せる相手や場所がない」と答えています</Cite>。だからこそ、家庭が安心できる場所であることに、大きな意味があります。
        </li>
      </ul>
      <p>
        完璧な親である必要はありません。「ありのままでいいよ」と言える人が一人いるだけで、お子さんの世界はずいぶん生きやすくなります。
      </p>
    </section>

    <section aria-labelledby="do">
      <h2 id="do">してあげられること</h2>
      <p>大きなことをしなくて大丈夫。今日からできる、小さなことばかりです。</p>
      <ul class="assure-list">
        {doList.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section aria-labelledby="avoid">
      <h2 id="avoid">気をつけたいこと</h2>
      <p>
        どれも、お子さんを思うからこそ出てくる気持ちです。責める意図はありません。ただ、結果としてお子さんを追いつめてしまいやすいことを、いくつか挙げておきます。
      </p>
      <ul>
        {avoidList.map((item) => (
          <li>
            {item.text}
            <br />
            <span class="muted-note">{item.why}</span>
          </li>
        ))}
      </ul>
      <p>
        とくに、無理に「治そう」とすることについて。<Cite src="apa-the-evidence-against">性自認や性的指向を変えようとする「転向（コンバージョン）療法」は、効果が確かめられておらず、むしろ心の健康を害すると、専門家の団体が一致して否定しています</Cite>。お子さんは、治す対象ではありません。
      </p>
    </section>

    <section aria-labelledby="self-care">
      <h2 id="self-care">親であるあなたも、ひとりで抱えないで</h2>
      <p>
        お子さんを支えるには、まずあなた自身が支えられていることが大切です。同じ立場の親と話したり、専門の窓口に相談したりすることは、わがままでも弱さでもありません。
      </p>
      <ul>
        <li>
          <a href="https://lgbt-family.or.jp/" target="_blank" rel="noreferrer">NPO法人 LGBTの家族と友人をつなぐ会</a>
          ：LGBTQの子をもつ親・家族のための、日本で代表的な会。全国でのミーティングや、講演・相談を行っています。
        </li>
        <li>
          <a href="https://queerfamily.jimdofree.com/" target="_blank" rel="noreferrer">にじいろかぞく</a>
          ：子育てするLGBTとその家族をつなぐ会。お茶会や勉強会、オンラインのチャットで、日常的な相談ができます。
        </li>
        <li>
          <a href="https://gid.jp/" target="_blank" rel="noreferrer">一般社団法人 gid.jp</a>
          ：性別違和の当事者会に加え、家族のための「家族交流会」を開いています。
        </li>
        <li>
          <a href="https://www.since2011.net/yorisoi/n4/" target="_blank" rel="noreferrer">よりそいホットライン（セクシュアルマイノリティ専門ライン）</a>
          ：24時間・無料の電話相談（0120-279-338、ガイダンス後に「4」）。親・家族からの相談も受け付けています。
        </li>
      </ul>
      <p>
        ほかの相談先は、<a href="/support/">相談先</a>のページにもまとめています。お子さん本人には、年代の近い人と出会える<a href="/resources/">居場所・関連サイト</a>を、そっと紹介してあげられるかもしれません。
      </p>
    </section>

    <section aria-labelledby="next">
      <h2 id="next">もう少し知りたくなったら</h2>
      <p>
        急がなくて大丈夫です。気になったときに、少しずつどうぞ。
      </p>
      <ul>
        <li>そもそも、トランスジェンダーって？ という方は<a href="/basics/">きほんのこと</a>から。</li>
        <li>打ち明けること全般については<a href="/coming-out/">カミングアウト入門</a>を。</li>
        <li>学校での配慮や相談については<a href="/school/">学校でのこと</a>を。</li>
        <li>身近な人としてのより広い関わり方は<a href="/allies/">周囲の人へ</a>を。</li>
      </ul>
    </section>

    <aside class="entry-message" role="note" aria-label="保護者の方へ">
      <p>あなたが戸惑いながらもこのページを開いていること自体が、お子さんを大切に思っている証です。その気持ちは、きっと伝わります。</p>
    </aside>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/allies/">周囲の人へ</a>
      <a class="word-chip" href="/coming-out/">カミングアウト入門</a>
      <a class="word-chip" href="/school/">学校でのこと</a>
      <a class="word-chip" href="/support/">相談先</a>
      <a class="word-chip" href="/basics/">きほんのこと</a>
      <a class="word-chip" href="/resources/">関連サイト</a>
    </nav>
    <References route="/parents/" />
  </article>
</BaseLayout>
