---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cite from '../components/Cite.astro';
import References from '../components/References.astro';

const areas = [
  {
    name: '顔・ヒゲ',
    body: 'いちばん相談の多い部位です。ホルモン療法では薄くなっても完全には消えにくく、脱毛を考える人が多くいます。範囲が広く、回数も多めになりがち。白髪が混じると、レーザーでは効きにくいため電気脱毛が選ばれます。',
  },
  {
    name: '脇下（わき）',
    body: '範囲は狭めで、比較的取り組みやすい部位です。日常では剃毛で対応する人も多く、しっかりなくしたい場合に脱毛を選びます。',
  },
  {
    name: 'VIO（デリケートゾーン）',
    body: '陰部まわりのこと。性別適合手術（SRS）を受ける場合、手術する部位の毛を事前になくしておくよう求められることがあります。皮膚が敏感で痛みも出やすいため、慣れた施設で慎重に。自己処理は深追いせず、肌を傷つけないように。',
  },
  {
    name: '腕・脚・胸・おなか',
    body: '広い範囲です。全部を一度にやろうとせず、気になるところから少しずつでも大丈夫。剃毛やワックスで日々整えつつ、脱毛を組み合わせる人もいます。',
  },
];
---

<BaseLayout
  title="脱毛と毛の処理（ヒゲ・体毛・VIO）の入門 - とらんすナビ"
  description="剃毛・ワックス・コンシーラーなど日々の毛の処理から、レーザー脱毛・電気脱毛まで。顔（ヒゲ）・脇下・VIO など部位ごとの話と、肌を守るための注意。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>脱毛と毛の処理の入門</h1>
    <p class="page-disclaimer">
      情報提供のみを目的としたページです。効果や費用には個人差・施設差があります。施術の判断は、施設や医師に相談してください。
    </p>
    <p class="lead">
      毛を減らしたい・なくしたいと思ったとき、方法はいくつもあります。すぐにできる日々の処理から、時間をかけて行う脱毛まで、順番に見ていきましょう。どこまでやるかは、あなたの自由です。
    </p>

    <section aria-labelledby="two-kinds">
      <h2 id="two-kinds">「処理」と「脱毛」は、別のもの</h2>
      <p>大きく分けて、2つの考え方があります。組み合わせて使うのがふつうです。</p>
      <div class="concept-grid">
        <div class="concept-card">
          <h3>一時的な処理</h3>
          <p>剃る、抜く、ワックス、隠す（コンシーラー）など。今すぐ・安くできますが、また生えてきます。</p>
        </div>
        <div class="concept-card">
          <h3>永久的な脱毛</h3>
          <p>レーザー脱毛・電気脱毛。時間と費用はかかりますが、毛そのものを減らしていきます。</p>
        </div>
      </div>
    </section>

    <section aria-labelledby="daily">
      <h2 id="daily">すぐにできる、毛の処理</h2>
      <ul class="assure-list">
        <li><strong>剃毛（シェービング）</strong>：いちばん手軽です。シェービング剤を使い、毛の流れに沿ってやさしく剃り、あとは保湿を。カミソリの逆剃りや乾いた肌での剃毛は、肌荒れ・カミソリ負けの原因になります。電気シェーバーは肌にやさしめです。すぐ生えてくるのが難点。</li>
        <li><strong>ワックス・毛抜き</strong>：根元から抜くので、数週間はつるつるが続きます。ただし痛みがあり、肌への負担や<strong>埋没毛</strong>（毛が皮膚の中に埋もれる）が起きることも。広い範囲はワックスが向きますが、敏感な部位は慎重に。</li>
        <li><strong>除毛クリーム</strong>：毛を溶かして処理します。肌に合わないことがあるので、必ず先に<strong>パッチテスト</strong>を。顔やデリケートゾーン用かどうかも確認してください。</li>
        <li><strong>コンシーラーで隠す</strong>：青ヒゲ（剃りあとの青み）は、オレンジ・赤み系のコントロールカラーを重ねてからファンデーションを塗ると、目立ちにくくなります。これは「なくす」のではなく「隠す」方法です。くわしくは<a href="/presentation/">見た目と、毎日のこと</a>をどうぞ。</li>
      </ul>
    </section>

    <section aria-labelledby="kinds">
      <h2 id="kinds">永久的な脱毛：大きく2つの方法</h2>
      <div class="concept-grid">
        <div class="concept-card">
          <h3>レーザー脱毛</h3>
          <p><Cite src={['my-laser-hair-removal', 'pubmed-a-review-of']}>黒い毛に反応する光をあてる方法。広い範囲を比較的早く処理できます。白髪や色の薄い毛には効きにくく、回数を重ねる必要があります</Cite>。</p>
        </div>
        <div class="concept-card">
          <h3>電気（ニードル）脱毛</h3>
          <p><Cite src={['my-laser-hair-removal', 'pubmed-a-review-of']}>毛穴ひとつずつに処理する方法。白髪にも効き、恒久的とされますが、時間がかかり、痛みも強めです</Cite>。仕上げや、レーザーで残った毛に向きます。</p>
        </div>
      </div>
      <p>多くの人は、まずレーザーで全体を減らし、残った毛や白髪を電気脱毛で仕上げる、という組み合わせをとります。</p>
    </section>

    <section aria-labelledby="areas">
      <h2 id="areas">部位（エリア）ごとのこと</h2>
      <div class="concept-grid">
        {areas.map((area) => (
          <div class="concept-card">
            <h3>{area.name}</h3>
            <p>{area.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section aria-labelledby="presurgical">
      <h2 id="presurgical">手術の前に行う脱毛</h2>
      <p>
        <Cite src="pmc-presurgical-laser-hair">性別適合手術（SRS）を受ける場合、手術する部位（VIOなど）の毛を、手術の前にレーザーなどでなくしておくよう求められることがあります</Cite>。皮膚が敏感で痛みも出やすい部位なので、経験のある施設で、計画的に進めると安心です。手術を考えている人は、早めに医療機関へ相談しておくとよいでしょう（<a href="/surgery/">移行のための手術</a>）。
      </p>
    </section>

    <section aria-labelledby="safety">
      <h2 id="safety">肌を守るために</h2>
      <ul class="assure-list">
        <li>新しい方法・新しい製品は、まず<strong>パッチテスト</strong>から。</li>
        <li>脱毛やワックスの前後は、肌が敏感になります。<strong>日焼けを避け、保湿</strong>を。</li>
        <li><Cite src="kokusen">赤み・痛み・化膿・強いかゆみが続くときは、無理をせず皮膚科へ</Cite>。</li>
        <li>デリケートゾーン（VIO）は、自己処理で深追いしないこと。心配なときは医療機関で。</li>
      </ul>
    </section>

    <section aria-labelledby="japan">
      <h2 id="japan">日本での「医療脱毛」と「サロン」の違い</h2>
      <p>
        日本では、医療機関で行う<strong>医療脱毛</strong>と、エステなどの<strong>脱毛サロン（光脱毛）</strong>が区別されています。<Cite src={['mhlw-3', 'igaku-datumou-gakkai']}>効果の強さ、安全管理、費用が異なります</Cite>。長く付き合うことになるので、対応している施設を確認できると安心です。
      </p>
      <p>
        医療脱毛は、病院やクリニックの<strong>皮膚科・美容皮膚科</strong>などで受けられます。<Cite src="igaku-datumou-gakkai">トランスジェンダーの脱毛は、ほとんどが</Cite><strong>自費診療（保険適用外）</strong>です。費用は部位・回数・施設によって幅があり、ヒゲ全体だと数万円〜十数万円ほどかかることもあります。総額の見積もりを、はじめに確認しておくと安心です。
      </p>
    </section>

    <aside class="entry-message" role="note" aria-label="読んでいるあなたへ">
      <p>毛のことは、時間も手間もかかります。一度に完璧を目指さなくて大丈夫。今日できる小さな処理からでも、十分です。</p>
    </aside>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/presentation/">見た目と、毎日のこと</a>
      <a class="word-chip" href="/transition/">性別移行を知る</a>
      <a class="word-chip" href="/clinics/">医療機関</a>
      <a class="word-chip" href="/resources/">関連サイト</a>
    </nav>

    <p class="source-note">
      方法の比較などは
      {' '}<a href="https://mtf.wiki/" target="_blank" rel="noreferrer">MtF.wiki</a>
      なども参考になります。医療脱毛に対応する皮膚科・美容皮膚科の情報は地域差が大きいため、<a href="/clinics/">医療機関</a>や<a href="/resources/">関連サイト</a>もあわせて確認してください。
    </p>
    <References route="/hair-removal/" />
  </article>
</BaseLayout>
