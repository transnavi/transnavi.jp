---
import BaseLayout from '../../layouts/BaseLayout.astro';
import glossaryData from '../../data/glossary.json';
import pageTags from '../../data/page-tags.json';
import { TAGS, FACETS } from '../../data/tag-taxonomy';
import type { GlossaryEntry } from '../../types/glossary';

export function getStaticPaths() {
  return Object.entries(TAGS).map(([label, v]) => ({ params: { slug: v.slug }, props: { label } }));
}

const { label } = Astro.props as { label: string };
const meta = TAGS[label];
const entries = glossaryData as GlossaryEntry[];
const pt = pageTags as Record<string, { title: string; tags: string[] }>;

const terms = entries.filter((e) => (e.tags ?? []).includes(label));
const pages = Object.entries(pt)
  .filter(([, v]) => v.tags.includes(label))
  .map(([route, v]) => ({ route, title: v.title }));

// Sibling tags = tags sharing a branch in the taxonomy (the "near" part of the tree).
const siblings = new Set<string>();
for (const f of FACETS) for (const b of f.branches) if (b.tags.includes(label)) for (const t of b.tags) siblings.add(t);
siblings.delete(label);
---

<BaseLayout
  title={`${label}（タグ） - とらんすナビ`}
  description={`「${label}」のタグがついた用語とページの一覧。${meta?.desc ?? ''}`}
>
  <article class="article-shell">
    <div class="eyebrow">タグ</div>
    <h1>{label}</h1>
    {meta?.desc && <p class="lead">{meta.desc}</p>}
    <div class="clinic-summary" aria-label="件数">
      <span>{terms.length} 語</span>
      <span>{pages.length} ページ</span>
    </div>

    {pages.length > 0 && (
      <section aria-labelledby="tag-pages">
        <h2 id="tag-pages">ページ</h2>
        <ul class="tag-page-list">
          {pages.map((p) => (
            <li><a href={p.route}>{p.title}</a></li>
          ))}
        </ul>
      </section>
    )}

    {terms.length > 0 && (
      <section aria-labelledby="tag-terms">
        <h2 id="tag-terms">用語</h2>
        <div class="word-chips">
          {terms.map((t) => (
            <a class="word-chip" href={`/glossary/${t.id}/`}>{t.term}</a>
          ))}
        </div>
      </section>
    )}

    {siblings.size > 0 && (
      <nav class="entry-siblings" aria-label="近いタグ">
        <span class="entry-siblings-label">近いタグ</span>
        <div class="word-chips">
          {[...siblings].map((s) => TAGS[s] && (
            <a class="word-chip" href={`/tags/${TAGS[s].slug}/`}>{s}</a>
          ))}
        </div>
      </nav>
    )}

    <p><a href="/tags/">← タグの地図（すべてのタグ）</a></p>
  </article>
</BaseLayout>
