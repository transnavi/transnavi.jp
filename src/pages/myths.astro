---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cite from '../components/Cite.astro';
import References from '../components/References.astro';

// よくある誤解（myth / fact）。誤解と、その隣にやさしい事実を置き、くわしく
// 読めるページへ橋渡しする。事実の根拠には出典をつける。`cite` は本文の末尾に
// 出典マーカー[n]として表示される（参照キーは citation-pages.yml の /myths/）。
const mythGroups = [
  {
    title: '「そういう存在」についての誤解',
    items: [
      {
        myth: 'トランスジェンダーは心の病気で、治して「もとに戻す」もの。',
        truth: 'トランスであること自体は、治す対象ではありません。世界の診断基準（ICD-11）でも、精神疾患の分類から外れています。性自認や性的指向を変えようとする「転向（コンバージョン）療法」は効果がなく、むしろ心の健康を害すると、専門家の団体が一致して否定しています。',
        cite: ['who-icd11', 'apa-the-evidence-against'],
        links: [{ href: '/dysphoria/', label: '性別違和を知る' }, { href: '/basics/', label: 'きほんのこと' }],
      },
      {
        myth: '性自認は「誰を好きになるか」で決まる。トランスって、つまりゲイのこと。',
        truth: '「自分がどんな性別か（性自認）」と「誰を好きになるか（性的指向）」は、別々のものさしです。トランスの人のなかにも、異性が好きな人・同性が好きな人・どちらも、あるいはどちらでもない人がいます。',
        cite: ['apa-understanding-transgender-people'],
        links: [{ href: '/orientation/', label: '性的指向と「好き」のいろいろ' }, { href: '/basics/', label: 'きほんのこと' }],
      },
      {
        myth: 'トランスというのは、性的な趣味やフェティシズムにすぎない。とくにトランス女性は、性的な動機からそうしている。',
        truth: '「自分がどんな性別か（性同一性）」は、性的な興奮や趣味とは別のものです。たとえば、異性の服を着ること（異性装）が好きな人の多くは、自分の生まれた性別に違和感はなく、性別を変えたいわけでもありません。異性装は、その人らしい「装いの表現」のひとつで、かならずしも性的なものではありません。トランスであることは、性的な目的ではなく、自分の性別をどう生きるかという、その人の根っこに関わることです。',
        cite: ['apa-understanding-transgender-people'],
        links: [{ href: '/orientation/', label: '性的指向と「好き」のいろいろ' }, { href: '/gender/', label: '性別は、男女だけじゃない' }],
      },
      {
        myth: '異性装やドラァグをしている人は、みんなトランスジェンダーだ。',
        truth: '服装やパフォーマンスと、その人の性別（性自認）は、別のものさしです。異性装を楽しむ人の多くは、自分の生まれた性別にしっくりきていますし、ドラァグは舞台や催しでの表現・エンターテインメントとして行われることが多いものです。装いやステージとして性別を表現することと、自分の性別そのものをトランスとして生きることは、重なる人もいれば、まったく別の人もいます。どちらも、その人らしいあり方のひとつです。',
        cite: ['apa-understanding-transgender-people'],
        links: [{ href: '/presentation/', label: '見た目と、毎日のこと' }, { href: '/gender/', label: '性別は、男女だけじゃない' }],
      },
      {
        myth: '最近SNSで急に増えた、一時的な流行にすぎない。',
        truth: '性別の多様なあり方は、今に始まったことではありません。世界の各地に、昔から多様な性を生きてきた人びとがいます。増えたように見えるのは、語るための言葉と、安心して話せる場所が、少しずつ増えてきたからです。',
        cite: ['apa-understanding-transgender-people'],
        links: [{ href: '/history/', label: 'トランスジェンダーの歴史' }, { href: '/basics/', label: 'きほんのこと' }],
      },
      {
        myth: '友達やSNSの影響でトランスは「うつる」もの。まわりに流されて、自分もそうだと思い込んでいるだけ。',
        truth: '性別の悩みが、友達やネットから「うつる」ように広がる、という考え方を裏づける、しっかりした研究はありません。安心して話せる仲間や、自分を表す言葉に出会って、ずっとあった気持ちに、やっと名前をつけられた。それはよくあることで、「流された」のとはちがいます。専門家の団体も、この「急に発症する」「まわりからうつる」という見方を支える証拠はない、としています。',
        cite: ['caaps-rogd-statement'],
        links: [{ href: '/dysphoria/', label: '性別違和を知る' }, { href: '/parents/', label: '保護者の方へ' }],
      },
      {
        myth: 'ノンバイナリーやXジェンダーは、欧米から来た外来の考え方で、日本には関係ない。',
        truth: '男女のどちらでもない、どちらでもある、という感じ方は、世界の各地に古くからあります。じつは「Xジェンダー」は、1990年代後半ごろから、日本の当事者の自助グループやインターネットのなかで名づけられ、つかわれてきた言葉です。「ノンバイナリー」は国際的にひろく使われている言葉です。どちらも、生き方そのものは「輸入品」ではなく、ずっとここにあったあり方に、あとから名前がついたものです。',
        cite: ['takeuchi-xgender', 'apa-understanding-transgender-people'],
        links: [{ href: '/history/', label: 'トランスジェンダーの歴史' }, { href: '/glossary/non-binary/', label: 'ノンバイナリー' }],
      },
      {
        myth: 'ノンバイナリーやXジェンダーは、中途半端で、本気じゃない。',
        truth: '男性・女性のどちらか、という枠にしっくりこないあり方も、ごく自然な性のかたちのひとつです。二つの性別の枠に収まらない生き方は、世界の各地に古くからあります。',
        links: [{ href: '/gender/', label: '性別は、男女だけじゃない' }, { href: '/glossary/non-binary/', label: 'ノンバイナリー' }],
      },
      {
        myth: 'トランスジェンダーって、男性から女性になる人（MtF）のことでしょう。',
        truth: 'トランスジェンダーには、女性から男性へ（FtM・トランス男性）の人も、男女どちらの枠にもおさまらない人も含まれます。トランス女性だけを指す言葉ではありません。トランス男性やトランスマスキュリンの人たちは見えにくくされがちですが、同じように、ここにいます。',
        cite: ['apa-understanding-transgender-people'],
        links: [{ href: '/basics/', label: 'きほんのこと' }, { href: '/transition/', label: '性別移行を知る' }],
      },
      {
        myth: '親の育て方や、まわりの環境のせいでトランスになる。',
        truth: '性自認は、育て方や本人の落ち度で決まるものではありません。誰のせいでもありません。',
        cite: ['apa-understanding-transgender-people'],
        links: [{ href: '/parents/', label: '保護者の方へ' }, { href: '/basics/', label: 'きほんのこと' }],
      },
      {
        myth: '子どもや若者が言う性別の悩みは、ただの気の迷い。',
        truth: '気持ちが一時的に揺れることもありますが、頭から否定されると、本人は「わかってもらえない」と感じて孤立しやすくなります。まず受けとめてもらえた経験は、その後の心の健康を守ることが、研究で示されています。',
        cite: ['familyproject-family-acceptance-of'],
        links: [{ href: '/parents/', label: '保護者の方へ' }, { href: '/dysphoria/', label: '性別違和を知る' }],
      },
    ],
  },
  {
    title: '移行と医療についての誤解',
    items: [
      {
        myth: '手術やホルモンをしていないと、「本物のトランス」ではない。',
        truth: '移行のかたちは人それぞれで、医療は必須ではありません。何をするか・しないかを選ぶのは、本人です。どこまで進んでいても、いなくても、あなたはあなたです。',
        links: [{ href: '/transition/', label: '性別移行を知る' }, { href: '/basics/', label: 'きほんのこと' }],
      },
      {
        myth: '精神科の診断を受けていないなら、ただの「自称」で、本当のトランスではない。',
        truth: '自分の性別をいちばんよく知っているのは、ほかの誰でもなく本人です。診断は「本物かどうかを審査する関門」ではなく、必要な医療やサポートにつながるための手続きのひとつです。日本でも、ホルモンや手術などの医療を考えるときには、専門の医師による診断や意見書が関わってきます。でも、こうした医療を望まない人もたくさんいて、それもまったく自然なことです。診断があってもなくても、あなたの気持ちが「自称」のひとことで片づけられることはありません。',
        cite: ['jspn-guideline', 'who-icd11'],
        links: [{ href: '/guidelines/', label: '学校・職場・自治体のSOGIガイドライン' }, { href: '/dysphoria/', label: '性別違和を知る' }],
      },
      {
        myth: '相談したら、子どもがすぐに手術やホルモンを受けさせられる。',
        truth: '実際には、名前や服装など社会的な移行から始めることが多く、未成年では「二次性徴をいったん止めて、考える時間をつくる」思春期ブロッカーという選択肢もあります。医療は、本人の年齢・希望・専門家との相談のうえで、慎重に段階を踏んで進めるものです。',
        links: [{ href: '/puberty-blockers/', label: '思春期ブロッカーとは' }, { href: '/transition/', label: '性別移行を知る' }],
      },
      {
        myth: '日本では未成年は何の支援も医療も受けられないのだから、大人になるまで何もできない。',
        truth: 'おとなになるまで何もできない、ということはありません。名前の呼び方や服装、トイレといった学校での配慮など、医療ではないサポートは、未成年のうちから受けられることがあります。文部科学省も、学校が一人ひとりに合わせて配慮するよう求めています。思春期ブロッカーなどの医療についても、年齢や本人の希望、家族や専門家との相談のうえで検討される選択肢があります（日本では限られた専門の医療機関にかぎられ、提供状況には制約があります）。まずは、相談できる場所を探すところから始められます。',
        cite: ['mext', 'jspn-guideline'],
        links: [{ href: '/school/', label: '学校でのこと' }, { href: '/puberty-blockers/', label: '思春期ブロッカーとは' }],
      },
      {
        myth: '思春期ブロッカーは体に取り返しのつかないダメージを残す実験的な薬で、使うと一生もとに戻らない。',
        truth: '思春期ブロッカー（GnRHアナログ）は、もともと子どもの病気の治療などで長く使われてきたお薬で、二次性徴を「いったん止める」ものです。やめれば本来の思春期が進むとされ、急いで決めなくていい時間をつくる選択肢と考えられています。専門の医療機関で、検査をしながら慎重に進めるもので、自己判断で使うものではありません。研究や制度は今も動いているので、断定的な情報には注意して、必ず専門の医師に確認してください。',
        cite: ['transfemscience-puberty-blockers-a', 'tandfonline-standards-of-care'],
        links: [{ href: '/puberty-blockers/', label: '思春期ブロッカーとは' }, { href: '/transition/', label: '性別移行を知る' }],
      },
      {
        myth: 'ホルモン療法をすると寿命が縮むし、いつか必ずがんになる。',
        truth: 'ホルモン療法（HRT）には注意すべき点もありますが、「必ずがんになる」「寿命が縮む」と決まっているわけではありません。だからこそ、専門の医師のもとで、血液検査などをしながら進めていくことが大切にされています。がん検診も、その人の体や状態に合わせて受けていきます。具体的な薬や量、検査の判断は、必ず医師に相談してください。自己判断での使用は危険です。',
        cite: ['academic-endocrine-treatment-of', 'tandfonline-standards-of-care'],
        links: [{ href: '/hrt-effects/', label: 'ホルモン療法で起きること' }, { href: '/hrt-medications/', label: 'ホルモン療法の薬とフラホル' }],
      },
      {
        myth: '手術を受ければ完全に「もう一方の性別」になれる。逆に、手術をしても所詮は作りもので、本物にはなれない。',
        truth: '性別適合手術は、その人が自分の体に少しでも安心して暮らせるようにするためのものです。「完全に別の性別の体に作り変える」ことを目指すものではありません。受けるか受けないか、どこまで望むかは、人によって違います。手術をしてもしなくても、その性別が「本物」かどうかが決まるわけではありません。あなたの性別は、手術の有無で証明するものではなく、はじめからあなたのものです。',
        cite: ['tandfonline-standards-of-care'],
        links: [{ href: '/surgery/', label: '移行のための手術' }, { href: '/transition/', label: '性別移行を知る' }],
      },
      {
        myth: '移行すれば心の悩みは全部消えるはず。それに、移行なんてしたら心の状態はもっと悪くなる。',
        truth: '移行は、つらさのすべてを一度に消す魔法ではありませんし、反対に、心の状態を悪くするものでもありません。自分に合った形で性別を肯定するケアを受けることは、不安やうつが軽くなることや、暮らしやすさが上がることと結びついていると、研究で報告されています。一方で、いじめや差別、孤立といった外からのつらさは、移行とは別に向き合っていく必要があります。困ったときは、一人で抱えこまず、相談できる場所を頼ってください。',
        cite: ['pmc-standards-of-care', 'familyproject-family-acceptance-of'],
        links: [{ href: '/transition/', label: '性別移行を知る' }, { href: '/support/', label: '相談先' }],
      },
      {
        myth: '移行しても、すぐに後悔してやめる人がほとんど。',
        truth: '移行を後悔する人や、移行をやめる（脱移行する）人はいますが、その割合は低いと報告されています。脱移行の理由も、性自認が変わったというより、周囲の偏見や家族・経済の事情など、外からの圧力によることが多いと示されています。揺れることも、立ち止まることも、おかしなことではありません。',
        cite: ['bustos-regret-after-gender', 'turban-factors-leading-to'],
        links: [{ href: '/detransition/', label: '気持ちが揺れたとき・脱移行のこと' }],
      },
    ],
  },
  {
    title: '日本の制度と手続きについての誤解',
    items: [
      {
        myth: '戸籍の性別を変えるには、必ず手術を受けないといけない。',
        truth: 'からだに関する要件は、いま大きく動いています。2023年に最高裁が、生殖機能をなくす手術を求める要件（生殖不能要件）を憲法違反と判断しました。さらに2024年には、もう一つの「外観」に関する要件についても、広島高裁が「手術が常に必要だと解釈するなら違憲の疑いが強い」とし、ホルモン療法などで近い外見になっていれば満たしうるとして、手術を受けていない当事者（男性から女性へ）の性別変更を認めました。ただし外観要件そのものは法律にまだ残っていて、最高裁の最終的な判断や法改正はこれからです。状況は変わりつつあるので、弁護士や当事者団体など専門のところで確かめてください。',
        cite: ['toben-5-10-25', 'hiroshima-2024-07-10', 'laws-15-111'],
        links: [{ href: '/legal-change/', label: '戸籍と名前の変更' }, { href: '/support/', label: '相談先' }],
      },
      {
        myth: '性同一性障害特例法は、もう無くなった（または全部変わった）。',
        truth: '特例法（性同一性障害者の性別の取扱いの特例に関する法律）は、いまもあります。2023年の最高裁判決で違憲とされたのは、いくつかある要件のうち「生殖不能要件」という一つで、法律そのものが無くなったわけではありません。また、2023年にできた「LGBT理解増進法」は、これとは別の法律です。罰則や新しい権利義務をともなうものではなく、国や自治体などに、理解を広げる取り組みを求める「理念法」です（内閣府も、この法律によって国民一人ひとりが新たに権利を得たり義務を負ったりするものではない、と説明しています）。条文の言葉づかいをめぐっては、当事者団体から懸念の声がある一方、歴史的な一歩だと評価する声もあります。名前が似ていて混同されやすいので、戸籍の手続きについては最新の一次情報で確かめると安心です。',
        cite: ['toben-5-10-25', 'laws-15-111', 'japaneselawtranslation', 'cao-rikaizoshin-qa'],
        links: [{ href: '/legal-change/', label: '戸籍と名前の変更' }, { href: '/faq/', label: 'よくある質問（FAQ）' }],
      },
      {
        myth: '結婚していたり、子どもがいたりすると、性別はもう絶対に変えられない。',
        truth: 'いまの特例法には、申立てのときに結婚していないこと（未婚要件）や、未成年の子がいないことなど、いくつかの要件があります。「子がいないこと」という要件は法改正で「未成年の子がいないこと」にゆるめられていて、いまは未成年の子がいなければ（子がみんな成人していれば）申立てができます。からだに関する要件のほうは近年の裁判で見直しが続いていて、当てはまるかどうかは一人ひとり事情がちがいます。まずあきらめず、弁護士や当事者団体に相談してみてください。',
        cite: ['laws-15-111', 'courts'],
        links: [{ href: '/legal-change/', label: '戸籍と名前の変更' }, { href: '/support/', label: '相談先' }],
      },
      {
        myth: '名前を変える（改名する）には、先に戸籍の性別を変えないといけない。',
        truth: '改名と、戸籍の性別変更は、別々の手続きです。戸籍の性別を変えていなくても、家庭裁判所に「名の変更許可」を申し立てて、名前だけを変えることはできます。許可には「正当な事由」が必要で、その名前を通称として長く使ってきた実績などが考慮されます。トランスの場合は、性別違和も理由として考慮されることがあります。どちらから進めるかは、自分の状況に合わせて選べます。手続きや要件は変わることがあるので、最新の情報は家庭裁判所や弁護士、当事者団体で確認してください。',
        cite: ['courts-2'],
        links: [{ href: '/legal-change/', label: '戸籍と名前の変更' }, { href: '/everyday/', label: 'トイレ・更衣室・身分証など' }],
      },
      {
        myth: '戸籍の性別を手術なしで変えられるようになったから、男性が「心は女性」と言えば、女湯や女子トイレに自由に入れるようになる。',
        truth: '戸籍（法律上）の性別を変える手続き（特例法）と、お風呂や銭湯の男女のわけ方は、別々のしくみです。公衆浴場や旅館のお風呂を男女に分ける基準は、もともと「からだ（身体的な特徴）」をもとにしたもので、厚生労働省も2023年に、自治体への事務連絡で、その扱いはこれまでと変わらないことを確認しています（新しい法律や禁止令ではなく、自治体への技術的な助言です）。だから「戸籍を変えれば、あるいは自己申告だけで、誰でも好きなお風呂に入れるようになる」というのは、実際のしくみとは違います。トイレなど性別で分かれた場所の使い方も、一人ひとりの状況や、施設ごとの配慮のなかで考えられていて、トランスの人がそうした場所を悪用するという心配に根拠がないことは、別の項目でふれたとおりです。',
        cite: ['mhlw-bath-2023', 'toben-5-10-25'],
        links: [{ href: '/everyday/', label: 'トイレ・更衣室・身分証など' }, { href: '/legal-change/', label: '戸籍と名前の変更' }],
      },
    ],
  },
  {
    title: '暮らしと、まわりの人についての誤解',
    items: [
      {
        myth: 'トランス女性がトイレや更衣室を悪用して、女性が危険にさらされる。',
        truth: 'トランスの人が性自認に沿ってトイレを使えるようにしても、トイレでの安全やプライバシーの問題が増えたという証拠はない、と複数の研究が示しています。むしろトランスの人のほうが、トイレで嫌がらせや暴力の被害に遭いやすい立場にあります。',
        cite: ['williamsinstitute-public-accommodations', 'williamsinstitute-ncvs-trans'],
        links: [{ href: '/everyday/', label: 'トイレ・更衣室・身分証など' }, { href: '/safety/', label: '安全とこころ' }],
      },
      {
        myth: 'トランス女性がスポーツに参加すると、女子競技を席巻してしまう。',
        truth: 'トップレベルの大会に出場する、性別を公表しているトランスの選手は、実際にはごくわずかです。たとえば東京2020オリンピックでは、約5,400〜5,500人いた女性選手のうち、女子種目に出場した公表トランス女性は、重量挙げのローレル・ハバード選手ただ一人でした（ほかに、ノンバイナリーのトランスの選手も出場しています）。エリート競技での出場資格は、公平性をどう考えるかをめぐって競技団体ごとに方針が分かれ、いまも議論が続いている領域です。一方で、学校や地域でからだを動かして楽しむ日常のスポーツは、それとはまた別の話です。トランスの子ども・若者がスポーツに参加できることは、こころと体の健康にとって大切だと考えられています。',
        cite: ['ioc-tokyo2020-balance', 'ioc-gender-framework'],
        links: [{ href: '/safety/', label: '安全とこころ' }, { href: '/basics/', label: 'きほんのこと' }],
      },
      {
        myth: 'トランスやLGBTQの人は、子どもにとって危険な存在だ。',
        truth: 'トランスであることやLGBTQであることは、誰かを子どもにとって危険にする理由にはなりません。アメリカ心理学会も、ゲイやレズビアンの親をもつ子どもが、その親や親の知人から性的被害に遭いやすいという心配には、科学的な裏づけがないとしています。トランスの人が子どもにとって危険だという根拠もありません。むしろトランスの人のほうが、暴力や被害を受けやすい立場に置かれています。誰を大人として好きになるかや、自分の性別をどう感じるかは、子どもへの加害とは、まったく別のことです。',
        cite: ['apa-understanding-sexual-orientation', 'williamsinstitute-ncvs-trans'],
        links: [{ href: '/basics/', label: 'きほんのこと' }, { href: '/orientation/', label: '性的指向と「好き」のいろいろ' }],
      },
      {
        myth: '呼ばれ方や名前にこだわるのは大げさだし、わがままだ。',
        truth: '名前や呼ばれ方は、その人が尊重されているかどうかに直結する、大切なことです。望む名前で呼ばれている若者ほど、うつの症状や自殺を考えることが少ない、という研究もあります。相手の望む呼び方をするのは、特別な気づかいではなく、あたりまえの礼儀のひとつです。',
        cite: ['pmc-chosen-name-use'],
        links: [{ href: '/everyday/', label: 'トイレ・更衣室・身分証など' }, { href: '/allies/', label: '周囲の人へ' }],
      },
      {
        myth: '通称名で呼んでもらうことや、性別への配慮は、法的な根拠のない我がままだ。',
        truth: '配慮を求めるのは、わがままではありません。学校での対応には、ちゃんとした土台があります。文部科学省は、性自認に悩む児童生徒へ「きめ細かな対応」をするよう全国の学校に通知していて、希望する呼称を校内の文書で使うことや、服装・トイレ・更衣などでの工夫を、具体的な例として挙げています。職場でも、性的指向や性自認に関するハラスメント（SOGIハラ）や、本人の同意のないアウティングを防ぐことが、国のパワハラ防止指針で事業主に求められています。配慮は、あなたが安心して過ごすための土台です。遠慮なく、頼っていいものです。',
        cite: ['mext', 'no-harassment-sogi'],
        links: [{ href: '/school/', label: '学校でのこと' }, { href: '/guidelines/', label: '学校・職場・自治体のSOGIガイドライン' }],
      },
      {
        myth: '打ち明けられたら、心配だから、まわりの人にも教えてあげたほうがいい。',
        truth: '本人の同意なく、その人のことを他の人に伝えること（アウティング）は避けてください。誰にいつ伝えるかは、本人が決めることです。よかれと思った行動が、信頼関係を壊し、本人を危険にさらすことがあります。',
        cite: ['tokyo-jinken'],
        links: [{ href: '/allies/', label: '周囲の人へ' }, { href: '/coming-out/', label: 'カミングアウト入門' }],
      },
      {
        myth: 'トランスであることを言わないのは、相手をだましている（うそをついている）ことだ。',
        truth: '自分の生い立ちや体のことは、とてもプライベートな情報です。それを誰に、いつ、どこまで話すかは、本人が決めてよいことで、言わないことは「うそ」ではありません。本人の同意なく性自認や過去を他人に伝えること（アウティング）は、プライバシーや人格権の侵害として問題になり得ます。あなたが自分のペースで話す（あるいは話さない）権利は、守られています。',
        cite: ['tokyo-jinken'],
        links: [{ href: '/coming-out/', label: 'カミングアウト入門' }, { href: '/safety/', label: '安全とこころ' }],
      },
      {
        myth: '見た目で「男か女か」はわかるはず。「らしく」見えないとおかしい。',
        truth: '見た目や声で、その人の性別が決まるわけではありません。「それらしく見える」かどうかは、その人らしさの本質ではありません。どんな見た目でも、その人の性別は、その人のものです。',
        links: [{ href: '/presentation/', label: '見た目と、毎日のこと' }, { href: '/gender/', label: '性別は、男女だけじゃない' }],
      },
      {
        myth: '日本は理解があるほうだから、トランスの人が医療や福祉でそんなに困ることはない。',
        truth: '実際には、医療や福祉の場面で困りごとを経験する人は、少なくありません。認定NPO法人ReBitの「LGBTQ医療福祉調査2023」（インターネット調査・有効回答961名）では、医療サービスを利用したトランスジェンダーの男性・女性のうち、77.8%（約8割）がセクシュアリティに関連した困りごとを経験し、その影響で42.0%（約4割）が体調が悪くても病院に行けなくなり、25.9%（約4人に1人）が自殺を考えた・自殺未遂をしたと答えています。これは母集団全体を代表する数字ではありませんが、安心して医療や相談につながれることの大切さを示しています。一人で抱えこまず、否定せずに受けとめてくれる窓口を頼ってください。',
        cite: ['rebit-medical-welfare-2023'],
        links: [{ href: '/support/', label: '相談先' }, { href: '/safety/', label: '安全とこころ' }],
      },
    ],
  },
  {
    title: '若者と、これからのことについての誤解',
    items: [
      {
        myth: '子どもや若者に、自分の性別なんてわかるはずがない。大人になればきっと変わる。',
        truth: '自分の性別についての感覚は、小さいころから少しずつ育っていくもので、若いから分からない、とは言いきれません。子どものうちに社会的な移行をした317人を平均5年後まで追ったある研究では、94%が引き続き男の子・女の子として、トランスのまま過ごしていました。もちろん、時間とともに感じ方が変わる人もいますし、それもふつうのことです。大切なのは、頭から否定せず、本人の言葉にゆっくり耳をかたむけることです。',
        cite: ['olson-gender-identity-5-years'],
        links: [{ href: '/parents/', label: '保護者の方へ' }, { href: '/gender/', label: '性別は、男女だけじゃない' }],
      },
      {
        myth: '子どもに社会的な性別移行をさせるのは危険で、いちど始めたら取り返しがつかない。',
        truth: '社会的な移行とは、呼び名・服装・髪型などを変えることで、薬や手術はいっさい使いません。だから、合わなければ戻すこともできる、もともと可逆的なステップです。むしろ、本人の気持ちが受けとめられることは、こころの健康を守ると示されています。急ぐ必要も、無理に止める必要もなく、本人のペースで確かめていけます。',
        cite: ['pmc-standards-of-care', 'familyproject-family-acceptance-of'],
        links: [{ href: '/transition/', label: '性別移行を知る' }, { href: '/parents/', label: '保護者の方へ' }, { href: '/detransition/', label: '気持ちが揺れたとき・脱移行のこと' }],
      },
    ],
  },
];

const mythLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: mythGroups.flatMap((g) =>
    g.items.map((item) => ({
      '@type': 'Question',
      name: `「${item.myth}」というのは本当？`,
      acceptedAnswer: { '@type': 'Answer', text: item.truth },
    })),
  ),
};
---

<BaseLayout
  title="よくある誤解 - とらんすナビ"
  description="トランスジェンダーをめぐって、よく見聞きする誤解と、その隣にあるやさしい事実。病気なの？　流行なの？　すぐ後悔する？　トイレは危ない？　日本の制度は？　出典つきで、ひとつずつ、おだやかに。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>よくある誤解</h1>
    <p class="lead">
      トランスジェンダーをめぐっては、いろいろな言葉が飛びかっています。なかには、事実とずれたまま広がっているものもあります。ここでは、よく見聞きする誤解と、その隣にある事実を、テーマごとにひとつずつ並べてみました。誰かを言い負かすためではなく、安心して読むための材料として。事実には、確かめられる出典をつけています。
    </p>

    {mythGroups.map((group) => (
      <section class="article-section" aria-label={group.title}>
        <h2>{group.title}</h2>
        {group.items.map((item) => (
          <div class="myth-item">
            <p class="myth-claim"><span class="myth-tag myth-tag-no">誤解</span>「{item.myth}」</p>
            <p class="myth-truth">
              <span class="myth-tag myth-tag-yes">ほんとうは</span>{item.truth}{item.cite && <Cite src={item.cite} />}
            </p>
            <nav class="word-chips" aria-label="くわしく読む">
              {item.links.map((link) => (
                <a class="word-chip" href={link.href}>{link.label}</a>
              ))}
            </nav>
          </div>
        ))}
      </section>
    ))}

    <aside class="entry-message" role="note" aria-label="読んでいるあなたへ">
      <p>誤解にぶつかると、心が削られます。でも、あなたが誰かに証明しなければならないことは、何ひとつありません。</p>
    </aside>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/faq/">よくある質問（FAQ）</a>
      <a class="word-chip" href="/basics/">きほんのこと</a>
      <a class="word-chip" href="/parents/">保護者の方へ</a>
      <a class="word-chip" href="/allies/">周囲の人へ</a>
      <a class="word-chip" href="/glossary/">用語集</a>
      <a class="word-chip" href="/learn/">知る・学ぶ</a>
    </nav>
    <References route="/myths/" />
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(mythLd)} />
</BaseLayout>

<style>
  /* 誤解 → ほんとうは のペア。誤解は控えめに、事実をはっきり見せる。 */
  .myth-item {
    padding: 18px 0;
    border-top: 1px solid var(--line);
  }
  .myth-item:first-of-type {
    border-top: none;
  }
  .myth-claim {
    margin: 0 0 8px;
    color: var(--ink);
    opacity: 0.72;
  }
  .myth-truth {
    margin: 0 0 10px;
    color: var(--ink-heading);
  }
  .myth-tag {
    display: inline-block;
    margin-right: 8px;
    padding: 1px 9px;
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 700;
    white-space: nowrap;
    vertical-align: 0.1em;
  }
  .myth-tag-no {
    background: rgba(63, 74, 98, 0.08);
    color: var(--ink);
  }
  .myth-tag-yes {
    background: var(--accent-soft);
    color: var(--ink-heading);
    border: 1px solid var(--line);
  }
</style>
