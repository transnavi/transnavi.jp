---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cite from '../components/Cite.astro';
import References from '../components/References.astro';
import Mascot from '../components/Mascot.astro';

const tellingTips = [
  'ぜんぶを一度に伝えなくて大丈夫。少しずつでいいんです。',
  '相手が安心できる人かどうかを思い浮かべて、伝えるタイミングや場所を選んで大丈夫です。',
  '「うまく説明できる言葉」が見つからなくても、あなたの気持ちは本物です。',
  '反応がこわいときは、信頼できる第三者や相談窓口に先に話しておくのも一つです。',
];

const listenTips = [
  'まず、否定せずに聞いてください。打ち明けるには勇気が要ります。',
  '本人の許可なく、他の人に伝えないでください（アウティングは避けてください）。',
  '「気のせい」「まだ若いから」などと、気持ちを小さく扱わないでください。',
  '答えやアドバイスを急がず、「話してくれてありがとう」と受けとめてください。',
  '呼んでほしい名前や代名詞があれば、本人に確認して尊重してください。',
];
---

<BaseLayout
  title="周囲の人へ - とらんすナビ"
  description="家族・学校・友人に伝えるとき、そして身近な人から打ち明けられたとき。"
>
  <article class="article-shell prose">
    <div class="eyebrow">周囲の人へ</div>
    <Mascot name="calm" />
    <h1>周囲の人へ</h1>
    <p class="lead">自分のことを伝えたいとき。そして、身近な人から打ち明けられたとき。</p>

    <h2>家族・学校・友人に伝えたいとき</h2>
    <p>自分のことを伝えるかどうか、誰に・いつ伝えるかは、あなたが選んでいいことです。伝えることは義務ではありません。</p>
    <ul class="assure-list">
      {tellingTips.map((tip) => <li>{tip}</li>)}
    </ul>

    <h2>身近な人から打ち明けられたら</h2>
    <p><Cite src={['familyproject-family-acceptance-of', 'whatweknow-what-does-the', 'thetrevorproject-accepting-adults-reduce']}>大切な人から打ち明けられたとき、あなたの最初のひと言は、その人がほっとできるかどうかを大きく左右します</Cite>。</p>
    <ul class="assure-list">
      {listenTips.map((tip) => <li>{tip}</li>)}
    </ul>
    <p>
      <Cite src="pmc-chosen-name-use">呼んでほしい名前で呼ばれることは、その人のこころの健康を守り、つらさを減らすことにつながると報告されています</Cite>。また、<Cite src="tokyo-jinken">打ち明けられたことを、本人の許可なく他の人へ伝える（アウティング）のは避けてください</Cite>。
    </p>

    <h2>学校や職場で、できること</h2>
    <p>学校・大学・職場・自治体には、性的指向や性自認（<a href="/glossary/sogi/">SOGI</a>）への対応をまとめた公式のガイドラインを公表しているところが増えています。<Cite src={['mext', 'apa-2020-resolution-on']}>名前や呼称、トイレ・更衣室、健康診断、就職活動などでの配慮の、よりどころになります</Cite>。<a href="/guidelines/">学校・職場・自治体のSOGIガイドライン</a>に、国・大学・自治体・企業などの例を集めました。自分の通う学校や働く場の方針を調べたり、まだないときに「こういう例があります」と伝えたりするのに使えます。</p>

    <aside class="entry-message" role="note" aria-label="読んでいるあなたへ">
      <p>「ありのままでいいよ」と言える人が一人いるだけで、その人の世界はずいぶん生きやすくなります。</p>
    </aside>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/coming-out/">カミングアウト入門</a>
      <a class="word-chip" href="/guidelines/">SOGIガイドライン</a>
      <a class="word-chip" href="/support/">相談先</a>
      <a class="word-chip" href="/glossary/">用語集</a>
      <a class="word-chip" href="/resources/">関連サイト</a>
    </nav>
    <References route="/allies/" />
  </article>
</BaseLayout>
