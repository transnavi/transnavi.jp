---
import BaseLayout from '../layouts/BaseLayout.astro';

// Accurate, gentle overview timeline of transgender history (world + Japan).
// Dates verified against mainstream sources; the 2023 rulings especially.
const world = [
  { year: '古くから', event: '世界中の多くの文化に、男女の枠におさまらない性のあり方を生きた人々がいました。北米先住民の「トゥースピリット」、南アジアの「ヒジュラ」、インドネシア・ブギスの社会に伝わる複数の性のあり方など。トランスジェンダーは、けっして新しい存在ではありません。' },
  { year: '紀元前3世紀ごろ', event: '古代ローマでは、女神キュベレーに仕える「ガリ」と呼ばれる人々が、女性の装いで生きていたと伝えられます。性別の境界をこえる生き方は、古代の各地に記録されています。' },
  { year: '1777年', event: 'フランスの外交官シュヴァリエ・デオンが、女性として生きることを公に認められます。当時のヨーロッパでも広く知られた人物でした。' },
  { year: '1886年', event: '北米先住民ズニの「ラマナ」だったウェウハが、ワシントンを訪れ、半年ほど滞在しました。トゥースピリットの存在を、当時の社会に印象づけた人です。' },
  { year: '1910年', event: 'ドイツの医師マグヌス・ヒルシュフェルトが著書のなかで、性別をこえて装い生きる人々について論じ、専門の言葉を使い始めます。' },
  { year: '1919年', event: 'ドイツ・ベルリンに、性のあり方を研究する「性科学研究所」が設立されます（マグヌス・ヒルシュフェルト）。先駆的な性別適合の医療も行われました。' },
  { year: '1930年代', event: '研究所などで初期の性別適合手術が行われます（ドラ・リヒターやリリー・エルベなど）。しかし1933年、ナチスによって研究所は破壊され、多くの資料が焼かれました。' },
  { year: '1946年', event: 'イギリスで、トランス男性のマイケル・ディロンが初期の陰茎形成術を受けます。トランス男性の歩みも、同じくらい古くから続いています。' },
  { year: '1952年', event: 'クリスティン・ジョーゲンセンの性別移行が大きく報道され、トランスジェンダーの存在が世界に広く知られるきっかけになりました。' },
  { year: '1966年', event: 'アメリカ・サンフランシスコの「コンプトンズ・カフェテリア」で、トランスの人々が差別的な扱いに立ち上がりました。ストーンウォールより前の、大切な抵抗の一つです。同じころ、医師ハリー・ベンジャミンの著書や大学の専門外来など、医療の動きも広がりました。' },
  { year: '1969年', event: 'アメリカ・ニューヨークの「ストーンウォール」で、性的マイノリティへの差別に抗議する出来事（ストーンウォールの反乱）。トランスの人々も大きな役割を果たし、いまのプライドの起源の一つになりました。' },
  { year: '1970年', event: 'マーシャ・P・ジョンソンとシルビア・リベラが、行き場のないトランスの若者を支える団体「STAR」を立ち上げます。当事者どうしの支え合いの、はやい例です。' },
  { year: '1977年', event: 'アメリカで、トランス女性のテニス選手レネイ・リチャーズが、女子大会への出場をめぐる裁判で勝訴します。スポーツと性別をめぐる、はやい時期の判断でした。' },
  { year: '1979年', event: 'トランスジェンダーの医療に関する国際的な専門家団体が設立され、ケアの指針（SOC）がつくられます（のちのWPATH）。' },
  { year: '1980年', event: 'アメリカ精神医学会の診断基準「DSM-III」に、はじめて関連する診断名が登場します。当時は性的逸脱と同じ枠に置かれるなど、いまとは大きく見方が異なりました。' },
  { year: '1999年', event: '「トランスジェンダー追悼の日（TDOR）」が始まります。差別や暴力で亡くなった人たちを、毎年11月20日に世界各地で追悼します。' },
  { year: '2007年', event: '性的指向と性自認に関する人権の国際的な指針「ジョグジャカルタ原則」がまとめられます。同じ年、ネパールの最高裁が「第三の性」を法的に認めました。' },
  { year: '2012年', event: 'アルゼンチンが、本人の自己申告だけで法律上の性別を変えられる「ジェンダー・アイデンティティ法」を成立させます。手術や診断を求めない、世界の先がけとなる法律でした。' },
  { year: '2013年', event: 'DSM-5で「性同一性障害」が「性別違和（Gender Dysphoria）」へと改められます。アイデンティティそのものではなく、そこから生じる苦痛のほうに焦点を移す、大切な言い換えでした。' },
  { year: '2014年', event: 'インドの最高裁が、トランスジェンダーを「第三の性」として法的に認め、平等な権利を保障する判断（NALSA判決）を出しました。' },
  { year: '2015年', event: 'マルタが、性別の変更に手術や診断を求めず、インターセックスの子どもへの不要な手術も禁じる、先進的な法律を定めます。' },
  { year: '2018年', event: 'WHOが、ICD-11で「性別不合」を精神疾患の分類から外します（脱病理化）。「トランスであることは病気ではない」という国際的な合意です。同じ年、パキスタンもトランスジェンダーの権利を守る法律を定めました。' },
  { year: '2020年', event: 'アメリカの連邦最高裁が、トランスジェンダーであることを理由とした職場での解雇は違法だと判断しました（ボストック判決）。' },
  { year: '2024年', event: 'ドイツが、本人の意思で法律上の性別と名前を変えられる「自己決定法」を成立させます。世界の流れは、いまも動き続けています。' },
];
const japan = [
  { year: '1969年', event: 'いわゆる「ブルーボーイ事件」で、性別適合手術を行った医師が有罪とされます。これ以降、日本では長らく手術が表立って行われなくなりました。' },
  { year: '1997年', event: '日本精神神経学会が「性同一性障害に関する診断と治療のガイドライン」を策定します。' },
  { year: '1998年', event: '埼玉医科大学で、正式な医療として日本で初めての性別適合手術が行われます。' },
  { year: '2003年', event: '「性同一性障害者の性別の取扱いの特例に関する法律」（特例法）が成立（翌2004年施行）。家庭裁判所の審判で、戸籍上の性別を変更できるようになりました。' },
  { year: '2008年', event: '特例法が改正され、「子がいないこと」の要件が「未成年の子がいないこと」へ緩和されます。' },
  { year: '2015年', event: '東京都の渋谷区・世田谷区が、同性カップルを公的に認める「パートナーシップ制度」を始めます。やがて全国の多くの自治体へ広がっていきます。' },
  { year: '2018年', event: '一定の条件のもとで、性別適合手術が公的医療保険の対象になりました。' },
  { year: '2019年', event: '最高裁が、当時の特例法の手術要件を「憲法に違反しない」と判断します。ただし補足意見で、要件を見直していく必要にふれました。のちの違憲判断につながる一歩でした。' },
  { year: '2023年6月', event: '「LGBT理解増進法」が成立します。国に、SOGIへの理解を広げるための「基本計画」づくりを求めるものです。' },
  { year: '2023年7月', event: '最高裁が、経済産業省のトランス女性職員の女性トイレ使用を制限した対応を違法と判断しました。' },
  { year: '2023年10月', event: '最高裁（大法廷）が、戸籍の性別変更に生殖機能をなくす手術を求める特例法の要件を「違憲」と判断しました。大きな転換点です。' },
  { year: '2024年7月', event: '広島高裁が、もう一つの「外観」に関する要件についても「違憲の疑いがある」とし、手術を受けていない人の戸籍上の性別変更を認めました。流れはさらに動いています。' },
];
---

<BaseLayout
  title="トランスジェンダーの歴史（年表） - とらんすナビ"
  description="トランスジェンダーの歴史を、世界と日本の年表でやさしくたどります。ブルーボーイ事件、特例法（2003年）、DSM・ICDの脱病理化、2023〜2024年の最高裁・高裁の違憲判断まで。あなたは、長い歴史の続きにいます。"
>
  <article class="article-shell prose">
    <div class="eyebrow">知る</div>
    <h1>トランスジェンダーの歴史</h1>
    <p class="lead">
      トランスジェンダーの人は、どの時代にも、どの地域にも生きてきました。あなたは、ひとりで生まれた特別な「例外」ではなく、長い歴史の続きにいます。ここでは、世界と日本の歩みを、ざっくりとした年表でたどります。
    </p>

    <div class="page-disclaimer">
      これは大きな流れをつかむための、ごく一部の出来事です。年表にのらない無数の人たちの暮らしや、声をあげた人たちの積み重ねの上に、今があります。
    </div>

    <section aria-labelledby="world">
      <h2 id="world">世界の歩み</h2>
      <ol class="timeline">
        {world.map((item) => (
          <li>
            <span class="timeline-year">{item.year}</span>
            <p class="timeline-event">{item.event}</p>
          </li>
        ))}
      </ol>
    </section>

    <section aria-labelledby="japan">
      <h2 id="japan">日本の歩み</h2>
      <ol class="timeline">
        {japan.map((item) => (
          <li>
            <span class="timeline-year">{item.year}</span>
            <p class="timeline-event">{item.event}</p>
          </li>
        ))}
      </ol>
    </section>

    <section aria-labelledby="meaning">
      <h2 id="meaning">歴史を知ることの意味</h2>
      <p>
        歴史には、前に進んだ出来事も、つらい差別や弾圧の出来事もあります。まっすぐに良くなってきた、という単純な話ではありません。それでも、いつの時代にも自分らしく生きようとした人たちがいて、その積み重ねが、いまのあなたの選択肢につながっています。
      </p>
      <p>
        制度はこれからも変わっていきます。最新の状況は<a href="/legal-change/">戸籍と名前の変更</a>や<a href="/transition/">性別移行を知る</a>で確認してください。言葉の意味は<a href="/glossary/">用語集</a>へ。
      </p>
    </section>

    <p class="source-note">
      参考：各言語版ウィキペディアの「トランスジェンダーの歴史」関連項目、
      {' '}アセクシュアル・アロマンティックを中心に歴史をまとめた
      {' '}<a href="https://acearobu.com/history/" target="_blank" rel="noreferrer">acearobu「歴史」</a>、
      {' '}<a href="https://www.hrw.org/ja/news/2023/10/26/victory-transgender-rights-japan" target="_blank" rel="noreferrer">Human Rights Watch</a> や
      {' '}<a href="https://www.amnesty.or.jp/news/2023/1026_10093.html" target="_blank" rel="noreferrer">アムネスティ</a>（2023年の最高裁判断）など。年表は大きな流れの紹介です。世界各地の出来事には、解釈や年代に幅のあるものもふくまれます。
    </p>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/legal-change/">戸籍と名前の変更</a>
      <a class="word-chip" href="/transition/">性別移行を知る</a>
      <a class="word-chip" href="/pride/">プライドの記念日・イベント</a>
      <a class="word-chip" href="/learn/">知る・学ぶ</a>
    </nav>
  </article>
</BaseLayout>
