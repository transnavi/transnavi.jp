---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cite from '../components/Cite.astro';
import References from '../components/References.astro';

const hrtOverview = '/library/mtf-wiki-ja/docs/medicine/hrt-overview/';

const estrogen = [
  '乳房がふくらみはじめる（3〜6か月ごろから／安定まで2〜3年が目安）',
  '体脂肪が女性的な位置に移り、体つきが丸みを帯びる',
  '肌がやわらかくなり、皮脂が減る',
  '体毛がやわらかく・薄くなる（ひげは消えにくい）',
  '筋肉量が落ちる',
  '勃起や性欲が変化する',
];
const testosterone = [
  '声が低くなる（数か月〜／戻りません）',
  'ひげや体毛が濃くなる',
  '体脂肪が男性的な位置に移る',
  '筋肉がつきやすくなる',
  '皮脂が増え、にきびが出やすくなる',
  '月経が止まる',
  '陰核が大きくなる',
  '人によっては頭髪が後退しやすくなる',
];
---

<BaseLayout
  title="ホルモン療法で起きること（第二の思春期） - とらんすナビ"
  description="ホルモン療法（HRT）で、からだはどう変わっていくのか。エストロゲン／テストステロン方向の変化の目安と、戻る変化・戻らない変化について。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>ホルモン療法で起きること</h1>
    <p class="page-disclaimer">
      情報提供のみを目的としたページです。効果や時間には大きな個人差があり、最新・正確とはかぎりません。具体的な薬や量、検査の判断は、必ず医師に相談してください。
    </p>
    <p class="lead">
      ホルモン療法（<a href="/glossary/gaht/">HRT</a>）は、望む性別の方向へ、もう一度「思春期」をやり直すように、からだを少しずつ変えていく治療です。
    </p>

    <section aria-labelledby="basics">
      <h2 id="basics">はじめに知っておきたいこと</h2>
      <ul class="assure-list">
        <li><strong>ホルモンは魔法ではありません。</strong>変化はゆっくりで、人によって大きく違います（くわしくは<a href="/library/transcircle/hrt-individual-differences/">効き方の個人差と血液検査のこと</a>へ）。</li>
        <li>気持ちの落ち着きが先に来て、見た目の変化はあとからのことも多いです。</li>
        <li>必ず医師のもとで、検査をしながら進めるものです。自己判断は危険です。</li>
      </ul>
    </section>

    <section aria-labelledby="estro">
      <h2 id="estro">エストロゲン（女性化）の方向</h2>
      <p><Cite src={['transcare-overview-of-feminizing', 'transfemscience-an-introduction-to', 'academic-endocrine-treatment-of']}><a href="/glossary/estrogen/">エストロゲンと</a>、必要に応じて<a href="/glossary/antiandrogen/">抗アンドロゲン薬</a>を使います</Cite>。おもな変化の目安です。</p>
      <ul class="assure-list assure-list-plain">
        {estrogen.map((e) => <li>{e}</li>)}
      </ul>
      <p><strong>戻る変化・戻らない変化：</strong><Cite src={['tandfonline-standards-of-care', 'transcare-overview-of-feminizing', 'academic-endocrine-treatment-of']}>多くは中止すると戻りますが、ふくらんだ乳房や、生殖機能への影響は、戻らないことがあります</Cite>。</p>
    </section>

    <section aria-labelledby="testo">
      <h2 id="testo">テストステロン（男性化）の方向</h2>
      <p><a href="/glossary/testosterone/">テストステロンを使います</a>。おもな変化の目安です。</p>
      <ul class="assure-list assure-list-plain">
        {testosterone.map((t) => <li>{t}</li>)}
      </ul>
      <p><strong>戻る変化・戻らない変化：</strong><Cite src={['tandfonline-standards-of-care', 'academic-endocrine-treatment-of']}>声・体毛・陰核の変化などは、基本的に戻りません</Cite>。</p>
      <p><strong>大切な注意：</strong>月経が止まっても、それは避妊ではありません。<Cite src={['pmc-one-third-of', 'academic-endocrine-treatment-of']}>月経がなくても妊娠することがあります</Cite>。</p>
    </section>

    <section aria-labelledby="nonbinary">
      <h2 id="nonbinary">ノンバイナリーの人の場合</h2>
      <p>ホルモン療法は、「完全に女性化する」か「完全に男性化する」かの二択ではありません。自分の望む見た目や感覚に合わせて、進め方を選べることがあります。</p>
      <ul class="assure-list">
        <li>少ない量で使って、変化をゆるやかにする。</li>
        <li><Cite src={['tandfonline-standards-of-care', 'academic-endocrine-treatment-of']}><a href="/puberty-blockers/">思春期ブロッカー</a>だけを使って、二次性徴の進みを抑える</Cite>。</li>
        <li>あるところまでで止める、途中で目標を見直す。</li>
      </ul>
      <p>「男性的でも女性的でもない」「その中間の」見た目を望む人もいます。どんな変化を、どこまで望むかは人それぞれです。自分の望みを医師に伝えれば、ペースを一緒に決めていけます。ただし少ない量でも体質によってはリスクがあるので、必ず検査を受けながら進めてください。</p>
    </section>

    <section aria-labelledby="before">
      <h2 id="before">始める前に考えること</h2>
      <p><Cite src={['tandfonline-standards-of-care', 'jspn-4-2', 'academic-endocrine-treatment-of']}>ホルモン療法は、妊孕性（子どもをもつ力）に影響することがあります</Cite>。希望があるかもしれない人は、始める前に<a href="/fertility/">妊孕性と「始める前」の選択</a>も読んでみてください。</p>
    </section>

    <section aria-labelledby="more">
      <h2 id="more">もっと詳しく</h2>
      <p>
        具体的な薬（エストラジオール、抗アンドロゲン、テストステロンなど）と、<a href="/glossary/diy-hrt/">自己投薬（フラホル）については</a><a href="/hrt-medications/">ホルモン療法の薬と、自己投薬（フラホル）について</a>でくわしく説明しています。検査やリスクの基礎は<a href={hrtOverview}>資料集</a>へ。受けられる<a href="/clinics/">医療機関</a>も探せます。量は必ず医師と血液検査をあわせて決めてください。
      </p>
    </section>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/hrt-medications/">薬と自己投薬（フラホル）</a>
      <a class="word-chip" href="/transition/">性別移行を知る</a>
      <a class="word-chip" href="/fertility/">妊孕性のこと</a>
      <a class="word-chip" href="/clinics/">医療機関</a>
    </nav>

    <p class="source-note">
      参考:
      {' '}<a href="https://transfemscience.org/" target="_blank" rel="noreferrer">Transfeminine Science</a>、
      {' '}<a href="https://mtf.wiki/ja/" target="_blank" rel="noreferrer">MtF.wiki</a>、
      {' '}<a href="https://ftm.wiki/" target="_blank" rel="noreferrer">FtM.wiki</a>
      など（海外の資料は日本の保険診療・処方の実態と異なる点に注意）。
    </p>
    <References route="/hrt-effects/" />
  </article>
</BaseLayout>
