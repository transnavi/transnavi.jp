---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cite from '../components/Cite.astro';
import References from '../components/References.astro';

const sides = [
  {
    name: '社会的な移行',
    body: '名前や呼ばれ方、代名詞、服装や髪型を、自分に合うものに変えていくこと。カミングアウトもここに含まれます。こうして日々を望む性別で実際に暮らしてみることを、実生活体験（RLE）と呼ぶこともあります（かつては手術前の必須条件とされましたが、今のガイドラインでは必須ではありません）。お金や医療がなくても始められる部分が多くあります。',
    links: [
      { href: '/presentation/', label: '見た目と、毎日のこと' },
      { href: '/coming-out/', label: 'カミングアウト入門' },
      { href: '/guidelines/', label: '学校・職場のSOGIガイドライン' },
      { href: '/glossary/rle/', label: '実生活体験（RLE）' },
      { href: '/allies/', label: '周囲の人へ' },
    ],
  },
  {
    name: '医療的な移行',
    body: 'ホルモン療法（HRT）や手術（SRSなど）は、医療的な移行の一部です。思春期の人には、二次性徴を一時的に抑える「思春期ブロッカー」という選択肢もあります。受けるかどうか、どこまで行うかは自分で選べます。医療的な移行をしないトランスの人もたくさんいます。',
    links: [
      { href: '/hrt-effects/', label: 'ホルモン療法で起きること' },
      { href: '/puberty-blockers/', label: '思春期ブロッカー' },
      { href: '/surgery/', label: '移行のための手術' },
      { href: '/clinics/', label: '医療機関を探す' },
    ],
  },
  {
    name: '法的な移行',
    body: '改名（家庭裁判所での手続き）や、戸籍の性別の変更など。日本では一定の要件があり、変わりつつあります。',
    links: [
      { href: '/legal-change/', label: '戸籍と名前の変更' },
    ],
  },
];
---

<BaseLayout
  title="性別移行を知る - とらんすナビ"
  description="性別移行（トランジション）とは何か。社会的・医療的・法的な側面と、自分のペースを大切にしながら、思春期ブロッカーなど時間が関わることは早めに知っておく、という考え方。"
>
  <article class="article-shell">
    <div class="eyebrow">知る</div>
    <h1>性別移行を知る</h1>
    <p class="lead">
      <a href="/dysphoria/">性別違和</a>を和らげ、自分らしく暮らしていくための方法のひとつが、<a href="/glossary/gender-transition/">性別移行</a>（トランジション）です。何を、どこまで行うかは、人によって本当にさまざまです。
    </p>

    <section aria-labelledby="no-right-way">
      <h2 id="no-right-way">移行に「正解」はありません</h2>
      <p>
        すべてを行う必要も、決まった順番もありません。<strong>医療的な移行をしてもしなくても、あなたはあなたです。</strong>「ここまでやらないと本物ではない」ということはありません。
      </p>
      <p>
        大切なのは、自分が少しでも生きやすくなること。そして、<strong>安全であること</strong>です。
      </p>
    </section>

    <section aria-labelledby="sides-heading">
      <h2 id="sides-heading">移行には、いくつかの側面がある</h2>
      <p class="resource-section-intro">どれか一つだけでも、組み合わせても、まったく行わなくてもかまいません。</p>
      <div class="concept-grid">
        {sides.map((side) => (
          <div class="concept-card">
            <h3>{side.name}</h3>
            <p>{side.body}</p>
            <div class="concept-card-links">
              {side.links.map((link) => (
                <a class="concept-more" href={link.href}>{link.label} →</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section aria-labelledby="routes">
      <h2 id="routes">医療を始めるときの、二つの道すじ</h2>
      <p>
        ホルモン療法や手術といった医療的な移行を受けるとき、日本には大きく分けて<strong>二つの道すじ</strong>があります。どちらが正しいということはなく、かかる時間・費用・保険の扱いがちがいます。急いで選ばなくて大丈夫です。
      </p>
      <div class="concept-grid">
        <div class="concept-card">
          <h3>ガイドラインに沿う道</h3>
          <p><Cite src="jspn-4">日本GI（性別不合）学会のガイドラインに沿って、複数の精神科医による診断などの段階を踏む方法です</Cite>。時間と手続きはかかりますが、一定の条件で<strong><a href="/glossary/gas/">性別適合手術</a>が保険適用</strong>になります。大学病院などが中心です。</p>
        </div>
        <div class="concept-card">
          <h3>自由診療（インフォームド・コンセント型）の道</h3>
          <p>リスクの説明と本人の同意をもとに進める方法で、多くの民間クリニックが採用しています。<a href="/glossary/diagnosis-certificate/">診断書</a>なしで<strong>早くホルモン療法を始められる</strong>ことが多い一方、費用は全額自費です。</p>
        </div>
      </div>
      <p class="callout">
        保険について、知っておきたい大事な点があります。手術を保険で受けるには、原則として「学会の認定施設で」「それまでホルモン療法を受けていない」ことが条件です。けれど、手術の前にホルモン療法を受ける人がほとんどで、そのホルモン療法は保険の対象外。日本では保険診療と自費診療を混ぜること（混合診療）が認められていないため、<strong>今の制度では、性別適合手術に保険を使えるのは事実上ごく一部にかぎられ、実際に保険で行われた手術はわずか</strong>です。この点については、当事者団体などが制度の改善を求めて声を上げており、これから変わっていく可能性があります。最新の状況を確認してください。順番やタイミングで費用が大きく変わるので、早い段階で、これからのことを医師とよく相談しておくと安心です。
      </p>
      <p>
        どちらの道を選ぶかは、保険が使えるか・始めるまでの時間・将来の手術費用などを、自分の状況に合わせて考えることになります。<a href="/clinics/">医療機関</a>や、相談できる専門医に確認してください。手術を受ける施設については<a href="/surgery/">移行のための手術</a>を、費用の全体像は<a href="/cost/">お金のこと・費用の全体像</a>もどうぞ。
      </p>
    </section>

    <section aria-labelledby="young">
      <h2 id="young">若い人・10代の場合</h2>
      <p>
        まだ思春期を迎えていない人や、その途中にいる人にとっては、選べることが少し違って見えます。あわてて何かを決める必要はありません。ただし、<strong>時間が関わること</strong>もあります。とくに思春期ブロッカーには使える時期があり、二次性徴が進むと、声や骨格など元に戻せない変化が起きていきます。だから、決めるのは急がなくても、<strong>知っておくこと・専門の窓口に早めに相談すること</strong>が大切な場面もあります。
      </p>
      <ul class="assure-list">
        <li><strong>社会的な移行から始めることが多い。</strong>名前や呼ばれ方、服装などは、医療なしでも試せます。合わなければ戻すこともできます。</li>
        <li><strong>思春期ブロッカーという「いったん止める」選択肢。</strong><Cite src={['tandfonline-standards-of-care', 'academic-endocrine-treatment-of']}>二次性徴を一時的に抑えて、考える時間をつくるための薬です</Cite>。すぐにホルモン療法や手術へ進むという意味ではありません。<a href="/puberty-blockers/">思春期ブロッカー</a>でくわしく説明しています。</li>
        <li><strong>ホルモン療法や手術には、年齢や同意などの条件がある。</strong>日本では未成年の医療には保護者の関わりが必要なことが多く、扱える医療機関も限られます。児童・思春期の性別の悩みに対応している窓口に相談するのが近道です。</li>
        <li><strong>信頼できる大人がいると心強い。</strong>家族でも、学校の先生やスクールカウンセラー、相談機関でもかまいません。ひとりで抱え込まなくて大丈夫です。</li>
      </ul>
      <p>
        まだ自分でもよくわからない、という状態のままで大丈夫です。<a href="/detransition/">気持ちは時間とともに変わることもあります</a>し、迷いながら進んでいいのです。つらいときは<a href="/support/">相談先</a>を頼ってください。
      </p>
    </section>

    <section aria-labelledby="legal-note">
      <h2 id="legal-note">日本の制度について</h2>
      <p>
        <Cite src="laws-15-111">日本では、戸籍上の性別を変えるための要件が「性同一性障害者の性別の取扱いの特例に関する法律」で定められています</Cite>。2023年には、要件のうち生殖機能をなくす手術を求める規定について、最高裁判所が憲法違反と判断しました。さらに2024年には、もう一つの「外観」に関する要件についても、手術を受けていない人の性別変更を認めた高裁の判断が出ています。くわしい流れは<a href="/legal-change/">戸籍と名前の変更</a>にまとめています。
      </p>
      <p>
        改名や戸籍の性別変更などの<Cite src={['courts', 'courts-2']}>手続きの実際</Cite>や費用、最新の状況は変わることがあります。<a href="/clinics/">医療機関</a>や公的な窓口、<a href="/resources/">関連サイト</a>で確認してください。
      </p>
    </section>

    <section aria-labelledby="foreigners">
      <h2 id="foreigners">日本で暮らす外国籍の人へ</h2>
      <p>
        日本に住む外国籍の人も、医療やサポートを利用できます。知っておくとよい点をいくつかまとめます。
      </p>
      <ul class="assure-list">
        <li><strong>健康保険</strong>：日本の公的医療保険（国民健康保険・社会保険など）に加入していれば、保険の扱いは基本的に国籍にかかわらず同じです。保険が使える手術なども、認定施設・要件を満たせば同様に対象になります。</li>
        <li><strong>言葉のこと</strong>：日本語に不安があるときは、英語などに対応する医療機関や、通訳・同行の支援を探せます。英語で相談できる窓口もあります（<a href="/resources/">関連サイト</a>に情報があります）。</li>
        <li><strong>法的な性別の変更</strong>：日本の「戸籍」は日本国籍の人の制度です。外国籍の人が法的な性別を変えるには、<strong>本国（出身国）の制度</strong>が関わり、日本では住民票の扱いなどが関係します。手続きは国によって大きく異なるため、本国の大使館・領事館や、くわしい専門家に確認してください。</li>
        <li><strong>在留資格のこと</strong>：治療や名前の変更が在留資格に影響しないか不安なときは、行政書士などの専門家に相談すると安心です。</li>
      </ul>
    </section>

    <aside class="entry-message" role="note" aria-label="読んでいるあなたへ">
      <p>あせらなくて大丈夫。今すぐすべてを決めなくてもかまいません。ただ、思春期ブロッカーや<a href="/fertility/">妊孕性</a>のように、時間が関わることもあります。だから、<strong>知るのは早めに、決めるのはあなたのペースで</strong>。</p>
    </aside>

    <nav class="word-chips entry-related" aria-label="関連ページ">
      <a class="word-chip" href="/dysphoria/">性別違和を知る</a>
      <a class="word-chip" href="/detransition/">気持ちが揺れたとき・脱移行のこと</a>
      <a class="word-chip" href="/support/">相談先</a>
      <a class="word-chip" href="/clinics/">医療機関</a>
      <a class="word-chip" href="/glossary/">用語集</a>
    </nav>

    <p class="source-note">
      医療的な情報は
      {' '}<a href="https://transfemscience.org/" target="_blank" rel="noreferrer">Transfeminine Science</a>
      や
      {' '}<a href="https://mtf.wiki/ja/" target="_blank" rel="noreferrer">MtF.wiki</a>
      なども参考になります（海外の情報は日本の制度・医療と異なる点に注意）。最終的な判断は専門職や公的窓口とあわせて確認してください。
    </p>
    <References route="/transition/" />
  </article>
</BaseLayout>
