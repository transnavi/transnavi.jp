---
import '../styles/global.css';
import pageDates from '../data/page-dates.json';

interface Props {
  title?: string;
  description?: string;
}

const siteName = 'とらんすナビ';
const subtitle = '日本のトランスジェンダー情報ウィキ';
const {
  title = `${siteName} - ${subtitle}`,
  description = 'トランスジェンダー、ノンバイナリー、Xジェンダー、ジェンダーを探索中の人のための医療・制度・生活・地域情報。',
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL('/og-image.png', Astro.site).toString();
const siteUrl = Astro.site?.toString() ?? 'https://transnavi.jp/';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: siteName,
      description: 'トランスジェンダー、ノンバイナリー、Xジェンダー、ジェンダーを探索中の人のための情報サイト。',
      inLanguage: 'ja',
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#organization`,
      name: siteName,
      url: siteUrl,
      logo: new URL('/favicon.svg', Astro.site).toString(),
      sameAs: ['https://github.com/transnavi/transnavi.jp', 'https://discord.gg/S8NJGeS3Da'],
    },
  ],
};

// Breadcrumbs (auto-derived from the path; no per-page props needed).
const pathname = Astro.url.pathname;
const pageDate = (pageDates as Record<string, { created: string; updated: string }>)[pathname];
const pageName = title.split(' - ')[0].trim();
const learnPages = new Set([
  '/basics/', '/gender/', '/orientation/', '/intersex/', '/dysphoria/', '/transition/', '/hrt-effects/', '/hrt-medications/', '/fertility/',
  '/voice/', '/presentation/', '/hair-removal/', '/surgery/', '/cost/', '/legal-change/', '/coming-out/',
  '/everyday/', '/safety/', '/puberty-blockers/', '/detransition/', '/flags/', '/pride/', '/works/', '/bibliography/',
]);
let section: { label: string; href: string } | null = null;
if (learnPages.has(pathname)) section = { label: '知る・学ぶ', href: '/learn/' };
else if (pathname.startsWith('/glossary/') && pathname !== '/glossary/') section = { label: '用語集', href: '/glossary/' };
else if (pathname.startsWith('/clinics/') && pathname !== '/clinics/') section = { label: '医療機関', href: '/clinics/' };
else if (pathname.startsWith('/library/') && pathname !== '/library/') section = { label: '資料集', href: '/library/' };
const breadcrumbTrail = [{ label: 'ホーム', href: '/' }, ...(section ? [section] : [])];
const showBreadcrumb = pathname !== '/';
const breadcrumbLd = showBreadcrumb
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [...breadcrumbTrail, { label: pageName, href: pathname }].map((item, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: item.label,
        item: new URL(item.href, Astro.site).toString(),
      })),
    }
  : null;

// Freshness for search engines: a WebPage with the git-derived dates.
const pageLd = pageDate
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: pageName,
      inLanguage: 'ja',
      isPartOf: { '@id': `${siteUrl}#website` },
      datePublished: pageDate.created,
      dateModified: pageDate.updated,
    }
  : null;
---

<!doctype html>
<html lang="ja" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      // Set the colour theme before paint (no flash): saved choice, else system.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffd6e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171826" media="(prefers-color-scheme: dark)" />
    <meta http-equiv="content-language" content="ja" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
    {pageLd && <script type="application/ld+json" set:html={JSON.stringify(pageLd)} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ja" href={canonicalUrl} />
    <link rel="alternate" hreflang="ja-JP" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">本文へスキップ</a>
    <aside id="event-banner" class="event-banner" hidden aria-label="記念日・イベントのお知らせ">
      <div class="event-banner-stripe" aria-hidden="true"></div>
      <div class="event-banner-inner">
        <span class="event-banner-emoji" aria-hidden="true"></span>
        <span class="event-banner-text"></span>
        <a class="event-banner-link" href="/pride/"></a>
        <button class="event-banner-close" type="button" aria-label="このお知らせを閉じる">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" /></svg>
        </button>
      </div>
    </aside>
    <script type="application/json" id="event-banner-data" set:html={JSON.stringify([
      // Recurring awareness days/months. Each window recurs every year; `lead`
      // is how many days before the start to begin showing ("very close").
      // First match (top to bottom) wins.
      { id: 'pride-month', sm: 6, sd: 1, em: 6, ed: 30, lead: 0, emoji: '🏳️‍🌈', text: '6月はプライド月間（Pride Month）です。', href: '/pride/', cta: '記念日・イベント' },
      { id: 'tdor-week', sm: 11, sd: 13, em: 11, ed: 20, lead: 2, emoji: '🏳️‍⚧️', text: 'トランスジェンダー認知週間です（11月20日は追悼の日・TDOR）。', href: '/pride/', cta: 'くわしく' },
      { id: 'tdov', sm: 3, sd: 31, em: 3, ed: 31, lead: 6, emoji: '🏳️‍⚧️', text: '3月31日は国際トランスジェンダー認知の日（TDOV）です。', href: '/pride/', cta: 'くわしく' },
      { id: 'coming-out-day', sm: 10, sd: 11, em: 10, ed: 11, lead: 3, emoji: '💬', text: '10月11日は国際カミングアウトデーです。', href: '/coming-out/', cta: 'カミングアウトについて' },
      { id: 'idahobit', sm: 5, sd: 17, em: 5, ed: 17, lead: 3, emoji: '🌈', text: '5月17日は IDAHOBIT（差別に反対する国際デー）です。', href: '/pride/', cta: 'くわしく' },
      { id: 'nonbinary-day', sm: 7, sd: 14, em: 7, ed: 14, lead: 2, emoji: '💛', text: '7月14日はノンバイナリーの日です。', href: '/flags/', cta: 'フラッグ' },
    ])} />
    <header class="site-header" id="top">
      <div class="header-top">
        <a class="brand" href="/" aria-label="とらんすナビ ホーム">
          <img class="brand-mark" src="/favicon.svg" alt="" width="44" height="44" />
          <span>
            <span class="brand-name">とらんすナビ</span>
            <span class="brand-subtitle">{subtitle}</span>
          </span>
        </a>
        <div class="header-tools">
          <form class="header-search" role="search" action="/search/" method="get">
            <input type="search" name="q" aria-label="サイト内を検索" placeholder="検索…" autocomplete="off" />
            <button type="submit" aria-label="検索する">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
            </button>
          </form>
          <button class="theme-toggle" type="button" aria-pressed="false" aria-label="ダークモード" title="表示テーマを切り替える">
            <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" /></svg>
            <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2" /><path d="M12 2.5v2.3M12 19.2v2.3M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2.5 12h2.3M19.2 12h2.3M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6" /></svg>
          </button>
        </div>
      </div>
      {pathname !== '/' && (
        <nav class="site-nav" aria-label="主要なページ">
          <a href="/start/">はじめての方へ</a>
          <a href="/learn/">知る・学ぶ</a>
          <a href="/glossary/">用語集</a>
          <a href="/support/">相談先</a>
          <a href="/clinics/">医療機関</a>
          <a href="/map/">地図</a>
          <a href="/works/">文芸</a>
          <a href="/bibliography/">文献</a>
          <a href="/resources/">リンク</a>
          <a href="/sitemap/">サイトマップ</a>
        </nav>
      )}
    </header>
    <main id="main-content">
      {showBreadcrumb && (
        <nav class="breadcrumbs" aria-label="パンくずリスト">
          {breadcrumbTrail.map((item) => (
            <>
              <a href={item.href}>{item.label}</a>
              <span class="bc-sep" aria-hidden="true">›</span>
            </>
          ))}
          <span aria-current="page">{pageName}</span>
        </nav>
      )}
      <slot />
      {pageDate && (
        <p class="page-updated">
          このページは <time datetime={pageDate.updated}>{pageDate.updated}</time> に更新しました（{pageDate.created} 公開）。情報は変わることがあります。とくに医療・制度・費用は、最新の内容を各機関の公式情報でご確認ください。
        </p>
      )}
      {showBreadcrumb && <a class="back-top" href="#top">↑ ページの先頭へ</a>}
    </main>
    <footer class="site-footer">
      <div class="footer-main">
        <div class="footer-brand">
          <img class="footer-mark" src="/favicon.svg" alt="" width="40" height="40" />
          <div>
            <span class="footer-name">{siteName}</span>
            <span class="footer-tagline">{subtitle}</span>
          </div>
        </div>
        <nav class="footer-nav" aria-label="フッターナビゲーション">
          <div class="footer-col">
            <h2>はじめに</h2>
            <a href="/start/">はじめての方へ</a>
            <a href="/support/">相談先</a>
            <a href="/safety/">安全とこころ</a>
            <a href="/allies/">周囲の人へ</a>
            <a href="/guidelines/">SOGIガイドライン</a>
            <a href="/clinics/">医療機関</a>
            <a href="/map/">地図で探す</a>
          </div>
          <div class="footer-col">
            <h2>知る・学ぶ</h2>
            <a href="/learn/">知る・学ぶ（一覧）</a>
            <a href="/basics/">トランス・シス・ノンバイナリーって？</a>
            <a href="/dysphoria/">性別違和を知る</a>
            <a href="/transition/">性別移行を知る</a>
            <a href="/hrt-effects/">ホルモン療法で起きること</a>
            <a href="/presentation/">見た目と、毎日のこと</a>
            <a href="/glossary/">用語集</a>
            <a href="/flags/">プライドフラッグ</a>
            <a href="/pride/">記念日・イベント</a>
            <a href="/resources/">リンク</a>
          </div>
          <div class="footer-col">
            <h2>つながる・サイト</h2>
            <a href="https://discord.gg/S8NJGeS3Da" target="_blank" rel="noreferrer">Discord（おしゃべりの場）</a>
            <a href="https://github.com/transnavi/transnavi.jp" target="_blank" rel="noreferrer">GitHub（ソースコード）</a>
            <a href="/edit/">情報を送る</a>
            <a href="/about/">このサイトについて</a>
            <a href="/data/">データの引用・二次利用</a>
            <a href="/search/">サイト内検索</a>
            <a href="/sitemap/">サイトマップ</a>
            <a href="/legal/">掲載について</a>
          </div>
        </nav>
      </div>
      <div class="footer-legal">
        <span>コンテンツ: <a href="https://creativecommons.org/licenses/by-sa/4.0/deed.ja" rel="license">CC BY-SA 4.0</a></span>
        <span>コード: <a href="https://opensource.org/license/mit" rel="license">MIT</a></span>
      </div>
    </footer>
    <script is:inline src="/event-banner.js" defer></script>
    <script is:inline>
      (function () {
        var b = document.querySelector('.theme-toggle');
        if (b) b.setAttribute('aria-pressed', String(document.documentElement.getAttribute('data-theme') === 'dark'));
      })();
      document.addEventListener('click', function (e) {
        var btn = e.target.closest && e.target.closest('.theme-toggle');
        if (!btn) return;
        var dark = document.documentElement.getAttribute('data-theme') === 'dark';
        var next = dark ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        btn.setAttribute('aria-pressed', String(next === 'dark'));
        try {
          localStorage.setItem('theme', next);
        } catch (e2) {}
      });
    </script>
  </body>
</html>
