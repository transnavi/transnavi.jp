---
import '../styles/global.css';
import pageDates from '../data/page-dates.json';
import { ogCardFor } from '../data/og-routes.mjs';

interface Props {
  title?: string;
  description?: string;
}

const siteName = 'とらんすナビ';
const subtitle = '日本のトランスジェンダー情報ウィキ';
const {
  title = `${siteName} - ${subtitle}`,
  description = 'トランスジェンダー、ノンバイナリー、Xジェンダー、ジェンダーを探索中の人のための医療・制度・生活・地域情報。',
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
// Per-page Open Graph card (generated in postbuild by gen-og-images.mjs). The
// homepage and any unmapped route keep the hand-made /og-image.png.
const ogCard = ogCardFor(Astro.url.pathname);
const ogImage = new URL(ogCard ? `/og/${ogCard.slug}.png` : '/og-image.png', Astro.site).toString();
const siteUrl = Astro.site?.toString() ?? 'https://transnavi.jp/';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: siteName,
      description: 'トランスジェンダー、ノンバイナリー、Xジェンダー、ジェンダーを探索中の人のための情報サイト。',
      inLanguage: 'ja',
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#organization`,
      name: siteName,
      url: siteUrl,
      logo: new URL('/favicon.svg', Astro.site).toString(),
      sameAs: ['https://github.com/transnavi/transnavi.jp', 'https://discord.gg/S8NJGeS3Da'],
    },
  ],
};

// Breadcrumbs (auto-derived from the path; no per-page props needed).
const pathname = Astro.url.pathname;
const pageDate = (pageDates as Record<string, { created: string; updated: string }>)[pathname];
const pageName = title.split(' - ')[0].trim();
const learnPages = new Set([
  '/basics/', '/gender/', '/orientation/', '/intersex/', '/dysphoria/', '/transition/', '/hrt-effects/', '/hrt-medications/', '/fertility/',
  '/voice/', '/presentation/', '/hair-removal/', '/surgery/', '/cost/', '/legal-change/', '/coming-out/',
  '/everyday/', '/relationships/', '/safety/', '/puberty-blockers/', '/detransition/', '/flags/', '/pride/', '/history/',
]);
// 資料・リンク gathers the 文芸 / 文献 / リンク / 資料集 pages under one nav entry.
const referencePages = new Set(['/reference/', '/works/', '/bibliography/', '/resources/', '/guidelines/']);
const isGlossaryDetail = pathname.startsWith('/glossary/') && pathname !== '/glossary/';
const isClinicDetail = pathname.startsWith('/clinics/') && pathname !== '/clinics/';
const isLibrary = pathname.startsWith('/library/');

let section: { label: string; href: string } | null = null;
if (referencePages.has(pathname) || isLibrary) section = { label: '資料・リンク', href: '/reference/' };
else if (learnPages.has(pathname)) section = { label: '知る・学ぶ', href: '/learn/' };
else if (isGlossaryDetail) section = { label: '用語集', href: '/glossary/' };
else if (isClinicDetail) section = { label: '医療機関', href: '/clinics/' };

// Header nav + which entry is "current" for this page (highlighted).
const navItems = [
  { href: '/start/', label: 'はじめての方へ' },
  { href: '/learn/', label: '知る・学ぶ' },
  { href: '/glossary/', label: '用語集' },
  { href: '/support/', label: '相談先' },
  { href: '/clinics/', label: '医療機関' },
  { href: '/map/', label: '地図' },
  { href: '/reference/', label: '資料・リンク' },
  { href: '/sitemap/', label: 'サイトマップ' },
];
const activeNav =
  pathname === '/start/' ? '/start/'
  : pathname === '/support/' ? '/support/'
  : pathname === '/map/' ? '/map/'
  : pathname === '/sitemap/' ? '/sitemap/'
  : (pathname === '/glossary/' || isGlossaryDetail) ? '/glossary/'
  : (pathname === '/clinics/' || isClinicDetail) ? '/clinics/'
  : (referencePages.has(pathname) || isLibrary) ? '/reference/'
  : (pathname === '/learn/' || learnPages.has(pathname)) ? '/learn/'
  : null;
const breadcrumbTrail = [{ label: 'ホーム', href: '/' }, ...(section ? [section] : [])];
const showBreadcrumb = pathname !== '/';
const breadcrumbLd = showBreadcrumb
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [...breadcrumbTrail, { label: pageName, href: pathname }].map((item, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: item.label,
        item: new URL(item.href, Astro.site).toString(),
      })),
    }
  : null;

// Freshness for search engines: a WebPage with the git-derived dates.
const pageLd = pageDate
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: pageName,
      inLanguage: 'ja',
      isPartOf: { '@id': `${siteUrl}#website` },
      datePublished: pageDate.created,
      dateModified: pageDate.updated,
    }
  : null;
---

<!doctype html>
<html lang="ja" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      // Set the colour theme before paint (no flash): saved choice, else system.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t !== 'light' && t !== 'dark') {
            t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
          if (localStorage.getItem('furigana') === 'on') document.documentElement.setAttribute('data-furigana', 'on');
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffd6e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#171826" media="(prefers-color-scheme: dark)" />
    <meta http-equiv="content-language" content="ja" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
    {pageLd && <script type="application/ld+json" set:html={JSON.stringify(pageLd)} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ja" href={canonicalUrl} />
    <link rel="alternate" hreflang="ja-JP" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">本文へスキップ</a>
    <aside id="event-banner" class="event-banner" hidden aria-label="記念日・イベントのお知らせ">
      <div class="event-banner-stripe" aria-hidden="true"></div>
      <div class="event-banner-inner">
        <span class="event-banner-emoji" aria-hidden="true"></span>
        <span class="event-banner-text"></span>
        <a class="event-banner-link" href="/pride/"></a>
        <button class="event-banner-close" type="button" aria-label="このお知らせを閉じる">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" /></svg>
        </button>
      </div>
    </aside>
    <script type="application/json" id="event-banner-data" set:html={JSON.stringify([
      // Recurring awareness days/months. Each window recurs every year; `lead`
      // is how many days before the start to begin showing ("very close").
      // First match (top to bottom) wins.
      { id: 'pride-month', sm: 6, sd: 1, em: 6, ed: 30, lead: 0, emoji: '🏳️‍🌈', text: '6月はプライド月間（Pride Month）です。', href: '/pride/', cta: '記念日・イベント' },
      { id: 'tdor-week', sm: 11, sd: 13, em: 11, ed: 20, lead: 2, emoji: '🏳️‍⚧️', text: 'トランスジェンダー認知週間です（11月20日は追悼の日・TDOR）。', href: '/pride/', cta: 'くわしく' },
      { id: 'tdov', sm: 3, sd: 31, em: 3, ed: 31, lead: 6, emoji: '🏳️‍⚧️', text: '3月31日は国際トランスジェンダー認知の日（TDOV）です。', href: '/pride/', cta: 'くわしく' },
      { id: 'coming-out-day', sm: 10, sd: 11, em: 10, ed: 11, lead: 3, emoji: '💬', text: '10月11日は国際カミングアウトデーです。', href: '/coming-out/', cta: 'カミングアウトについて' },
      { id: 'idahobit', sm: 5, sd: 17, em: 5, ed: 17, lead: 3, emoji: '🌈', text: '5月17日は IDAHOBIT（差別に反対する国際デー）です。', href: '/pride/', cta: 'くわしく' },
      { id: 'nonbinary-day', sm: 7, sd: 14, em: 7, ed: 14, lead: 2, emoji: '💛', text: '7月14日はノンバイナリーの日です。', href: '/flags/', cta: 'フラッグ' },
    ])} />
    <header class="site-header" id="top">
      <div class="header-top">
        <a class="brand" href="/" aria-label="とらんすナビ ホーム">
          <img class="brand-mark" src="/favicon.svg" alt="" width="44" height="44" />
          <span>
            <span class="brand-name">とらんすナビ</span>
            <span class="brand-subtitle">{subtitle}</span>
          </span>
        </a>
        <div class="header-tools">
          <form class="header-search" role="search" action="/search/" method="get">
            <input type="search" name="q" aria-label="サイト内を検索" placeholder="検索…" autocomplete="off" />
            <button type="submit" aria-label="検索する">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
            </button>
          </form>
          <button class="theme-toggle" type="button" aria-pressed="false" aria-label="ダークモード" title="表示テーマを切り替える">
            <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" /></svg>
            <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2" /><path d="M12 2.5v2.3M12 19.2v2.3M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2.5 12h2.3M19.2 12h2.3M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6" /></svg>
          </button>
          <button class="furigana-toggle" type="button" aria-pressed="false" aria-label="ふりがなを表示" title="漢字にふりがなを表示する">
            {/* The ふ glyph as an SVG path (from the site font, M PLUS Rounded 1c)
                so it is not a stray "ふ" text node for screen readers, text
                browsers or crawlers — the button's name comes from aria-label. */}
            <svg viewBox="50 -757 918 817" aria-hidden="true" focusable="false"><g transform="scale(1,-1)"><path fill="currentColor" d="M710 636Q622 620 571.0 581.5Q520 543 520 500Q520 471 538.0 439.5Q556 408 603 355Q662 289 684.5 243.5Q707 198 707 150Q707 54 639.5 -3.0Q572 -60 460 -60Q398 -60 331 -36Q309 -28 299.5 -5.5Q290 17 299 40L301 45Q309 66 331.0 75.5Q353 85 375 77Q422 60 454 60Q503 60 533.5 85.0Q564 110 564 150Q564 183 546.0 216.0Q528 249 476 303Q424 358 402.0 400.5Q380 443 380 487Q380 566 472 640Q473 641 473.0 642.0Q473 643 472 643H287Q264 643 247.0 660.0Q230 677 230.0 700.0Q230 723 247.0 740.0Q264 757 287 757H710Q733 757 750.0 740.0Q767 723 767 700Q767 676 750.5 658.5Q734 641 710 636ZM778 429Q800 439 823.0 431.0Q846 423 857 401Q917 285 965 148Q973 126 962.0 105.5Q951 85 929 78L921 75Q898 68 877.5 79.0Q857 90 850 112Q806 236 745 352Q734 372 741.0 393.5Q748 415 769 425ZM83 77Q61 86 53.5 107.5Q46 129 56 150Q107 260 147 383Q155 406 175.5 417.5Q196 429 219 424L228 422Q251 417 263.0 396.5Q275 376 268 354Q229 229 169 103Q159 81 136.0 72.5Q113 64 91 73Z"/></g></svg>
          </button>
        </div>
      </div>
      {pathname !== '/' && (
        <nav class="site-nav" aria-label="主要なページ">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[{ 'is-active': item.href === activeNav }]}
              aria-current={item.href === activeNav ? 'page' : undefined}
            >{item.label}</a>
          ))}
        </nav>
      )}
    </header>
    <main id="main-content">
      {showBreadcrumb && (
        <nav class="breadcrumbs" aria-label="パンくずリスト">
          {breadcrumbTrail.map((item) => (
            <>
              <a href={item.href}>{item.label}</a>
              <span class="bc-sep" aria-hidden="true">›</span>
            </>
          ))}
          <span aria-current="page">{pageName}</span>
        </nav>
      )}
      <div class="main-body">
        {/* Filled client-side from the article's <h2> headings (page-toc.js).
            Hidden until then; becomes a sticky sidebar on wide screens and a
            collapsible 目次 box on small ones. */}
        <nav id="page-toc" class="page-toc" aria-label="目次" hidden></nav>
        <div class="main-col">
          <slot />
          {pageDate && (
            <p class="page-updated">
              このページは <time datetime={pageDate.updated}>{pageDate.updated}</time> に更新しました（{pageDate.created} 公開）。情報は変わることがあります。とくに医療・制度・費用は、最新の内容を各機関の公式情報でご確認ください。
            </p>
          )}
          {showBreadcrumb && <a class="back-top" href="#top">↑ ページの先頭へ</a>}
        </div>
      </div>
    </main>
    <footer class="site-footer">
      <aside class="footer-crisis" aria-label="今すぐの相談先">
        <span class="footer-crisis-label">つらくて、今すぐ話したいとき</span>
        <a class="footer-crisis-tel" href="tel:0120279338" aria-label="よりそいホットラインに電話する 0120-279-338（24時間・無料・匿名）">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="15" height="15"><path d="M6.6 10.8a15.3 15.3 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1Z"/></svg>
          よりそいホットライン <strong>0120-279-338</strong><span class="footer-crisis-hours">24時間・無料・匿名</span>
        </a>
        <a class="footer-crisis-more" href="/support/">ほかの相談先・チャット相談を見る</a>
      </aside>
      <div class="footer-main">
        <div class="footer-brand">
          <img class="footer-mark" src="/favicon.svg" alt="" width="40" height="40" />
          <div>
            <span class="footer-name">{siteName}</span>
            <span class="footer-tagline">{subtitle}</span>
          </div>
        </div>
        <nav class="footer-nav" aria-label="フッターナビゲーション">
          <div class="footer-col">
            <h2>はじめに</h2>
            <a href="/start/">はじめての方へ</a>
            <a href="/faq/">よくある質問</a>
            <a href="/support/">相談先</a>
            <a href="/safety/">安全とこころ</a>
            <a href="/allies/">周囲の人へ</a>
            <a href="/guidelines/">SOGIガイドライン</a>
            <a href="/clinics/">医療機関</a>
            <a href="/map/">地図で探す</a>
          </div>
          <div class="footer-col">
            <h2>知る・学ぶ</h2>
            <a href="/learn/">知る・学ぶ（一覧）</a>
            <a href="/basics/">トランス・シス・ノンバイナリーって？</a>
            <a href="/dysphoria/">性別違和を知る</a>
            <a href="/transition/">性別移行を知る</a>
            <a href="/hrt-effects/">ホルモン療法で起きること</a>
            <a href="/presentation/">見た目と、毎日のこと</a>
            <a href="/glossary/">用語集</a>
            <a href="/flags/">プライドフラッグ</a>
            <a href="/pride/">記念日・イベント</a>
            <a href="/resources/">リンク</a>
          </div>
          <div class="footer-col">
            <h2>つながる・サイト</h2>
            <a href="https://discord.gg/S8NJGeS3Da" target="_blank" rel="noreferrer">Discord（おしゃべりの場）</a>
            <a href="https://github.com/transnavi/transnavi.jp" target="_blank" rel="noreferrer">GitHub（ソースコード）</a>
            <a href="/edit/">情報を送る</a>
            <a href="/about/">このサイトについて</a>
            <a href="/data/">データの引用・二次利用</a>
            <a href="/search/">サイト内検索</a>
            <a href="/sitemap/">サイトマップ</a>
            <a href="/legal/">掲載について</a>
          </div>
        </nav>
      </div>
      <div class="footer-legal">
        <span>コンテンツ: <a href="https://creativecommons.org/licenses/by-sa/4.0/deed.ja" rel="license">CC BY-SA 4.0</a></span>
        <span>コード: <a href="https://opensource.org/license/mit" rel="license">MIT</a></span>
      </div>
    </footer>
    <script is:inline src="/event-banner.js" defer></script>
    <script is:inline src="/page-toc.js" defer></script>
    <script is:inline>
      (function () {
        var el = document.documentElement;
        var b = document.querySelector('.theme-toggle');
        if (b) b.setAttribute('aria-pressed', String(el.getAttribute('data-theme') === 'dark'));
        var f = document.querySelector('.furigana-toggle');
        if (f) f.setAttribute('aria-pressed', String(el.getAttribute('data-furigana') === 'on'));
      })();
      document.addEventListener('click', function (e) {
        var el = document.documentElement;
        var btn = e.target.closest && e.target.closest('.theme-toggle');
        if (btn) {
          var next = el.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          el.setAttribute('data-theme', next);
          btn.setAttribute('aria-pressed', String(next === 'dark'));
          try { localStorage.setItem('theme', next); } catch (e2) {}
          return;
        }
        var fbtn = e.target.closest && e.target.closest('.furigana-toggle');
        if (fbtn) {
          var on = el.getAttribute('data-furigana') === 'on';
          if (on) el.removeAttribute('data-furigana'); else el.setAttribute('data-furigana', 'on');
          fbtn.setAttribute('aria-pressed', String(!on));
          try { localStorage.setItem('furigana', on ? 'off' : 'on'); } catch (e3) {}
        }
      });
    </script>
  </body>
</html>
