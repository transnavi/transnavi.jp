---
import mascots from '../data/mascots.json';

interface Props {
  name: keyof typeof mascots;
  variant?: 'spot' | 'hero';
}
const { name, variant = 'spot' } = Astro.props;
const svg = (mascots as Record<string, string>)[name] ?? '';
---

{svg && (
  <div class:list={['mascot', `mascot-${variant}`]} aria-hidden="true" set:html={svg} />
)}
